---
import '../styles/global.css';
import '../styles/PlantillaAdmin.css';

interface Props {
  titulo: string;
  paginaActual: 'dashboard' | 'alumnos' | 'cursos' | 'tickets';
}

const { titulo, paginaActual } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{titulo} — Cursos Umme Admin</title>
  </head>
  <body>
    <div class="admin-layout">

      <!-- Sidebar -->
      <aside class="sidebar">
        <div class="sidebar-logo">
          <a href="/admin">
            <span class="logo-marca">Cursos</span>
            <span class="logo-umme">Umme</span>
          </a>
        </div>

        <div class="sidebar-seccion">
          <p class="sidebar-seccion-label">General</p>
          <ul class="sidebar-nav">
            <li>
              <a href="/admin" class={paginaActual === 'dashboard' ? 'activo' : ''}>
                <svg viewBox="0 0 16 16" fill="none">
                  <rect x="1" y="1" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
                  <rect x="9" y="1" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
                  <rect x="1" y="9" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
                  <rect x="9" y="9" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
                </svg>
                Dashboard
              </a>
            </li>
          </ul>
        </div>

        <div class="sidebar-seccion">
          <p class="sidebar-seccion-label">Gestion</p>
          <ul class="sidebar-nav">
            <li>
              <a href="/admin/alumnos" class={paginaActual === 'alumnos' ? 'activo' : ''}>
                <svg viewBox="0 0 16 16" fill="none">
                  <circle cx="8" cy="5" r="3" stroke="currentColor" stroke-width="1.4"/>
                  <path d="M2 14c0-3.314 2.686-6 6-6s6 2.686 6 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                </svg>
                Alumnos
              </a>
            </li>
            <li>
              <a href="/admin/cursos" class={paginaActual === 'cursos' ? 'activo' : ''}>
                <svg viewBox="0 0 16 16" fill="none">
                  <rect x="1" y="3" width="14" height="10" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
                  <path d="M5 7h6M5 10h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                </svg>
                Cursos
              </a>
            </li>
            <li>
              <a href="/admin/tickets" id="linkTickets" class={paginaActual === 'tickets' ? 'activo' : ''} style="position:relative;">
                <svg viewBox="0 0 16 16" fill="none">
                  <path d="M2 3.5A1.5 1.5 0 013.5 2h9A1.5 1.5 0 0114 3.5v7A1.5 1.5 0 0112.5 12H9l-3 2v-2H3.5A1.5 1.5 0 012 10.5v-7z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
                  <path d="M5 6h6M5 8.5h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Soporte
                <span id="adminTicketsBadge" style="display:none; position:absolute; top:6px; right:10px; width:8px; height:8px; background:#e53; border-radius:50%; border:1.5px solid #fff;"></span>
              </a>
            </li>
          </ul>
        </div>

        <!-- Footer del sidebar: info de Rocío -->
        <div class="sidebar-footer">
          <div class="sidebar-avatar">
            <svg viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="8" r="4" fill="#555"/>
              <path d="M4 20c0-4.418 3.582-8 8-8s8 3.582 8 8" fill="#555"/>
            </svg>
          </div>
          <div class="sidebar-usuario-info">
            <span class="sidebar-usuario-nombre">Umme</span>
            <span class="sidebar-usuario-rol">Administradora</span>
          </div>
        </div>
      </aside>

      <!-- Contenido -->
      <div class="admin-contenido">
        <header class="admin-header">
          <span class="admin-header-titulo">{titulo}</span>
          <div class="admin-header-acciones">
            <button id="btn-logout" class="btn-admin">
              <svg viewBox="0 0 16 16" fill="none">
                <path d="M10 4l-4 4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Salir
            </button>
          </div>
        </header>

        <div class="admin-cuerpo">
          <slot />
        </div>
      </div>

    </div>

  <!-- Capa anti-captura -->
  <div id="pantalla-negra" aria-hidden="true" style="display:none;position:fixed;inset:0;background:#000;z-index:99999;pointer-events:none;"></div>

  <!-- GUARDIA DE RUTA: solo admin puede acceder -->
  <script is:inline>
    (function () {
      var overlay = document.getElementById('pantalla-negra');
      var timer = null;
      function mostrar() {
        overlay.style.display = 'block';
        clearTimeout(timer);
        timer = setTimeout(function () { overlay.style.display = 'none'; }, 2000);
      }
      document.addEventListener('keydown', function (e) {
        var k = e.key || '';
        if (k === 'PrintScreen') { mostrar(); return; }
        if (e.altKey && k === 'PrintScreen') { mostrar(); return; }
        if (e.metaKey && e.shiftKey && (k === 's' || k === 'S')) { mostrar(); return; }
        if (e.metaKey && e.shiftKey && (k === '3' || k === '4' || k === '5' || k === '6')) { mostrar(); return; }
        if (e.metaKey && e.ctrlKey && e.shiftKey && (k === '3' || k === '4')) { mostrar(); return; }
      });
      window.addEventListener('blur', function () { mostrar(); });
      document.addEventListener('visibilitychange', function () {
        if (document.hidden) mostrar();
        else overlay.style.display = 'none';
      });
      document.addEventListener('contextmenu', function (e) { e.preventDefault(); });
    })();
  </script>

  <script is:inline>
    (function () {
      try {
        var raw = sessionStorage.getItem('umme_session');
        if (!raw) { window.location.replace('/'); return; }
        var s = JSON.parse(raw);
        if (!s || Date.now() > s.exp) {
          sessionStorage.removeItem('umme_session');
          window.location.replace('/');
          return;
        }
        if (s.rol !== 'admin') {
          window.location.replace('/inicio');
          return;
        }
      } catch (e) {
        window.location.replace('/');
      }
    })();

    // Logout: borra la sesión y redirige al login
    document.getElementById('btn-logout').addEventListener('click', function () {
      sessionStorage.removeItem('umme_session');
      sessionStorage.removeItem('umme_admin_badge');
      window.location.replace('/');
    });

    // Badge de tickets abiertos sin responder (siempre en tiempo real)
    (function () {
      var s = {};
      try { s = JSON.parse(sessionStorage.getItem('umme_session') || '{}'); } catch {}
      if (!s.userId) return;
      var badge = document.getElementById('adminTicketsBadge');
      fetch('/api/tickets.php?admin=1&usuario_id=' + s.userId)
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (!data.ok) return;
          var hayAbiertos = (data.tickets || []).some(function (t) { return t.estado === 'abierto'; });
          if (hayAbiertos) badge.style.display = 'block';
        })
        .catch(function () {});
    })();
  </script>
  </body>
</html>
