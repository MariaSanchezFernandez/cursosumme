---
import '../styles/global.css';
import '../styles/PlantillaAdmin.css';
import SidebarAdmin from '../components/SidebarAdmin.astro';
import Toast from '../components/Toast.astro';
import BotonCargando from '../components/BotonCargando.astro';
import Modal from '../components/Modal.astro';

interface Props {
  titulo: string;
  paginaActual: 'dashboard' | 'alumnos' | 'cursos' | 'tickets' | 'perfil' | 'logs' | 'errores';
}

const { titulo, paginaActual } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{titulo} — Cursos Umme Admin</title>
  </head>
  <body>
    <!-- Hidratar sesión "Recordarme": copiar localStorage → sessionStorage si la sesión sigue vigente -->
    <script is:inline>
    (function () {
      try {
        if (sessionStorage.getItem('umme_session')) return;
        var raw = localStorage.getItem('umme_session');
        if (!raw) return;
        var s = JSON.parse(raw);
        if (!s || !s.exp || Date.now() > s.exp) {
          localStorage.removeItem('umme_session');
          return;
        }
        sessionStorage.setItem('umme_session', raw);
      } catch (e) {
        try { localStorage.removeItem('umme_session'); } catch (e2) {}
      }
    })();
    </script>

    <!-- Captura global de errores JS -->
    <script is:inline>
    (function () {
      var _enviados = {};
      function enviar(tipo, msg, url, linea, col, stack) {
        var clave = tipo + '|' + msg + '|' + (linea || '');
        if (_enviados[clave]) return;
        _enviados[clave] = true;
        try {
          var s = JSON.parse(sessionStorage.getItem('umme_session') || '{}');
          fetch('/api/log-error.php', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              tipo: 'admin_' + tipo, mensaje: String(msg).slice(0, 1000),
              url: String(url || location.href).slice(0, 500),
              linea: linea || null, columna: col || null,
              stack: String(stack || '').slice(0, 3000),
              usuario_id: s.userId || null, usuario_email: s.email || null,
            }),
          }).catch(function(){});
        } catch(e) {}
      }
      window.onerror = function(msg, src, linea, col, err) {
        enviar('js', msg, src, linea, col, err && err.stack);
        return false;
      };
      window.addEventListener('unhandledrejection', function(e) {
        var err = e.reason;
        enviar('promise', err && err.message ? err.message : String(err), location.href, null, null, err && err.stack);
      });

      // Helper para registrar errores "manejados" (uploads fallidos, llamadas API, etc.)
      window.logAppError = function(tipo, mensaje, extra) {
        extra = extra || {};
        try {
          var s = JSON.parse(sessionStorage.getItem('umme_session') || '{}');
          var msgFinal = String(mensaje).slice(0, 900);
          if (extra.detalle) msgFinal += ' | ' + String(extra.detalle).slice(0, 300);
          fetch('/api/log-error.php', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              tipo: 'admin_' + tipo,
              mensaje: msgFinal,
              url: location.href,
              linea: null, columna: null,
              stack: extra.stack || null,
              usuario_id: s.userId || null,
              usuario_email: s.email || null,
            }),
          }).catch(function(){});
        } catch(e) {}
      };
    })();
    </script>

    <div class="admin-layout">

      <SidebarAdmin paginaActual={paginaActual} />

      <!-- Contenido -->
      <div class="admin-contenido">
        <header class="admin-header">
          <button id="btn-menu" class="btn-menu-mobile" aria-label="Abrir menú" aria-expanded="false">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </button>
          <span class="admin-header-titulo">{titulo}</span>
          <div class="admin-header-acciones">
            <button id="btn-logout" class="btn-admin">
              <svg viewBox="0 0 16 16" fill="none">
                <path d="M10 4l-4 4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Salir
            </button>
          </div>
        </header>

        <div class="admin-cuerpo">
          <slot />
        </div>
      </div>

    </div>

    <!-- Sistema global de toasts (window.mostrarToast / window.toast.*) -->
    <Toast />

    <!-- Helper global de estado de carga en botones (window.botonCargando) -->
    <BotonCargando />

    <!-- Helper global de modal de confirmación (window.confirmar) -->
    <Modal />

    <!-- Helper global de estados vacíos (window.htmlEstadoVacio) -->
    <script is:inline>
      window.htmlEstadoVacio = function (o) {
        var ico  = o.icono  || '';
        var sub  = o.sub    ? '<p class="estado-vacio-sub">'   + o.sub   + '</p>' : '';
        var cta  = o.cta    ? '<a href="' + o.cta.href + '" class="estado-vacio-cta">' + o.cta.texto + '</a>' : '';
        return '<div class="estado-vacio">' + ico +
          '<p class="estado-vacio-titulo">' + o.titulo + '</p>' + sub + cta + '</div>';
      };
    </script>

    <!-- Helper global de errores en formularios (window.enfocarPrimerError) -->
    <script is:inline>
      window.enfocarPrimerError = function (form) {
        var primer = form.querySelector('.field--error input, .field--error select, .field--error textarea');
        if (primer) primer.focus();
      };
    </script>

    <!-- Interceptor fetch: añade X-Token automáticamente a todas las llamadas /api/ -->
    <script is:inline>
    (function () {
      var _origFetch = window.fetch.bind(window);
      window.fetch = function (url, opts) {
        try {
          var urlStr = typeof url === 'string' ? url : (url instanceof URL ? url.toString() : '');
          if (urlStr.startsWith('/api/')) {
            var s = {};
            try { s = JSON.parse(sessionStorage.getItem('umme_session') || '{}'); } catch (e) {}
            opts = opts ? Object.assign({}, opts) : {};
            opts.headers = Object.assign({ 'X-Token': s.token || '' }, opts.headers || {});
          }
        } catch (e) {}
        return _origFetch(url, opts);
      };
    })();
    </script>

  <script is:inline>
    var _s = {};
    try {
      var _raw = sessionStorage.getItem('umme_session');
      if (!_raw) { window.location.replace('/'); }
      else {
        _s = JSON.parse(_raw);
        if (!_s || Date.now() > _s.exp) {
          sessionStorage.removeItem('umme_session');
          localStorage.removeItem('umme_session');
          window.location.replace('/');
        } else if (_s.rol !== 'admin') {
          window.location.replace('/inicio');
        }
      }
    } catch (e) { window.location.replace('/'); }

    // Nombre del admin en el sidebar
    var _nombreEl = document.getElementById('sidebarNombreAdmin');
    if (_nombreEl && _s.nombre) _nombreEl.textContent = _s.nombre;

    // Drawer móvil: abrir/cerrar sidebar
    var _sidebar = document.getElementById('sidebarAdmin');
    var _overlay = document.getElementById('sidebarOverlay');
    var _btnMenu = document.getElementById('btn-menu');
    function abrirDrawer() {
      _sidebar.classList.add('abierto');
      _overlay.classList.add('activo');
      _btnMenu.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function cerrarDrawer() {
      _sidebar.classList.remove('abierto');
      _overlay.classList.remove('activo');
      _btnMenu.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
    if (_btnMenu) _btnMenu.addEventListener('click', abrirDrawer);
    if (_overlay) _overlay.addEventListener('click', cerrarDrawer);
    // Cerrar al pulsar cualquier enlace dentro del sidebar
    if (_sidebar) {
      _sidebar.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', cerrarDrawer);
      });
    }
    // Restaurar overflow al pasar a desktop
    window.addEventListener('resize', function () {
      if (window.innerWidth > 768) cerrarDrawer();
    });

    // Logout: invalida el token en BD y limpia el storage local
    document.getElementById('btn-logout').addEventListener('click', async function () {
      try {
        var _s2 = JSON.parse(sessionStorage.getItem('umme_session') || '{}');
        if (_s2.token) {
          await fetch('/api/logout.php', {
            method: 'POST',
            headers: { 'Authorization': 'Bearer ' + _s2.token },
          });
        }
      } catch (e) {}
      sessionStorage.removeItem('umme_session');
      sessionStorage.removeItem('umme_admin_badge');
      localStorage.removeItem('umme_session');
      window.location.replace('/');
    });

    // Badge tickets abiertos (tiempo real)
    if (_s.userId) {
      var _badge = document.getElementById('adminTicketsBadge');
      fetch('/api/tickets.php?admin=1&usuario_id=' + _s.userId)
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (!data.ok) return;
          var hayAbiertos = (data.tickets || []).some(function (t) { return t.estado === 'abierto'; });
          if (hayAbiertos && _badge) _badge.style.display = 'block';
        })
        .catch(function () {});
    }
  </script>
  </body>
</html>
