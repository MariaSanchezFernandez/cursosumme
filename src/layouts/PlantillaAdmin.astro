---
import '../styles/global.css';
import '../styles/PlantillaAdmin.css';
import Toast from '../components/Toast.astro';

interface Props {
  titulo: string;
  paginaActual: 'dashboard' | 'alumnos' | 'cursos' | 'tickets' | 'perfil' | 'logs' | 'errores';
}

const { titulo, paginaActual } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{titulo} — Cursos Umme Admin</title>
  </head>
  <body>
    <!-- Hidratar sesión "Recordarme": copiar localStorage → sessionStorage si la sesión sigue vigente -->
    <script is:inline>
    (function () {
      try {
        if (sessionStorage.getItem('umme_session')) return;
        var raw = localStorage.getItem('umme_session');
        if (!raw) return;
        var s = JSON.parse(raw);
        if (!s || !s.exp || Date.now() > s.exp) {
          localStorage.removeItem('umme_session');
          return;
        }
        sessionStorage.setItem('umme_session', raw);
      } catch (e) {
        try { localStorage.removeItem('umme_session'); } catch (e2) {}
      }
    })();
    </script>

    <!-- Captura global de errores JS -->
    <script is:inline>
    (function () {
      var _enviados = {};
      function enviar(tipo, msg, url, linea, col, stack) {
        var clave = tipo + '|' + msg + '|' + (linea || '');
        if (_enviados[clave]) return;
        _enviados[clave] = true;
        try {
          var s = JSON.parse(sessionStorage.getItem('umme_session') || '{}');
          fetch('/api/log-error.php', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              tipo: 'admin_' + tipo, mensaje: String(msg).slice(0, 1000),
              url: String(url || location.href).slice(0, 500),
              linea: linea || null, columna: col || null,
              stack: String(stack || '').slice(0, 3000),
              usuario_id: s.userId || null, usuario_email: s.email || null,
            }),
          }).catch(function(){});
        } catch(e) {}
      }
      window.onerror = function(msg, src, linea, col, err) {
        enviar('js', msg, src, linea, col, err && err.stack);
        return false;
      };
      window.addEventListener('unhandledrejection', function(e) {
        var err = e.reason;
        enviar('promise', err && err.message ? err.message : String(err), location.href, null, null, err && err.stack);
      });

      // Helper para registrar errores "manejados" (uploads fallidos, llamadas API, etc.)
      window.logAppError = function(tipo, mensaje, extra) {
        extra = extra || {};
        try {
          var s = JSON.parse(sessionStorage.getItem('umme_session') || '{}');
          var msgFinal = String(mensaje).slice(0, 900);
          if (extra.detalle) msgFinal += ' | ' + String(extra.detalle).slice(0, 300);
          fetch('/api/log-error.php', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              tipo: 'admin_' + tipo,
              mensaje: msgFinal,
              url: location.href,
              linea: null, columna: null,
              stack: extra.stack || null,
              usuario_id: s.userId || null,
              usuario_email: s.email || null,
            }),
          }).catch(function(){});
        } catch(e) {}
      };
    })();
    </script>

    <div class="admin-layout">

      <!-- Overlay (solo móvil, cubre el contenido cuando el drawer está abierto) -->
      <div id="sidebarOverlay" class="sidebar-overlay" aria-hidden="true"></div>

      <!-- Sidebar -->
      <aside class="sidebar" id="sidebarAdmin">
        <div class="sidebar-logo">
          <a href="/admin">
            <span class="logo-marca">Cursos</span>
            <span class="logo-umme">Umme</span>
          </a>
        </div>

        <div class="sidebar-seccion">
          <p class="sidebar-seccion-label">General</p>
          <ul class="sidebar-nav">
            <li>
              <a href="/admin" class={paginaActual === 'dashboard' ? 'activo' : ''}>
                <svg viewBox="0 0 16 16" fill="none">
                  <rect x="1" y="1" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
                  <rect x="9" y="1" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
                  <rect x="1" y="9" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
                  <rect x="9" y="9" width="6" height="6" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
                </svg>
                Dashboard
              </a>
            </li>
          </ul>
        </div>

        <div class="sidebar-seccion">
          <p class="sidebar-seccion-label">Gestion</p>
          <ul class="sidebar-nav">
            <li>
              <a href="/admin/alumnos" class={paginaActual === 'alumnos' ? 'activo' : ''}>
                <svg viewBox="0 0 16 16" fill="none">
                  <circle cx="8" cy="5" r="3" stroke="currentColor" stroke-width="1.4"/>
                  <path d="M2 14c0-3.314 2.686-6 6-6s6 2.686 6 6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                </svg>
                Alumnos
              </a>
            </li>
            <li>
              <a href="/admin/cursos" class={paginaActual === 'cursos' ? 'activo' : ''}>
                <svg viewBox="0 0 16 16" fill="none">
                  <rect x="1" y="3" width="14" height="10" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
                  <path d="M5 7h6M5 10h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
                </svg>
                Cursos
              </a>
            </li>
            <li>
              <a href="/admin/tickets" id="linkTickets" class={paginaActual === 'tickets' ? 'activo' : ''} style="position:relative;">
                <svg viewBox="0 0 16 16" fill="none">
                  <path d="M2 3.5A1.5 1.5 0 013.5 2h9A1.5 1.5 0 0114 3.5v7A1.5 1.5 0 0112.5 12H9l-3 2v-2H3.5A1.5 1.5 0 012 10.5v-7z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
                  <path d="M5 6h6M5 8.5h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                </svg>
                Soporte
                <span id="adminTicketsBadge" style="display:none; position:absolute; top:6px; right:10px; width:8px; height:8px; background:#e53; border-radius:50%; border:1.5px solid #fff;"></span>
              </a>
            </li>
            <li>
              <a href="/admin/logs" class={paginaActual === 'logs' ? 'activo' : ''}>
                <svg viewBox="0 0 16 16" fill="none">
                  <path d="M3 3h10M3 6h10M3 9h6M3 12h4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                </svg>
                Log de cambios
              </a>
            </li>
            <li>
              <a href="/admin/errores" id="linkErrores" class={paginaActual === 'errores' ? 'activo' : ''} style="position:relative;">
                <svg viewBox="0 0 16 16" fill="none">
                  <path d="M8 2l6 11H2L8 2z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
                  <path d="M8 7v3M8 11.5v.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                </svg>
                Errores
                <span id="erroresBadge" style="display:none; position:absolute; top:6px; right:10px; min-width:16px; height:16px; background:#e53; border-radius:8px; border:1.5px solid #fff; font-size:0.6rem; font-weight:800; color:#fff; display:none; align-items:center; justify-content:center; padding:0 3px;"></span>
              </a>
            </li>
          </ul>
        </div>

        <!-- Footer del sidebar: perfil admin -->
        <a href="/admin/perfil" class="sidebar-footer" style="text-decoration:none; cursor:pointer;" title="Mi perfil">
          <div class="sidebar-avatar">
            <svg viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="8" r="4" fill="#555"/>
              <path d="M4 20c0-4.418 3.582-8 8-8s8 3.582 8 8" fill="#555"/>
            </svg>
          </div>
          <div class="sidebar-usuario-info">
            <span class="sidebar-usuario-nombre" id="sidebarNombreAdmin">—</span>
            <span class="sidebar-usuario-rol">Administradora</span>
          </div>
        </a>
      </aside>

      <!-- Contenido -->
      <div class="admin-contenido">
        <header class="admin-header">
          <button id="btn-menu" class="btn-menu-mobile" aria-label="Abrir menú" aria-expanded="false">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M4 7h16M4 12h16M4 17h16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </button>
          <span class="admin-header-titulo">{titulo}</span>
          <div class="admin-header-acciones">
            <button id="btn-logout" class="btn-admin">
              <svg viewBox="0 0 16 16" fill="none">
                <path d="M10 4l-4 4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Salir
            </button>
          </div>
        </header>

        <div class="admin-cuerpo">
          <slot />
        </div>
      </div>

    </div>

    <!-- Sistema global de toasts (window.mostrarToast / window.toast.*) -->
    <Toast />

  <script is:inline>
    var _s = {};
    try {
      var _raw = sessionStorage.getItem('umme_session');
      if (!_raw) { window.location.replace('/'); }
      else {
        _s = JSON.parse(_raw);
        if (!_s || Date.now() > _s.exp) {
          sessionStorage.removeItem('umme_session');
          localStorage.removeItem('umme_session');
          window.location.replace('/');
        } else if (_s.rol !== 'admin') {
          window.location.replace('/inicio');
        }
      }
    } catch (e) { window.location.replace('/'); }

    // Nombre del admin en el sidebar
    var _nombreEl = document.getElementById('sidebarNombreAdmin');
    if (_nombreEl && _s.nombre) _nombreEl.textContent = _s.nombre;

    // Drawer móvil: abrir/cerrar sidebar
    var _sidebar = document.getElementById('sidebarAdmin');
    var _overlay = document.getElementById('sidebarOverlay');
    var _btnMenu = document.getElementById('btn-menu');
    function abrirDrawer() {
      _sidebar.classList.add('abierto');
      _overlay.classList.add('activo');
      _btnMenu.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function cerrarDrawer() {
      _sidebar.classList.remove('abierto');
      _overlay.classList.remove('activo');
      _btnMenu.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
    if (_btnMenu) _btnMenu.addEventListener('click', abrirDrawer);
    if (_overlay) _overlay.addEventListener('click', cerrarDrawer);
    // Cerrar al pulsar cualquier enlace dentro del sidebar
    if (_sidebar) {
      _sidebar.querySelectorAll('a').forEach(function (a) {
        a.addEventListener('click', cerrarDrawer);
      });
    }
    // Restaurar overflow al pasar a desktop
    window.addEventListener('resize', function () {
      if (window.innerWidth > 768) cerrarDrawer();
    });

    // Logout (limpia también la sesión persistente "Recordarme")
    document.getElementById('btn-logout').addEventListener('click', function () {
      sessionStorage.removeItem('umme_session');
      sessionStorage.removeItem('umme_admin_badge');
      localStorage.removeItem('umme_session');
      window.location.replace('/');
    });

    // Badge tickets abiertos (tiempo real)
    if (_s.userId) {
      var _badge = document.getElementById('adminTicketsBadge');
      fetch('/api/tickets.php?admin=1&usuario_id=' + _s.userId)
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (!data.ok) return;
          var hayAbiertos = (data.tickets || []).some(function (t) { return t.estado === 'abierto'; });
          if (hayAbiertos && _badge) _badge.style.display = 'block';
        })
        .catch(function () {});
    }
  </script>
  </body>
</html>
