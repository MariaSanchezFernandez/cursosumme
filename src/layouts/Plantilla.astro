---
import '../styles/global.css';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Cursos Umme</title>
  </head>
  <body>
    <slot />
    <!-- Firma de marca: aparece en todas las páginas, esquina inferior izquierda -->
    <span class="firma">cursos umme</span>

    <!-- Capa anti-captura -->
    <div id="pantalla-negra" aria-hidden="true"></div>
  </body>
</html>

<style>
  /* Texto fijo en esquina inferior izquierda */
  .firma {
    position: fixed;
    bottom: 1rem;
    left: 1.25rem;
    font-size: 0.7rem;
    font-weight: 200;
    color: var(--color-text-muted);
    letter-spacing: 0.08em;
    z-index: 10;
    pointer-events: none;
  }

  /* Pantalla negra anti-captura */
  #pantalla-negra {
    display: none;
    position: fixed;
    inset: 0;
    background: #000;
    z-index: 99999;
    pointer-events: none;
  }
  #pantalla-negra.activa {
    display: block;
  }
</style>

<script is:inline>
  (function () {
    var overlay = document.getElementById('pantalla-negra');
    var timer = null;

    function mostrar() {
      overlay.classList.add('activa');
      clearTimeout(timer);
      timer = setTimeout(ocultar, 2000);
    }

    function ocultar() {
      overlay.classList.remove('activa');
    }

    // 1. Tecla PrintScreen y atajos comunes de captura
    document.addEventListener('keydown', function (e) {
      var k = e.key || '';

      // PrintScreen
      if (k === 'PrintScreen') { mostrar(); return; }

      // Windows: Win+Shift+S
      if (e.metaKey && e.shiftKey && (k === 's' || k === 'S')) { mostrar(); return; }

      // Mac: Cmd+Shift+3, Cmd+Shift+4, Cmd+Shift+5, Cmd+Ctrl+Shift+3/4
      if (e.metaKey && e.shiftKey && (k === '3' || k === '4' || k === '5' || k === '6')) { mostrar(); return; }
      if (e.metaKey && e.ctrlKey && e.shiftKey && (k === '3' || k === '4')) { mostrar(); return; }

      // Alt+PrintScreen
      if (e.altKey && k === 'PrintScreen') { mostrar(); return; }
    });

    // 2. Pérdida de foco: herramientas de grabación y captura la capturan
    window.addEventListener('blur', function () {
      mostrar();
    });
    document.addEventListener('visibilitychange', function () {
      if (document.hidden) mostrar();
      else ocultar();
    });

    // 3. Bloquear clic derecho
    document.addEventListener('contextmenu', function (e) { e.preventDefault(); });
  })();
</script>
