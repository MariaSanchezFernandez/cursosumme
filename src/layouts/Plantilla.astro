---
import '../styles/global.css';
import Toast from '../components/Toast.astro';
import BotonCargando from '../components/BotonCargando.astro';
import Modal from '../components/Modal.astro';
import BotonesFlair from '../components/BotonesFlair.astro';

interface Props {
  titulo?: string;
  // Meta description SEO (≈155 caracteres). Si no se pasa, se usa la genérica.
  descripcion?: string;
  // Imagen para Open Graph / Twitter Card (URL absoluta o ruta). Default: logo.
  imagenOg?: string;
  // Tipo Open Graph — "website" por defecto. Solo cambia en artículos de blog.
  tipoOg?: 'website' | 'article';
  // Excluir esta página de los buscadores. Útil en /login, /pago-ok, etc.
  noindex?: boolean;
  // Solo cargar el reproductor VdoCipher en páginas que de hecho lo usan
  // (inicio, preview, test-vdo). Son 352 KB que bloquean render: meterlo en
  // páginas sin vídeo (home, login, precios, legales…) ralentiza el primer paint.
  vdoCipher?: boolean;
  // BotonesFlair carga GSAP (~70 KB) y un MutationObserver del body solo
  // para el hover magnético de .cta--ghost. Hoy solo se usa en la home.
  botonesFlair?: boolean;
}
const {
  titulo = 'Cursos Umme',
  descripcion = 'Cursos online para preparar las oposiciones de Pedagogía Terapéutica: vídeo on-demand, temario actualizado y materiales descargables. Compra única, 1 año de acceso.',
  imagenOg = '/logo.png',
  tipoOg = 'website',
  noindex = false,
  vdoCipher = false,
  botonesFlair = false,
} = Astro.props;

// URL canónica y URL absoluta de la imagen OG. Astro.site se define en
// astro.config.mjs como 'https://cursosumme.es'.
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const imagenOgAbs = imagenOg.startsWith('http')
  ? imagenOg
  : new URL(imagenOg, Astro.site).href;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon-64.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <title>{titulo}</title>

    <!-- SEO básico -->
    <meta name="description" content={descripcion} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonical} />

    <!-- Open Graph (Facebook, WhatsApp, LinkedIn, Slack…) -->
    <meta property="og:site_name" content="Cursos Umme" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:type" content={tipoOg} />
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imagenOgAbs} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={titulo} />
    <meta name="twitter:description" content={descripcion} />
    <meta name="twitter:image" content={imagenOgAbs} />

    {vdoCipher && (
      <script is:inline data-cfasync="false" data-no-defer="1" src="https://player.vdocipher.com/v2/player.js"></script>
    )}
  </head>
  <body>

    <!-- 0) Anular la restauración automática del scroll del navegador.
         Chrome (y otros) recuerdan en qué scrollY estabas la última vez
         que visitaste cada URL y te dejan ahí al volver. En esta app eso
         hacía que /inicio (y otras páginas largas) abrieran con el footer
         a la vista, dando la sensación de "página rota". Forzamos siempre
         scroll arriba en cargas nuevas y en restauraciones del bfcache. -->
    <script is:inline>
    (function () {
      try { if ('scrollRestoration' in history) history.scrollRestoration = 'manual'; } catch (e) {}
      // Evita el flash de scroll a mitad cuando Chrome ya empezó a restaurar
      // antes de que este script corra: forzamos top en cuanto carga el DOM y
      // de nuevo tras la primera pintura para ganar a cualquier reflow.
      function arriba() { try { window.scrollTo(0, 0); } catch (e) {} }
      arriba();
      document.addEventListener('DOMContentLoaded', arriba, { once: true });
      window.addEventListener('pageshow', function (e) {
        // pageshow.persisted = true → la página viene del bfcache (back/forward)
        if (e.persisted) arriba();
      });
    })();
    </script>

    <!-- 1) Hidratar sesión "Recordarme" PRIMERO: copiar localStorage → sessionStorage si vigente.
         Tiene que ir antes del interceptor para que el primer fetch ya lleve el X-Token. -->
    <script is:inline>
    (function () {
      try {
        if (sessionStorage.getItem('umme_session')) return;
        var raw = localStorage.getItem('umme_session');
        if (!raw) return;
        var s = JSON.parse(raw);
        if (!s || !s.exp || Date.now() > s.exp) {
          localStorage.removeItem('umme_session');
          return;
        }
        sessionStorage.setItem('umme_session', raw);
      } catch (e) {
        try { localStorage.removeItem('umme_session'); } catch (e2) {}
      }
    })();
    </script>

    <!-- 2) Interceptor global: añade X-Token a todas las llamadas /api/ y, si la respuesta
         es 401 con una sesión guardada, limpia storage y redirige al login (evita que el
         usuario quede atrapado con un token caducado/invalidado mostrando "no se pudieron
         cargar los cursos"). -->
    <script is:inline>
    (function () {
      var _fetch = window.fetch;
      var PUBLICAS = ['/', '/login', '/login/', '/precios', '/precios/',
                      '/recuperar-contrasena', '/recuperar-contrasena/',
                      '/pago-ok', '/pago-ok/', '/pago-ko', '/pago-ko/', '/preview', '/preview/',
                      '/soporte', '/soporte/'];

      function sesionExpirada() {
        if (window._sesionExpiradaHandled) return;
        window._sesionExpiradaHandled = true;
        try {
          sessionStorage.removeItem('umme_session');
          localStorage.removeItem('umme_session');
        } catch (e) {}
        if (PUBLICAS.indexOf(window.location.pathname) !== -1) return;
        window.location.replace('/login?expirada=1');
      }

      window.fetch = function (url, opts) {
        if (typeof url === 'string' && url.startsWith('/api/')) {
          try {
            var s = JSON.parse(sessionStorage.getItem('umme_session') || '{}');
            var t = s.token || '';
            if (t) {
              opts = opts ? Object.assign({}, opts) : {};
              var h = opts.headers
                ? (opts.headers instanceof Headers
                    ? opts.headers
                    : Object.assign({}, opts.headers))
                : {};
              if (!h['X-Token']) h['X-Token'] = t;
              opts.headers = h;
            }
          } catch (e) {}
        }
        return _fetch.call(this, url, opts).then(function (res) {
          if (res.status === 401 && typeof url === 'string' && url.startsWith('/api/')) {
            // Solo redirigimos si HABÍA sesión (token rancio / caducado / invalidado).
            // Un 401 sin sesión guardada es flujo normal de no-logueado.
            try {
              if (sessionStorage.getItem('umme_session')) sesionExpirada();
            } catch (e) {}
          }
          return res;
        });
      };
    })();
    </script>

    <!-- Captura global de errores JS -->
    <script is:inline>
    (function () {
      var _enviados = {};
      function enviar(tipo, msg, url, linea, col, stack) {
        var clave = tipo + '|' + msg + '|' + (linea || '');
        if (_enviados[clave]) return;
        _enviados[clave] = true;
        try {
          var s = JSON.parse(sessionStorage.getItem('umme_session') || '{}');
          fetch('/api/log-error.php', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              tipo: tipo, mensaje: String(msg).slice(0, 1000),
              url: String(url || location.href).slice(0, 500),
              linea: linea || null, columna: col || null,
              stack: String(stack || '').slice(0, 3000),
              usuario_id: s.userId || null, usuario_email: s.email || null,
            }),
          }).catch(function(){});
        } catch(e) {}
      }
      window.onerror = function(msg, src, linea, col, err) {
        enviar('js', msg, src, linea, col, err && err.stack);
        return false;
      };
      window.addEventListener('unhandledrejection', function(e) {
        var err = e.reason;
        enviar('promise', err && err.message ? err.message : String(err), location.href, null, null, err && err.stack);
      });

      // Helper para registrar errores "manejados" (uploads fallidos, llamadas API, etc.)
      window.logAppError = function(tipo, mensaje, extra) {
        extra = extra || {};
        try {
          var s = JSON.parse(sessionStorage.getItem('umme_session') || '{}');
          var msgFinal = String(mensaje).slice(0, 900);
          if (extra.detalle) msgFinal += ' | ' + String(extra.detalle).slice(0, 300);
          fetch('/api/log-error.php', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              tipo: tipo,
              mensaje: msgFinal,
              url: location.href,
              linea: null, columna: null,
              stack: extra.stack || null,
              usuario_id: s.userId || null,
              usuario_email: s.email || null,
            }),
          }).catch(function(){});
        } catch(e) {}
      };
    })();
    </script>

    <slot />

    <!-- Sistema global de toasts (window.mostrarToast / window.toast.*) -->
    <Toast />

    <!-- Helper global de estado de carga en botones (window.botonCargando) -->
    <BotonCargando />

    <!-- Helper global de modal de confirmación (window.confirmar) -->
    <Modal />

    <!-- Efecto magnetic flair (GSAP) en CTAs .cta--ghost — solo donde se usa. -->
    {botonesFlair && <BotonesFlair />}

    <!-- Helper global de estados vacíos (window.htmlEstadoVacio) -->
    <script is:inline>
      window.htmlEstadoVacio = function (o) {
        var ico  = o.icono  || '';
        var sub  = o.sub    ? '<p class="estado-vacio-sub">'   + o.sub   + '</p>' : '';
        var cta  = o.cta    ? '<a href="' + o.cta.href + '" class="estado-vacio-cta">' + o.cta.texto + '</a>' : '';
        return '<div class="estado-vacio">' + ico +
          '<p class="estado-vacio-titulo">' + o.titulo + '</p>' + sub + cta + '</div>';
      };
    </script>

    <!-- Helper global de errores en formularios (window.enfocarPrimerError) -->
    <script is:inline>
      window.enfocarPrimerError = function (form) {
        var primer = form.querySelector('.field--error input, .field--error select, .field--error textarea');
        if (primer) primer.focus();
      };
    </script>
  </body>
</html>
