---
import '../styles/TarjetaCurso.css';

interface Props {
  titulo: string;
  etiqueta: string;
  subtemas: number;
  duracion: string;
  nivel: string;
  acento: 'c1' | 'c2' | 'c3' | 'c4';
  temas: { titulo: string; duracion: string }[];
}

const { titulo, etiqueta, subtemas, duracion, nivel, acento, temas } = Astro.props;
---

<article class="curso" data-titulo={titulo} data-temas={JSON.stringify(temas)}>
  <button class="curso-fila">
    <div class={`curso-acento ${acento}`}></div>
    <div class="curso-info">
      <span class="etiqueta">{etiqueta}</span>
      <h2>{titulo}</h2>
      <div class="curso-meta">
        <span>{subtemas} subtemas</span>
        <span>·</span>
        <span>{duracion}</span>
        <span>·</span>
        <span>{nivel}</span>
      </div>
    </div>
    <svg class="chevron-fila" viewBox="0 0 16 16" fill="none">
      <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
</article>
