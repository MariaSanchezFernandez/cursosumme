---
interface Props {
  titulo: string;
  etiqueta: string;
  subtemas: number;
  duracion: string;
  nivel: string;
  acento: 'c1' | 'c2' | 'c3' | 'c4';
  temas: { titulo: string; duracion: string }[];
}

const { titulo, etiqueta, subtemas, duracion, nivel, acento, temas } = Astro.props;
---

<article class="curso" data-titulo={titulo} data-temas={JSON.stringify(temas)}>
  <button class="curso-fila">
    <div class={`curso-acento ${acento}`}></div>
    <div class="curso-info">
      <span class="etiqueta">{etiqueta}</span>
      <h2>{titulo}</h2>
      <div class="curso-meta">
        <span>{subtemas} subtemas</span>
        <span>·</span>
        <span>{duracion}</span>
        <span>·</span>
        <span>{nivel}</span>
      </div>
    </div>
    <svg class="chevron-fila" viewBox="0 0 16 16" fill="none">
      <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
</article>

<style>
  .curso {
    border: 1px solid #e8eeec; border-radius: 8px;
    overflow: hidden; transition: border-color 0.15s;
  }
  .curso.activo { border-color: var(--color-primary); background: #f4faf8; }

  .curso-fila {
    width: 100%; display: flex; align-items: center; gap: 1rem;
    padding: 1.1rem 1rem; background: none; border: none;
    cursor: pointer; font-family: inherit; text-align: left;
    transition: background 0.12s;
  }
  .curso-fila:hover { background: #f7faf9; }
  .curso.activo .curso-fila { background: transparent; }

  .curso-acento { flex-shrink: 0; width: 5px; height: 44px; border-radius: 4px; }
  .c1 { background: var(--color-primary); }
  .c2 { background: var(--color-secondary); }
  .c3 { background: var(--color-coral); }
  .c4 { background: #d4c9f7; }

  .curso-info { flex: 1; min-width: 0; }

  .etiqueta {
    display: inline-block; font-size: 0.65rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.07em;
    color: var(--color-text-muted); margin-bottom: 0.2rem;
  }

  .curso-info h2 {
    font-size: 0.88rem; font-weight: 600; margin-bottom: 0.25rem;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  .curso-meta {
    display: flex; gap: 0.35rem; align-items: center;
    font-size: 0.72rem; color: #aaa;
  }

  .chevron-fila { flex-shrink: 0; width: 16px; height: 16px; color: #ccc; transition: color 0.12s; }
  .curso-fila:hover .chevron-fila { color: #999; }
</style>
