---
/**
 * COMPONENTE: PanelDetalleTabs
 * ----------------------------
 * Panel de contenido de un tema: tabs Lección / Materiales,
 * reproductor de vídeo (VdoCipher DRM + HTML5 local),
 * playlist y lista de materiales descargables.
 *
 * Los IDs internos los gestiona el JS de inicio.astro.
 */
---

<div class="panel-contenido" id="panelContenido">

  <div class="tabs" role="tablist">
    <button class="tab activo" data-tab="leccion" role="tab">
      <svg viewBox="0 0 16 16" fill="none">
        <rect x="2" y="3" width="12" height="10" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
        <path d="M5 6h6M5 9h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
      </svg>
      Lección
    </button>
    <button class="tab" data-tab="materiales" role="tab">
      <svg viewBox="0 0 16 16" fill="none">
        <path d="M4 2h6l4 4v8a1 1 0 01-1 1H4a1 1 0 01-1-1V3a1 1 0 011-1z" stroke="currentColor" stroke-width="1.4"/>
        <path d="M10 2v4h4" stroke="currentColor" stroke-width="1.4"/>
      </svg>
      Materiales
    </button>
  </div>

  <!-- Panel Lección -->
  <div class="tab-panel activo" id="tab-leccion">
    <!-- Título y descripción del tema -->
    <div class="leccion-texto">
      <h3 class="leccion-titulo" id="leccionTitulo"></h3>
      <div class="leccion-descripcion" id="leccionDescripcion"></div>
    </div>
    <div class="video-box">
      <!-- Reproductor VdoCipher DRM (web component — player.js) -->
      <div id="vdoWrapper" style="display:none; position:relative; width:100%; padding-top:56.25%; border-radius:10px; overflow:hidden; background:#000; flex-shrink:0;">
        <div id="vdoPlayerContainer" style="position:absolute; top:0; left:0; width:100%; height:100%;"></div>
      </div>
      <!-- Placeholder cuando el vídeo VdoCipher está procesando -->
      <div id="vdoProcesando" style="display:none; width:100%; padding:2.5rem 0; text-align:center; background:#111; border-radius:10px; color:#aaa; font-size:0.85rem; flex-shrink:0;">
        <svg viewBox="0 0 24 24" fill="none" width="28" height="28" style="margin-bottom:0.5rem; opacity:0.5;">
          <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
          <path d="M12 7v5l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <p style="margin:0;">El vídeo se está procesando…</p>
        <p style="margin:0.25rem 0 0; font-size:0.75rem; opacity:0.6;">Estará disponible en unos minutos</p>
      </div>
      <!-- Reproductor HTML5 local (vídeos sin DRM) -->
      <video id="videoPlayer" controls
        controlslist="nodownload nofullscreen noremoteplayback"
        disablepictureinpicture
        style="width:100%; height:100%; display:none; background:#000; border-radius:10px;">
      </video>
      <!-- Marca de agua con email del alumno (solo player local) -->
      <div class="video-marca-agua" id="videoMarcaAgua"></div>
      <!-- Placeholder cuando no hay vídeo seleccionado -->
      <div class="video-inner" id="videoPlaceholder">
        <svg viewBox="0 0 64 64" fill="none">
          <circle cx="32" cy="32" r="20" fill="rgba(255,255,255,0.15)"/>
          <polygon points="27,22 27,42 46,32" fill="white"/>
        </svg>
        <span class="video-titulo-overlay" id="videoTitulo">Selecciona un tema</span>
      </div>
    </div>
    <!-- Playlist (solo visible si el tema tiene más de un vídeo) -->
    <div id="videoPlaylist" class="video-playlist" style="display:none;"></div>
  </div>

  <!-- Panel Materiales -->
  <div class="tab-panel" id="tab-materiales">
    <div class="materiales-lista" id="materialesLista">
      <p style="font-size:0.85rem; color:#aaa; padding:0.5rem 0;">
        Selecciona un tema para ver sus materiales.
      </p>
    </div>
  </div>

</div>
