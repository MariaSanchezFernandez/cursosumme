---
import '../styles/PanelDetalle.css';
import PanelDetalleTabs from './PanelDetalleTabs.astro';
---

<div class="col-detalle" id="colDetalle">

  <!-- Cabecera -->
  <div class="detalle-top">
    <button class="btn-toggle-lista" id="btnToggleLista" title="Ocultar panel de cursos">
      <svg viewBox="0 0 16 16" fill="none">
        <rect x="1.5" y="1.5" width="13" height="13" rx="2" stroke="currentColor" stroke-width="1.3"/>
        <path d="M6 1.5V14.5" stroke="currentColor" stroke-width="1.3"/>
        <path d="M3.5 5H4.5M3.5 8H4.5M3.5 11H4.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
      </svg>
    </button>
    <button class="btn-volver" id="btnVolver">
      <svg viewBox="0 0 16 16" fill="none">
        <path d="M10 4l-4 4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="btn-volver-desktop">Volver</span>
      <span class="btn-volver-mobile">Mis cursos</span>
    </button>
    <span class="detalle-titulo-curso" id="detalleTitulo"></span>
  </div>

  <!-- Barra de progreso del curso -->
  <div class="curso-progreso" title="Disponible próximamente">
    <div class="curso-progreso-info">
      <span class="curso-progreso-titulo">Progreso del curso</span>
      <span class="curso-progreso-dato">
        <span id="temasCompletados">0</span> de <span id="temasTotal">0</span> temas completados
      </span>
    </div>
    <div class="curso-progreso-barra">
      <div class="curso-progreso-fill" id="progresoFill" style="width: 0%"></div>
    </div>
    <span class="curso-progreso-pct" id="progresoPct">0%</span>
  </div>

  <!-- Cuerpo -->
  <div class="detalle-cuerpo">

    <!-- Sidebar de navegación entre temas (visible solo al ver un tema) -->
    <aside class="panel-subtemas" id="panelSubtemas">
      <p class="subtemas-label">Contenido del curso</p>
      <ol id="listaTemas"></ol>
    </aside>

    <!-- Vista intro del curso (descripcion + índice de temas) -->
    <div class="panel-contenido" id="panelIntro" style="display:none; overflow-y:auto; padding:0; flex-direction:column; gap:0;">

      <div class="intro-layout">

        <!-- Columna izquierda: foto + título + descripción -->
        <div class="intro-col-izq">
          <div class="intro-hero-imagen" id="introCursoBanner" style="display:none;">
            <img src="" alt="" />
          </div>
          <h1 class="intro-curso-titulo" id="introCursoTitulo"></h1>
          <div class="intro-stats" id="introStats"></div>
          <div id="introDescripcion" class="intro-desc"></div>
        </div>

        <!-- Columna derecha: lista de temas -->
        <div class="intro-col-der">
          <h2 class="intro-curriculum-titulo">Contenido del curso</h2>
          <ol class="intro-temas-lista" id="introTemaLista"></ol>
        </div>

      </div>

    </div>

    <!-- Video + tabs -->
    <PanelDetalleTabs />
  </div>
</div>
