---
import '../styles/PanelDetalle.css';
---

<div class="col-detalle" id="colDetalle">

  <!-- Cabecera -->
  <div class="detalle-top">
    <button class="btn-volver" id="btnVolver">
      <svg viewBox="0 0 16 16" fill="none">
        <path d="M10 4l-4 4 4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Volver
    </button>
    <span class="detalle-titulo-curso" id="detalleTitulo"></span>
  </div>

  <!-- Barra de progreso del curso -->
  <div class="curso-progreso" title="Disponible próximamente">
    <div class="curso-progreso-info">
      <span class="curso-progreso-titulo">Progreso del curso</span>
      <span class="curso-progreso-dato">
        <span id="temasCompletados">0</span> de <span id="temasTotal">0</span> temas completados
      </span>
    </div>
    <div class="curso-progreso-barra">
      <div class="curso-progreso-fill" id="progresoFill" style="width: 0%"></div>
    </div>
    <span class="curso-progreso-pct" id="progresoPct">0%</span>
  </div>

  <!-- Cuerpo -->
  <div class="detalle-cuerpo">

    <!-- Sidebar de navegación entre temas (visible solo al ver un tema) -->
    <aside class="panel-subtemas" id="panelSubtemas">
      <p class="subtemas-label">Contenido del curso</p>
      <ol id="listaTemas"></ol>
    </aside>

    <!-- Vista intro del curso (descripcion + índice de temas) -->
    <div class="panel-contenido" id="panelIntro" style="display:none; overflow-y:auto; padding:0; flex-direction:column; gap:0;">
      <div id="introCursoBanner" style="display:none; width:100%; flex-shrink:0;">
        <img src="" alt="" style="width:100%; height:280px; object-fit:contain; background:#f3f6f4; display:block;" />
      </div>
      <div style="padding:1.75rem 2rem; display:flex; flex-direction:column; gap:1.25rem; flex:1;">
      <div id="introDescripcion" class="intro-desc"></div>
      <div>
        <p class="intro-temas-label">Contenido del curso</p>
        <ol class="intro-temas-lista" id="introTemaLista"></ol>
      </div>
      </div>
    </div>

    <!-- Video + tabs -->
    <div class="panel-contenido" id="panelContenido">

      <div class="tabs" role="tablist">
        <button class="tab activo" data-tab="leccion" role="tab">
          <svg viewBox="0 0 16 16" fill="none">
            <rect x="2" y="3" width="12" height="10" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
            <path d="M5 6h6M5 9h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
          </svg>
          Lección
        </button>
        <button class="tab" data-tab="materiales" role="tab">
          <svg viewBox="0 0 16 16" fill="none">
            <path d="M4 2h6l4 4v8a1 1 0 01-1 1H4a1 1 0 01-1-1V3a1 1 0 011-1z" stroke="currentColor" stroke-width="1.4"/>
            <path d="M10 2v4h4" stroke="currentColor" stroke-width="1.4"/>
          </svg>
          Materiales
        </button>
      </div>

      <!-- Panel Lección -->
      <div class="tab-panel activo" id="tab-leccion">
        <div class="leccion-texto">
          <h3 class="leccion-titulo" id="leccionTitulo">Selecciona un tema para comenzar</h3>
          <p class="leccion-descripcion" id="leccionDescripcion"></p>
        </div>
        <div class="video-box">
          <!-- Reproductor real -->
          <video id="videoPlayer" controls
            controlslist="nodownload nofullscreen noremoteplayback"
            disablepictureinpicture
            style="width:100%; height:100%; display:none; background:#000; border-radius:10px;">
          </video>
          <!-- Marca de agua con email del alumno -->
          <div class="video-marca-agua" id="videoMarcaAgua"></div>
          <!-- Placeholder cuando no hay vídeo seleccionado -->
          <div class="video-inner" id="videoPlaceholder">
            <svg viewBox="0 0 64 64" fill="none">
              <circle cx="32" cy="32" r="20" fill="rgba(255,255,255,0.15)"/>
              <polygon points="27,22 27,42 46,32" fill="white"/>
            </svg>
            <span class="video-titulo-overlay" id="videoTitulo">Selecciona un tema</span>
          </div>
        </div>
      </div>

      <!-- Panel Materiales -->
      <div class="tab-panel" id="tab-materiales">
        <div class="materiales-lista" id="materialesLista">
          <p style="font-size:0.85rem; color:#aaa; padding:0.5rem 0;">
            Selecciona un tema para ver sus materiales.
          </p>
        </div>
      </div>

    </div>
  </div>
</div>
