---
/**
 * COMPONENTE: Button
 * ------------------
 * Botón principal reutilizable con el coral de marca.
 *
 * Props:
 *   - text  {string}  Texto que muestra el botón
 *   - type  {string}  Tipo del botón (submit, button, reset). Por defecto: button
 */
import '../styles/Boton.css';
const { text, type = 'button' } = Astro.props;
---

<!-- Botón reutilizable
     PENDIENTE: añadir soporte para variantes de color cuando sea necesario -->
<button type={type} class="btn">
  {text}
</button>

