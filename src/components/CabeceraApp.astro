---
import '../styles/CabeceraApp.css';
---

<header class="header">
  <a class="logo" href="/inicio">
    <span class="logo-marca">Cursos</span>
    <span class="logo-umme">Umme</span>
  </a>

  <div class="usuario">
    <span class="avatar-circulo" id="avatarBtn" title="Cambiar foto de perfil">
      <svg id="avatarSvg" viewBox="0 0 24 24" fill="none">
        <circle cx="12" cy="8" r="4" fill="#555"/>
        <path d="M4 20c0-4.418 3.582-8 8-8s8 3.582 8 8" fill="#555"/>
      </svg>
    </span>
    <input type="file" id="avatar-file-input" accept="image/jpeg,image/png,image/webp,image/gif" />
    <a class="avatar-nombre" id="nombreUsuario" href="/perfil" title="Mi perfil">—</a>
    <a class="btn-cursos" href="/inicio" title="Mis cursos">
      <svg viewBox="0 0 16 16" fill="none" width="14" height="14">
        <rect x="1" y="3" width="14" height="10" rx="1.5" stroke="currentColor" stroke-width="1.4"/>
        <path d="M5 7h6M5 10h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
      </svg>
      Mis cursos
    </a>
    <a class="btn-soporte" href="/soporte" title="Soporte y consultas" id="btnSoporte">
      <svg viewBox="0 0 16 16" fill="none" width="14" height="14">
        <path d="M2 3.5A1.5 1.5 0 013.5 2h9A1.5 1.5 0 0114 3.5v7A1.5 1.5 0 0112.5 12H9l-3 2v-2H3.5A1.5 1.5 0 012 10.5v-7z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
        <path d="M5 6h6M5 8.5h4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      Soporte
      <span class="soporte-badge" id="soporteBadge" style="display:none;"></span>
    </a>
    <button class="btn-salir" id="btnSalir">
      <svg viewBox="0 0 16 16" fill="none">
        <path d="M10 8H3M3 8l2.5-2.5M3 8l2.5 2.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M8 4V3a1 1 0 011-1h3a1 1 0 011 1v10a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
      Salir
    </button>
  </div>
</header>

<script>
  const s = (() => { try { return JSON.parse(sessionStorage.getItem('umme_session') || '{}'); } catch { return {}; } })();

  // Nombre
  if (s.email) {
    document.getElementById('nombreUsuario')!.textContent = s.nombre || s.email.split('@')[0];
  }

  // Cargar foto actual
  const avatarBtn = document.getElementById('avatarBtn') as HTMLElement;
  const avatarSvg = document.getElementById('avatarSvg') as HTMLElement;
  const fileInput = document.getElementById('avatar-file-input') as HTMLInputElement;

  async function cargarFoto() {
    if (!s.userId) return;
    // Use cached URL from session to avoid extra request on every page
    const cached = sessionStorage.getItem('umme_foto');
    if (cached) { mostrarFoto(cached); return; }
    try {
      const res  = await fetch(`/api/foto-perfil.php?usuario_id=${s.userId}`);
      const data = await res.json();
      if (data.ok && data.url) {
        sessionStorage.setItem('umme_foto', data.url);
        mostrarFoto(data.url);
      }
    } catch {}
  }

  function mostrarFoto(url: string) {
    avatarSvg.style.display = 'none';
    let img = avatarBtn.querySelector('img');
    if (!img) {
      img = document.createElement('img');
      img.alt = 'Foto de perfil';
      avatarBtn.appendChild(img);
    }
    img.src = url;
  }

  cargarFoto();

  // Badge de notificación en Soporte si hay tickets respondidos (cache 5min)
  async function comprobarTickets() {
    if (!s.userId) return;
    const badge = document.getElementById('soporteBadge') as HTMLElement;
    const cached = sessionStorage.getItem('umme_badge');
    if (cached) {
      const { valor, hasta } = JSON.parse(cached);
      if (Date.now() < hasta) { if (valor) badge.style.display = 'block'; return; }
    }
    try {
      const res  = await fetch(`/api/tickets.php?usuario_id=${s.userId}`);
      const data = await res.json();
      if (!data.ok) return;
      const hayRespuesta = (data.tickets || []).some((t: any) => t.estado === 'respondido');
      sessionStorage.setItem('umme_badge', JSON.stringify({ valor: hayRespuesta, hasta: Date.now() + 5 * 60 * 1000 }));
      if (hayRespuesta) badge.style.display = 'block';
    } catch {}
  }
  comprobarTickets();

  // Abrir selector de archivo al clicar el avatar
  avatarBtn.addEventListener('click', () => fileInput.click());

  fileInput.addEventListener('change', async () => {
    const archivo = fileInput.files?.[0];
    if (!archivo || !s.userId) return;

    const fd = new FormData();
    fd.append('archivo', archivo);
    fd.append('usuario_id', String(s.userId));

    try {
      const res  = await fetch('/api/foto-perfil.php', { method: 'POST', body: fd });
      const data = await res.json();
      if (data.ok) {
        sessionStorage.setItem('umme_foto', data.url);
        mostrarFoto(data.url);
      } else {
        (window as any).logAppError?.('foto_perfil', 'Servidor rechazó foto (cabecera)', { detalle: data.mensaje || ('HTTP ' + res.status) });
        alert('No se pudo subir la foto: ' + (data.mensaje || 'error del servidor'));
      }
    } catch (err: any) {
      (window as any).logAppError?.('foto_perfil', 'Error de red subiendo foto (cabecera)', { detalle: err?.message, stack: err?.stack });
      alert('Error de conexión al subir la foto.');
    }

    fileInput.value = '';
  });

  // Cerrar sesión
  document.getElementById('btnSalir')!.addEventListener('click', () => {
    sessionStorage.removeItem('umme_session');
    sessionStorage.removeItem('umme_foto');
    sessionStorage.removeItem('umme_badge');
    window.location.replace('/');
  });
</script>

<style>
.btn-cursos {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.32rem 0.75rem;
  border: 1px solid #d8e8e0;
  border-radius: 7px;
  background: #f4f9f6;
  font-family: inherit;
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--color-text-muted);
  text-decoration: none;
  transition: background 0.12s, color 0.12s, border-color 0.12s;
}
.btn-cursos:hover {
  background: #e6f4ed;
  border-color: #b8d9c8;
  color: var(--color-text);
}
.btn-soporte {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.32rem 0.75rem;
  border: 1px solid #d8e8e0;
  border-radius: 7px;
  background: #f4f9f6;
  font-family: inherit;
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--color-text-muted);
  text-decoration: none;
  transition: background 0.12s, color 0.12s, border-color 0.12s;
}
.btn-soporte:hover {
  background: #e6f4ed;
  border-color: #b8d9c8;
  color: var(--color-text);
}
.btn-soporte {
  position: relative;
}
.soporte-badge {
  position: absolute;
  top: -4px;
  right: -4px;
  width: 8px;
  height: 8px;
  background: #e53;
  border-radius: 50%;
  border: 1.5px solid #fff;
}
</style>
