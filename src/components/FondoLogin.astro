<style>
  /*
   * Fondo fijo que cubre toda la pantalla.
   * Sin overflow:hidden: permite que overflow:visible en los SVG funcione.
   * Los elementos fixed no generan scrollbar al salir del viewport.
   */
  .bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  /* ── Nubes ─────────────────────────────────────────────── */

  .cloud {
    position: absolute;
    opacity: 0.9;
    /* Evita que el browser recorte el path al borde del elemento SVG */
    overflow: visible;
  }

  /* Nube 1: compacta, parte alta */
  .cloud-1 {
    width: 220px;
    top: 8%;
    animation: drift 40s linear infinite;
  }

  /* Nube 2: azul, simétrica, zona alta-media */
  .cloud-2 {
    width: 200px;
    top: 22%;
    animation: drift 28s linear infinite;
    animation-delay: -10s;
  }

  /* Nube 3: ancha, zona baja */
  .cloud-3 {
    width: 280px;
    top: 68%;
    animation: drift 22s linear infinite;
    animation-delay: -6s;
  }

  /* Nube 4: la más grande, lenta, simula fondo lejano */
  .cloud-4 {
    width: 360px;
    top: 40%;
    animation: drift 55s linear infinite;
    animation-delay: -25s;
  }

  /* Nube 5: mediana, zona media-baja */
  .cloud-5 {
    width: 240px;
    top: 78%;
    animation: drift 32s linear infinite;
    animation-delay: -15s;
  }

  /* Nube 6: mediana, zona muy baja */
  .cloud-6 {
    width: 210px;
    top: 90%;
    animation: drift 25s linear infinite;
    animation-delay: -8s;
  }

  /* Todas las nubes de derecha a izquierda */
  @keyframes drift {
    from { transform: translateX(110vw); }
    to   { transform: translateX(-120%); }
  }

  /* ── Pájaros ────────────────────────────────────────────── */

  .birds {
    position: absolute;
    opacity: 0.6;
  }

  .birds-1 {
    width: 140px;
    top: 30%;
    animation: drift 35s linear infinite;
    animation-delay: -20s;
  }

  .birds-2 {
    width: 100px;
    top: 15%;
    animation: drift 50s linear infinite;
    animation-delay: -38s;
  }

  .birds-3 {
    width: 60px;
    top: 55%;
    animation: drift 60s linear infinite;
    animation-delay: -5s;
  }

  /* ── Globo aerostático ──────────────────────────────────── */

  .balloon {
    position: absolute;
    width: 130px;
    right: 12%;
    top: 8%;
    animation: float 7s ease-in-out infinite;
  }

  @keyframes float {
    0%   { transform: translateY(0px)   rotate(-2deg); }
    50%  { transform: translateY(-30px) rotate(2deg);  }
    100% { transform: translateY(0px)   rotate(-2deg); }
  }
</style>
