---
/**
 * COMPONENTE: TarjetaLogin
 * ------------------------
 * Tarjeta de acceso con email y contraseña.
 * Incluye enlace a la página de recuperación de contraseña.
 *
 * ESTADO ACTUAL: Solo visual. Sin lógica ni autenticación.
 * PENDIENTE:     Conectar con sistema de autenticación cuando
 *                esté definida la arquitectura de backend.
 */
import CampoFormulario from './CampoFormulario.astro';
import Boton from './Boton.astro';
---

<div class="login-card">

  <!-- CABECERA -->
  <div class="login-header">
    <h1>Bienvenida</h1>
    <p>Accede a tu área privada</p>
  </div>

  <!-- FORMULARIO
       PENDIENTE: añadir action, method y lógica de autenticación -->
  <form class="login-form">
    <CampoFormulario
      label="Email"
      type="email"
      id="email"
      name="email"
      placeholder="tucorreo@ejemplo.com"
    />
    <CampoFormulario
      label="Contraseña"
      type="password"
      id="password"
      name="password"
      placeholder="••••••••"
    />
    <Boton text="Entrar" type="submit" />

    <a href="/recuperar-contrasena" class="forgot-link">
      ¿Has olvidado tu contraseña?
    </a>
  </form>

</div>

<style>
  .login-card {
    background-color: #fff;
    border-radius: 20px;
    overflow: hidden;
    padding: 2.5rem 2.5rem 2rem;
    width: 100%;
    max-width: 420px;
  }

  .login-header {
    margin-bottom: 2rem;
    text-align: center;
  }

  .login-header h1 {
    font-weight: 600;
    font-size: 1.9rem;
    color: var(--color-text);
    margin: 0;
  }

  .login-header p {
    font-weight: 200;
    color: var(--color-text-muted);
    margin-top: 0.35rem;
    font-size: 0.95rem;
  }

  /* Enlace a recuperación de contraseña */
  .forgot-link {
    display: block;
    margin-top: 1rem;
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: underline;
    transition: color 0.2s;
  }

  .forgot-link:hover {
    color: var(--color-text);
  }
</style>
