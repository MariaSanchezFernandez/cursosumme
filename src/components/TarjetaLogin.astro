---
/**
 * COMPONENTE: TarjetaLogin
 * ------------------------
 * Tarjeta de acceso con email y contraseña.
 * Incluye enlace a la página de recuperación de contraseña.
 *
 * ESTADO ACTUAL: Solo visual. Sin lógica ni autenticación.
 * PENDIENTE:     Conectar con sistema de autenticación cuando
 *                esté definida la arquitectura de backend.
 */
import CampoFormulario from './CampoFormulario.astro';
import Boton from './Boton.astro';
import '../styles/TarjetaLogin.css';
---

<div class="login-card">

  <!-- CABECERA -->
  <div class="login-header">
    <h1>Bienvenida</h1>
    <p>Accede a tu área privada</p>
  </div>

  <!-- FORMULARIO
       PENDIENTE: añadir action, method y lógica de autenticación -->
  <form class="login-form">
    <CampoFormulario
      label="Email"
      type="email"
      id="email"
      name="email"
      placeholder="tucorreo@ejemplo.com"
    />
    <CampoFormulario
      label="Contraseña"
      type="password"
      id="password"
      name="password"
      placeholder="••••••••"
    />
    <Boton text="Entrar" type="submit" />

    <a href="/recuperar-contrasena" class="forgot-link">
      ¿Has olvidado tu contraseña?
    </a>
  </form>

</div>

