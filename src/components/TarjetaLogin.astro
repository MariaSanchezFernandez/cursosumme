---
/**
 * COMPONENTE: TarjetaLogin
 * ------------------------
 * Envía email + contraseña al endpoint PHP /api/login.php.
 * El servidor valida contra MySQL y devuelve el rol.
 * En caso de éxito redirige: admin → /admin, alumno → /inicio.
 */
import CampoFormulario from './CampoFormulario.astro';
import Boton from './Boton.astro';
import '../styles/TarjetaLogin.css';
---

<div class="login-card">

  <div class="login-header">
    <h1>Bienvenida</h1>
    <p>Accede a tu área privada</p>
  </div>

  <form class="login-form" id="login-form">
    <CampoFormulario
      label="Email"
      type="email"
      id="email"
      name="email"
      placeholder="tucorreo@ejemplo.com"
      autocomplete="username"
    />
    <CampoFormulario
      label="Contraseña"
      type="password"
      id="password"
      name="password"
      placeholder="••••••••"
      autocomplete="current-password"
    />
    <label class="login-recordarme">
      <input type="checkbox" id="recordarme" />
      <span>Recordarme en este dispositivo (15 días)</span>
    </label>
    <p id="login-error" style="display:none; font-size:0.78rem; color:#c0392b; margin:-0.25rem 0 0.25rem;">
      Email o contraseña incorrectos.
    </p>
    <Boton text="Entrar" type="submit" />

    <a href="/recuperar-contrasena" class="forgot-link">
      ¿Has olvidado tu contraseña?
    </a>
  </form>

</div>

<script>
  const form = document.getElementById('login-form') as HTMLFormElement;
  const errorMsg = document.getElementById('login-error') as HTMLParagraphElement;
  const boton = form.querySelector('button[type="submit"]') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const email = (form.querySelector('#email') as HTMLInputElement).value.trim().toLowerCase();
    const contrasena = (form.querySelector('#password') as HTMLInputElement).value;

    boton.disabled = true;
    boton.textContent = 'Entrando...';
    errorMsg.style.display = 'none';

    try {
      const respuesta = await fetch('/api/login.php', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, contrasena }),
      });

      const datos = await respuesta.json();

      if (!datos.ok) {
        // Si la API trae un mensaje (rate-limit, mantenimiento, etc.), mostrarlo;
        // si no, usar el texto genérico "Email o contraseña incorrectos".
        errorMsg.textContent = datos.mensaje || 'Email o contraseña incorrectos.';
        errorMsg.style.display = 'block';
        boton.disabled = false;
        boton.textContent = 'Entrar';
        return;
      }

      // Sesión: 15 días si "Recordarme" está marcado (localStorage),
      // 8 horas en caso contrario (sessionStorage, se borra al cerrar el navegador).
      const recordar  = (form.querySelector('#recordarme') as HTMLInputElement).checked;
      const duracion  = recordar ? 15 * 24 * 60 * 60 * 1000 : 8 * 60 * 60 * 1000;
      const sesion = {
        userId: datos.id,
        rol: datos.rol,
        email: datos.email,
        nombre: datos.nombre,
        token: datos.token,
        exp: Date.now() + duracion,
      };
      const raw = JSON.stringify(sesion);
      sessionStorage.setItem('umme_session', raw);
      if (recordar) localStorage.setItem('umme_session', raw);
      else          localStorage.removeItem('umme_session');

      window.location.href = datos.rol === 'admin' ? '/admin' : '/inicio';

    } catch (err: any) {
      errorMsg.textContent = 'Error de conexión. Inténtalo de nuevo.';
      errorMsg.style.display = 'block';
      boton.disabled = false;
      boton.textContent = 'Entrar';
      (window as any).logAppError?.('login', 'Error de red en login', { detalle: (err && err.message) || '', stack: err && err.stack });
    }
  });
</script>
