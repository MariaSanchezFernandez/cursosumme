---
import Plantilla from '../layouts/Plantilla.astro';
import PiePagina from '../components/PiePagina.astro';
import '../styles/global.css';
---

<Plantilla>
  <!-- Cabecera pública -->
  <header style="background:#fff; border-bottom:1px solid #e8eeec; padding:0.9rem 2rem; display:flex; align-items:center; gap:1rem;">
    <a href="/" style="text-decoration:none; font-weight:800; font-size:1.05rem; color:#1a3a28;">
      Cursos <span style="color:#2e7d55;">Umme</span>
    </a>
    <nav style="margin-left:auto; display:flex; gap:1rem; align-items:center;">
      <a href="/" style="font-size:0.85rem; color:#555; text-decoration:none; font-weight:500;">Inicio</a>
      <a href="/precios" style="font-size:0.85rem; color:#2e7d55; text-decoration:none; font-weight:700;">Cursos</a>
    </nav>
  </header>

  <main style="max-width:900px; margin:0 auto; padding:3rem 1.5rem 5rem;">
    <div style="text-align:center; margin-bottom:3rem;">
      <h1 style="font-size:2rem; font-weight:800; color:#1a3a28; margin:0 0 0.75rem;">Formación para oposiciones</h1>
      <p style="color:#666; font-size:1rem; margin:0;">Elige el curso que necesitas o accede a todo el contenido con un pack.</p>
    </div>

    <!-- Packs -->
    <div id="packs-section" style="margin-bottom:3rem;"></div>

    <!-- Cursos individuales -->
    <h2 style="font-size:1.1rem; font-weight:700; color:#1a3a28; margin:0 0 1.25rem;">Cursos individuales</h2>
    <div id="cursos-section" style="display:grid; grid-template-columns:repeat(auto-fill,minmax(260px,1fr)); gap:1.25rem;"></div>

    <div id="loading" style="text-align:center; padding:3rem; color:#aaa; font-size:0.9rem;">Cargando cursos…</div>
    <div id="error"  style="display:none; text-align:center; padding:3rem; color:#c00; font-size:0.9rem;"></div>
  </main>

  <PiePagina />
</Plantilla>

<script>
const PALETA = ['#b5d8cc','#b5c8e8','#d4c8e8','#e8d4b5','#e8c8b5','#c8e8b5'];

async function cargar() {
  const loading = document.getElementById('loading')!;
  const errorEl = document.getElementById('error')!;

  try {
    const [resCursos, resPacks] = await Promise.all([
      fetch('/api/cursos.php?publicos=1'),
      fetch('/api/packs.php'),
    ]);
    const dataCursos = await resCursos.json();
    const dataPacks  = await resPacks.json();
    loading.style.display = 'none';

    // Packs
    const packsSection = document.getElementById('packs-section')!;
    const packs = (dataPacks.packs ?? []).filter((p: any) => p.precio);
    if (packs.length > 0) {
      packsSection.innerHTML = `<h2 style="font-size:1.1rem;font-weight:700;color:#1a3a28;margin:0 0 1.25rem;">Packs</h2>`;
      const grid = document.createElement('div');
      grid.style.cssText = 'display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.25rem;margin-bottom:3rem;';
      packs.forEach((pack: any) => {
        const card = document.createElement('div');
        card.style.cssText = 'background:#fff;border:1px solid #e8eeec;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.05);display:flex;flex-direction:column;';
        card.innerHTML = `
          <div style="background:#2e7d55;padding:1.25rem 1.5rem;">
            <div style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:rgba(255,255,255,0.7);margin-bottom:0.3rem;">Pack completo</div>
            <h3 style="margin:0;color:#fff;font-size:1rem;font-weight:700;">${pack.nombre}</h3>
          </div>
          <div style="padding:1.25rem 1.5rem;flex:1;display:flex;flex-direction:column;gap:0.75rem;">
            ${pack.descripcion ? `<p style="margin:0;font-size:0.85rem;color:#666;line-height:1.6;">${pack.descripcion}</p>` : ''}
            <div style="margin-top:auto;display:flex;align-items:center;justify-content:space-between;gap:0.75rem;">
              <span style="font-size:1.5rem;font-weight:800;color:#1a3a28;">${parseFloat(pack.precio).toFixed(2).replace('.',',')} €</span>
              <button class="btn-comprar" data-tipo="pack" data-id="${pack.id}"
                style="background:#2e7d55;color:#fff;border:none;border-radius:8px;padding:0.6rem 1.25rem;font-weight:700;font-size:0.85rem;cursor:pointer;white-space:nowrap;">
                Comprar pack →
              </button>
            </div>
          </div>
        `;
        grid.appendChild(card);
      });
      packsSection.appendChild(grid);
    }

    // Cursos individuales
    const cursosSection = document.getElementById('cursos-section')!;
    const cursos = (dataCursos.cursos ?? []).filter((c: any) => c.precio);
    if (cursos.length === 0) {
      cursosSection.innerHTML = '<p style="color:#aaa;font-size:0.85rem;">No hay cursos individuales disponibles aún.</p>';
    } else {
      cursos.forEach((curso: any, idx: number) => {
        const color = curso.color || PALETA[idx % PALETA.length];
        const card  = document.createElement('div');
        card.style.cssText = 'background:#fff;border:1px solid #e8eeec;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.05);display:flex;flex-direction:column;';
        const numTemas = curso.num_temas ?? 0;
        card.innerHTML = `
          <div style="height:6px;background:${color};"></div>
          <div style="padding:1.25rem 1.5rem;flex:1;display:flex;flex-direction:column;gap:0.5rem;">
            <div style="font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:#aaa;">${curso.etiqueta ?? ''}</div>
            <h3 style="margin:0;font-size:0.95rem;font-weight:700;color:#1a3a28;line-height:1.4;">${curso.titulo}</h3>
            ${numTemas > 0 ? `<div style="font-size:0.78rem;color:#aaa;">${numTemas} tema${numTemas !== 1 ? 's' : ''}</div>` : ''}
            <div style="margin-top:auto;padding-top:0.75rem;display:flex;align-items:center;justify-content:space-between;gap:0.5rem;">
              <span style="font-size:1.3rem;font-weight:800;color:#1a3a28;">${parseFloat(curso.precio).toFixed(2).replace('.',',')} €</span>
              <button class="btn-comprar" data-tipo="curso" data-id="${curso.id}"
                style="background:#2e7d55;color:#fff;border:none;border-radius:8px;padding:0.5rem 1rem;font-weight:700;font-size:0.82rem;cursor:pointer;">
                Comprar →
              </button>
            </div>
          </div>
        `;
        cursosSection.appendChild(card);
      });
    }

    // Botones de compra
    document.addEventListener('click', async (e) => {
      const btn = (e.target as HTMLElement).closest('.btn-comprar') as HTMLButtonElement | null;
      if (!btn) return;
      btn.disabled = true;
      btn.textContent = 'Redirigiendo…';
      const res  = await fetch('/api/stripe-checkout.php', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ tipo: btn.dataset.tipo, id: Number(btn.dataset.id) }),
      });
      const data = await res.json();
      if (data.ok) {
        window.location.href = data.url;
      } else {
        alert(data.mensaje || 'Error al iniciar el pago');
        btn.disabled = false;
        btn.textContent = 'Comprar →';
      }
    });

  } catch {
    loading.style.display = 'none';
    errorEl.style.display = 'block';
    errorEl.textContent   = 'Error al cargar los cursos. Inténtalo de nuevo.';
  }
}

cargar();
</script>
