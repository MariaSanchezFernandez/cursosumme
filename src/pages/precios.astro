---
/**
 * PÁGINA: Catálogo (/precios)
 * ---------------------------
 * Listado público de cursos y packs disponibles a la venta.
 *
 * SEO: los cursos y packs se **pre-renderizan en build time** vía fetch
 * a la API pública. Esto deja en el HTML estático todo el contenido que
 * Googlebot necesita para indexar la página (nombres, precios, descripciones)
 * sin tener que esperar a la segunda pasada de ejecución de JavaScript.
 * Cada `npm run deploy` reconstruye y vuelve a pedir los datos, así que
 * los cambios en admin se reflejan tras desplegar.
 *
 * El botón "Comprar" se conecta por JS en el cliente y lleva a /checkout.
 */
import Plantilla from '../layouts/Plantilla.astro';
import CabeceraPublica from '../components/CabeceraPublica.astro';
import PiePagina from '../components/PiePagina.astro';
import '../styles/global.css';

// Paleta de colores rotativa para las tarjetas (la API a veces devuelve
// `color: null` y la home/landing usa esta misma lista).
const PALETA = ['#b3e8da','#b5c8e8','#d4c8e8','#fff8b7','#ffb5a7','#c8e8b5'];

type Curso = {
  id: number;
  titulo: string;
  etiqueta?: string | null;
  color?: string | null;
  precio: string | number;
  num_temas?: number;
  puntos?: string[];
};

type Pack = {
  id: number;
  nombre: string;
  descripcion?: string;
  precio: string | number;
};

// Fetch en build time. Si la API falla (por ejemplo, durante el primer
// build de un equipo nuevo sin SSL todavía), no se rompe el deploy: la
// página queda con secciones vacías y el JS de cliente intenta llenarlas.
async function pedir<T>(url: string, clave: string): Promise<T[]> {
  try {
    const r = await fetch(url);
    if (!r.ok) return [];
    const j = await r.json();
    return Array.isArray(j[clave]) ? j[clave] : [];
  } catch {
    return [];
  }
}

const porPrecio = <T extends { precio: string | number }>(a: T, b: T) =>
  parseFloat(String(a.precio ?? 0)) - parseFloat(String(b.precio ?? 0));

const cursos = (await pedir<Curso>('https://cursosumme.es/api/cursos.php?publicos=1', 'cursos'))
  .filter((c) => c.precio)
  .sort(porPrecio);

const packs = (await pedir<Pack>('https://cursosumme.es/api/packs.php', 'packs'))
  .filter((p) => p.precio)
  .sort(porPrecio);

const fmt = (v: string | number) =>
  parseFloat(String(v)).toFixed(2).replace('.', ',');

// JSON-LD Schema.org Course — pre-construido para que Google lo lea
// directamente del HTML sin esperar a JavaScript.
const schemaCursos = cursos.length
  ? {
      '@context': 'https://schema.org',
      '@graph': cursos.map((c) => ({
        '@type': 'Course',
        name: c.titulo,
        description: c.etiqueta
          ? `${c.etiqueta} — preparación para oposiciones de Pedagogía Terapéutica.`
          : 'Curso de preparación para oposiciones de Pedagogía Terapéutica.',
        url: `https://cursosumme.es/cursos/${c.id}`,
        provider: {
          '@type': 'EducationalOrganization',
          name: 'Cursos Umme',
          sameAs: 'https://cursosumme.es',
        },
        offers: {
          '@type': 'Offer',
          price: parseFloat(String(c.precio ?? 0)).toFixed(2),
          priceCurrency: 'EUR',
          availability: 'https://schema.org/InStock',
          url: 'https://cursosumme.es/precios',
        },
        hasCourseInstance: {
          '@type': 'CourseInstance',
          courseMode: 'online',
          ...(c.num_temas ? { courseWorkload: `${c.num_temas} temas en vídeo` } : {}),
        },
        inLanguage: 'es',
      })),
    }
  : null;
---

<Plantilla
  titulo="Catálogo de cursos — Pedagogía Terapéutica — Cursos Umme"
  descripcion="Cursos individuales y packs para preparar las oposiciones de PT. Temario actualizado a cada convocatoria, vídeo on-demand y materiales descargables. Compra única, sin suscripción, con 1 año de acceso."
>
  <CabeceraPublica activa="cursos" />

  <main class="contenido">
    <header class="catalogo-hero">
      <p class="catalogo-eyebrow">Oposiciones de Pedagogía Terapéutica</p>
      <h1 class="catalogo-titulo">Elige el material que va con tu plaza</h1>
      <p class="catalogo-sub">
        Temarios actualizados a cada convocatoria, vídeo on-demand y
        materiales descargables. Compra única, sin suscripciones, con
        1 año de acceso desde la fecha de compra.
      </p>
    </header>

    {packs.length > 0 && (
      <section class="catalogo-seccion">
        <header class="catalogo-seccion-header" id="packs">
          <h2 class="catalogo-seccion-titulo">Packs completos</h2>
          <p class="catalogo-seccion-sub">Más material por menos. Acceso a todos los cursos del pack en una sola compra.</p>
        </header>
        <div class="catalogo-grid catalogo-grid--packs">
          {packs.map((pack, i) => (
            <article
              class="tarjeta-curso tarjeta-curso--pack"
              style={`--curso-color: ${PALETA[i % PALETA.length]}; animation-delay: ${i * 0.07}s;`}
            >
              <div class="tarjeta-curso-acento"></div>
              <div class="tarjeta-curso-body">
                <span class="tarjeta-curso-chip tarjeta-curso-chip--pack">Pack completo</span>
                <h3 class="tarjeta-curso-titulo">{pack.nombre}</h3>
                {pack.descripcion && (
                  <p class="tarjeta-curso-desc">{pack.descripcion}</p>
                )}
                <ul class="tarjeta-curso-checklist">
                  <li>Todos los cursos del pack</li>
                  <li>Apuntes y materiales descargables</li>
                  <li>Ahorra frente a comprarlos sueltos</li>
                </ul>
                <div class="tarjeta-curso-pie">
                  <span class="tarjeta-curso-precio">{fmt(pack.precio)} €</span>
                  <button class="tarjeta-curso-cta" data-tipo="pack" data-id={pack.id}>Comprar pack →</button>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}

    {cursos.length > 0 ? (
      <section class="catalogo-seccion">
        <header class="catalogo-seccion-header">
          <h2 class="catalogo-seccion-titulo">Cursos individuales</h2>
          <p class="catalogo-seccion-sub">Elige solo lo que necesitas. Acceso completo a cada curso por separado.</p>
        </header>
        <div class="catalogo-grid">
          {cursos.map((curso, i) => {
            const color = curso.color || PALETA[i % PALETA.length];
            const numTemas = Number(curso.num_temas ?? 0);
            const puntos = Array.isArray(curso.puntos) ? curso.puntos : [];
            const items: string[] = [];
            if (numTemas > 0) items.push(`${numTemas} ${numTemas === 1 ? 'tema' : 'temas'} en vídeo`);
            for (const p of puntos) {
              if (items.length >= 4) break;
              items.push(p);
            }
            return (
              <article
                class="tarjeta-curso"
                style={`--curso-color: ${color}; animation-delay: ${i * 0.06}s;`}
              >
                <div class="tarjeta-curso-acento"></div>
                <a href={`/cursos/${curso.id}`} class="tarjeta-curso-overlay" aria-label={`Ver detalle de ${curso.titulo}`}></a>
                <div class="tarjeta-curso-body">
                  {curso.etiqueta && <span class="tarjeta-curso-chip">{curso.etiqueta}</span>}
                  <h3 class="tarjeta-curso-titulo">{curso.titulo}</h3>
                  {items.length > 0 && (
                    <ul class="tarjeta-curso-checklist">
                      {items.map((p) => <li>{p}</li>)}
                    </ul>
                  )}
                  <a href={`/cursos/${curso.id}`} class="tarjeta-curso-ver">Ver detalle del curso →</a>
                  <div class="tarjeta-curso-pie">
                    <span class="tarjeta-curso-precio">{fmt(curso.precio)} €</span>
                    <button class="tarjeta-curso-cta" data-tipo="curso" data-id={curso.id}>Comprar →</button>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      </section>
    ) : (
      <p class="estado-carga">No hay cursos disponibles aún.</p>
    )}

    {schemaCursos && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaCursos)}></script>
    )}

    {/* Snapshot de los datos del build: el JS lo compara contra lo que
        devuelve la API en directo para repintar las tarjetas solo si han
        cambiado entre el último deploy y ahora. */}
    <script type="application/json" id="datos-build" is:inline set:html={JSON.stringify({ packs, cursos })}></script>
  </main>

  <PiePagina />
</Plantilla>

<style is:global>
.contenido {
  max-width: 1180px;
  margin: 0 auto;
  padding: 3rem 1.5rem 5rem;
  /* 100dvh tiene en cuenta la barra dinámica de iOS/Android.
     Restamos solo la cabecera (72px desktop, 64px móvil) — el footer no
     entra aquí porque vive fuera de .contenido y ya tiene su propio espacio. */
  min-height: calc(100dvh - 72px);
}
@media (max-width: 720px) {
  .contenido { min-height: calc(100dvh - 64px); }
}
/* En pantallas anchas dejamos respirar el catálogo para poder
   meter 4 columnas sin que las tarjetas queden estrujadas. */
@media (min-width: 1280px) { .contenido { max-width: 1440px; } }
@media (min-width: 1600px) { .contenido { max-width: 1640px; } }

/* ── Hero del catálogo ─────────────────────────────────────── */
.catalogo-hero {
  text-align: center;
  margin: 0 auto 3.5rem;
  max-width: 720px;
}
.catalogo-eyebrow {
  font-size: 0.74rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--color-text-muted);
  margin-bottom: 0.85rem;
}
.catalogo-titulo {
  font-size: clamp(1.9rem, 4vw, 2.6rem);
  font-weight: 800;
  letter-spacing: -0.02em;
  line-height: 1.15;
  margin: 0 0 0.85rem;
  color: var(--color-text);
}
.catalogo-sub {
  font-size: 1rem;
  color: var(--color-text-muted);
  line-height: 1.65;
  margin: 0;
}

/* ── Estados ───────────────────────────────────────────────── */
.estado-carga,
.estado-error {
  text-align: center;
  padding: 3.5rem 1rem;
  font-size: 0.95rem;
}
.estado-carga { color: #aaa; }
.estado-error { color: #c0392b; }

/* ── Secciones ─────────────────────────────────────────────── */
.catalogo-seccion {
  margin-bottom: 4rem;
}
.catalogo-seccion-header {
  margin-bottom: 1.75rem;
  max-width: 640px;
}
.catalogo-seccion-titulo {
  font-size: clamp(1.2rem, 2vw, 1.5rem);
  font-weight: 800;
  letter-spacing: -0.015em;
  margin: 0 0 0.5rem;
}
.catalogo-seccion-sub {
  font-size: 0.92rem;
  color: var(--color-text-muted);
  line-height: 1.6;
  margin: 0;
}

/* ── Grid ──────────────────────────────────────────────────── */
/* Flex en vez de grid: si una fila tiene menos tarjetas que columnas
   (p. ej. 4 cursos con un layout de 3, o 2 packs en un layout de 3),
   las tarjetas sobrantes quedan centradas en su fila en vez de
   pegadas a la izquierda. Mantiene el "stretch" dentro de cada fila
   gracias al align-items por defecto. */
.catalogo-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 1.5rem;
}
/* Cada tarjeta toma una fracción exacta del ancho disponible por
   breakpoint. Restamos los gaps de la fila al ancho antes de
   dividir, así no se desbordan ni se quedan cortas. */
.catalogo-grid > * { flex: 0 1 100%; }
@media (min-width: 560px) {
  .catalogo-grid > * { flex: 0 1 calc((100% - 1.5rem) / 2); }
}
@media (min-width: 860px) {
  .catalogo-grid > * { flex: 0 1 calc((100% - 3rem) / 3); }
}
@media (min-width: 1280px) {
  .catalogo-grid > * { flex: 0 1 calc((100% - 4.5rem) / 4); }
}
@media (min-width: 1600px) {
  .catalogo-grid > * { flex: 0 1 calc((100% - 6rem) / 5); }
}
/* Packs: máximo 2 por fila en desktop/tablet, 3 en pantallas
   muy anchas. Si hay un número impar, la última queda centrada. */
.catalogo-grid--packs > * { flex: 0 1 calc((100% - 1.5rem) / 2); }
@media (max-width: 720px) {
  .catalogo-grid--packs > * { flex: 0 1 100%; }
}
@media (min-width: 1280px) {
  .catalogo-grid--packs > * { flex: 0 1 calc((100% - 3rem) / 3); }
}

/* ── Tarjeta de curso (sin imagen, altura uniforme) ───────── */
.tarjeta-curso {
  position: relative;
  background: #fff;
  border: 1px solid #ececec;
  border-radius: var(--radius-md);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  text-decoration: none;
  color: inherit;
  height: 100%;
  /* Altura mínima ajustada al contenido real (chip + título + 4
     bullets + "Ver detalle" + pie con botón). El grid-auto-rows: 1fr
     iguala todas las filas a la fila más alta, así que no necesitamos
     reservar espacio extra "por si acaso". */
  min-height: 360px;
  transition: transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1),
              box-shadow 0.28s,
              border-color 0.2s;
  will-change: transform;
  opacity: 0;
  transform: translateY(20px);
  animation: tarjetaEntra 0.5s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}
@keyframes tarjetaEntra {
  to { opacity: 1; transform: translateY(0); }
}
.tarjeta-curso:hover {
  transform: translateY(-6px);
  border-color: color-mix(in srgb, var(--curso-color, var(--color-primary)) 60%, #ffffff);
  box-shadow: 0 18px 36px -10px color-mix(in srgb, var(--curso-color, var(--color-primary)) 50%, rgba(0,0,0,0.1));
}
.tarjeta-curso-acento {
  height: 6px;
  background: var(--curso-color, var(--color-primary));
  transition: height 0.2s;
}
.tarjeta-curso:hover .tarjeta-curso-acento { height: 8px; }

/* Overlay link que cubre toda la tarjeta — el pie (precio +
   botón Comprar) va por encima con z-index mayor para no robar
   los clicks. NOTA: el body NO lleva z-index para que el pie
   pueda elevarse por encima del overlay con z-index 2. */
.tarjeta-curso-overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  text-decoration: none;
  text-indent: -9999px;
}
.tarjeta-curso-body { position: relative; }
.tarjeta-curso-pie { position: relative; z-index: 2; }
.tarjeta-curso-cta--full { width: 100%; justify-content: center; }

.tarjeta-curso-chip {
  display: inline-flex;
  align-self: flex-start;
  background: var(--color-light);
  color: var(--color-text);
  padding: 0.3rem 0.7rem;
  border-radius: 999px;
  font-size: 0.66rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: 0.5rem;
}
.tarjeta-curso-chip--pack { background: var(--color-secondary); }

.tarjeta-curso-body {
  padding: 1.4rem;
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
  flex: 1;
}
.tarjeta-curso-titulo-link {
  text-decoration: none;
  color: inherit;
  display: flex;
  flex-direction: column;
}
.tarjeta-curso-titulo {
  font-size: 1.15rem;
  font-weight: 800;
  line-height: 1.3;
  letter-spacing: -0.01em;
  margin: 0;
  color: var(--color-text);
}

.tarjeta-curso-checklist {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  flex: 1;
}
.tarjeta-curso-checklist li {
  position: relative;
  padding-left: 1.6rem;
  font-size: 0.86rem;
  color: var(--color-text);
  line-height: 1.45;
}
.tarjeta-curso-checklist li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0.15rem;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: color-mix(in srgb, var(--curso-color, var(--color-primary)) 40%, #ffffff);
}
.tarjeta-curso-checklist li::after {
  content: '';
  position: absolute;
  left: 4px;
  top: 0.45rem;
  width: 9px;
  height: 5px;
  border-left: 2px solid var(--color-text);
  border-bottom: 2px solid var(--color-text);
  transform: rotate(-45deg);
}

.tarjeta-curso-pie {
  display: flex;
  flex-wrap: nowrap;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
  margin-top: auto;
  padding-top: 1rem;
  border-top: 1px solid #f1f4f3;
}
.tarjeta-curso-precio { flex-shrink: 0; }
.tarjeta-curso-precio {
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--color-text);
  line-height: 1;
}
.tarjeta-curso--pack .tarjeta-curso-precio { font-size: 1.8rem; }

/* Descripción del pack — visible bajo el título, antes del checklist.
   Color y espaciado coherentes con el resto de subtextos. */
.tarjeta-curso-desc {
  font-size: 0.88rem;
  color: var(--color-text-muted);
  line-height: 1.5;
  margin: 0;
}

/* Enlace visible "Ver detalle del curso" — secundario, alineado a la
   derecha encima del pie. Posicionado por encima del overlay para que
   el click vaya al link explícito (semántica clara). */
.tarjeta-curso-ver {
  position: relative;
  z-index: 2;
  align-self: flex-end;
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  margin-top: 0.4rem;
  padding: 0.45rem 0.85rem;
  background: var(--color-light);
  border: 1px solid #e3e6e5;
  border-radius: 999px;
  color: var(--color-text);
  font-size: 0.78rem;
  font-weight: 700;
  text-decoration: none;
  white-space: nowrap;
  transition: background 0.15s, border-color 0.15s, transform 0.18s;
}
.tarjeta-curso-ver:hover {
  background: #fff;
  border-color: var(--curso-color, var(--color-primary));
  transform: translateX(2px);
}

.tarjeta-curso-cta {
  background: var(--color-coral);
  color: var(--color-text);
  border: none;
  border-radius: var(--radius-sm);
  padding: 0.6rem 1.1rem;
  font-family: 'DM Sans', sans-serif;
  font-weight: 800;
  font-size: 0.85rem;
  cursor: pointer;
  white-space: nowrap;
  transition: transform 0.18s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.15s, box-shadow 0.18s;
}
.tarjeta-curso-cta:hover {
  transform: translateY(-2px) scale(1.03);
  opacity: 0.94;
  box-shadow: 0 8px 18px rgba(0,0,0,0.12);
}
.tarjeta-curso-cta:active { transform: translateY(0) scale(0.98); }

/* ── Responsive ────────────────────────────────────────────── */
@media (max-width: 480px) {
  .contenido { padding: 2rem 1rem 4rem; }
  .catalogo-seccion { margin-bottom: 3rem; }
  .tarjeta-curso-pie { flex-direction: column; align-items: stretch; }
  .tarjeta-curso-cta { width: 100%; text-align: center; }
}
</style>

<script>
// ───────────────────────────────────────────────────────────────────
// 1) Las tarjetas vienen pre-renderizadas del build (ver frontmatter).
// 2) Tras la carga inicial, revalidamos contra la API: si los precios o
//    los cursos han cambiado desde el último deploy, repintamos. Si la
//    API falla, el visitante sigue viendo el HTML estático sin error.
// 3) En modo ?preview los botones "Comprar" muestran un toast en vez
//    de redirigir a checkout (útil para previsualización sin Stripe).
// ───────────────────────────────────────────────────────────────────
const PALETA = ['#b3e8da','#b5c8e8','#d4c8e8','#fff8b7','#ffb5a7','#c8e8b5'];
const esPreview = new URLSearchParams(location.search).has('preview');

function escapar(s: string): string {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function fmt(v: string | number): string {
  return parseFloat(String(v)).toFixed(2).replace('.', ',');
}
function porPrecio(a: any, b: any): number {
  return parseFloat(String(a.precio ?? 0)) - parseFloat(String(b.precio ?? 0));
}

function htmlPack(pack: any, idx: number): string {
  const color = PALETA[idx % PALETA.length];
  const desc = pack.descripcion ? `<p class="tarjeta-curso-desc">${escapar(pack.descripcion)}</p>` : '';
  return `
    <article class="tarjeta-curso tarjeta-curso--pack" style="--curso-color: ${color}; animation-delay: ${idx * 0.07}s;">
      <div class="tarjeta-curso-acento"></div>
      <div class="tarjeta-curso-body">
        <span class="tarjeta-curso-chip tarjeta-curso-chip--pack">Pack completo</span>
        <h3 class="tarjeta-curso-titulo">${escapar(pack.nombre)}</h3>
        ${desc}
        <ul class="tarjeta-curso-checklist">
          <li>Todos los cursos del pack</li>
          <li>Apuntes y materiales descargables</li>
          <li>Ahorra frente a comprarlos sueltos</li>
        </ul>
        <div class="tarjeta-curso-pie">
          <span class="tarjeta-curso-precio">${fmt(pack.precio ?? 0)} €</span>
          <button class="tarjeta-curso-cta" data-tipo="pack" data-id="${pack.id}">Comprar pack →</button>
        </div>
      </div>
    </article>`;
}

function htmlCurso(curso: any, idx: number): string {
  const color = curso.color || PALETA[idx % PALETA.length];
  const numTemas = Number(curso.num_temas ?? 0);
  const puntos: string[] = Array.isArray(curso.puntos) ? curso.puntos : [];
  const items: string[] = [];
  if (numTemas > 0) items.push(`${numTemas} ${numTemas === 1 ? 'tema' : 'temas'} en vídeo`);
  for (const p of puntos) {
    if (items.length >= 4) break;
    items.push(p);
  }
  const checklist = items.length
    ? `<ul class="tarjeta-curso-checklist">${items.map((p) => `<li>${escapar(p)}</li>`).join('')}</ul>`
    : '';
  return `
    <article class="tarjeta-curso" style="--curso-color: ${color}; animation-delay: ${idx * 0.06}s;">
      <div class="tarjeta-curso-acento"></div>
      <a href="/cursos/${curso.id}" class="tarjeta-curso-overlay" aria-label="Ver detalle de ${escapar(curso.titulo)}"></a>
      <div class="tarjeta-curso-body">
        ${curso.etiqueta ? `<span class="tarjeta-curso-chip">${escapar(curso.etiqueta)}</span>` : ''}
        <h3 class="tarjeta-curso-titulo">${escapar(curso.titulo)}</h3>
        ${checklist}
        <a href="/cursos/${curso.id}" class="tarjeta-curso-ver">Ver detalle del curso →</a>
        <div class="tarjeta-curso-pie">
          <span class="tarjeta-curso-precio">${fmt(curso.precio ?? 0)} €</span>
          <button class="tarjeta-curso-cta" data-tipo="curso" data-id="${curso.id}">Comprar →</button>
        </div>
      </div>
    </article>`;
}

// Huella ligera para detectar cambios: lista ordenada de "id|precio".
// Si admin sube un precio, retira un curso o añade uno nuevo, la huella
// cambia y disparamos el repintado. Comparamos packs y cursos por
// separado para no repintar la sección equivocada.
function huella(items: any[], idKey: string): string {
  return items
    .map((x) => `${x[idKey]}|${parseFloat(String(x.precio ?? 0)).toFixed(2)}`)
    .join(',');
}

function pintarPacks(packs: any[]) {
  // Busca la sección renderizada por build; si no existe (cero packs en
  // build) la creamos antes del bloque de cursos.
  let sec = document.querySelector('section[aria-label="packs"]') as HTMLElement | null
    || document.getElementById('packs')?.closest('section') as HTMLElement | null;
  if (!packs.length) {
    if (sec) sec.remove();
    return;
  }
  if (!sec) {
    const main = document.querySelector('main.contenido')!;
    sec = document.createElement('section');
    sec.className = 'catalogo-seccion';
    sec.setAttribute('aria-label', 'packs');
    sec.innerHTML = `
      <header class="catalogo-seccion-header" id="packs">
        <h2 class="catalogo-seccion-titulo">Packs completos</h2>
        <p class="catalogo-seccion-sub">Más material por menos. Acceso a todos los cursos del pack en una sola compra.</p>
      </header>
      <div class="catalogo-grid catalogo-grid--packs"></div>`;
    main.insertBefore(sec, main.firstElementChild!.nextElementSibling);
  }
  const grid = sec.querySelector('.catalogo-grid') as HTMLElement;
  grid.innerHTML = packs.map((p, i) => htmlPack(p, i)).join('');
}

function pintarCursos(cursos: any[]) {
  // La sección de cursos individuales SIEMPRE existe en el HTML (al
  // menos como contenedor). Localizamos el grid por la primera
  // .catalogo-grid que no sea --packs.
  const grids = Array.from(document.querySelectorAll('.catalogo-grid'));
  const grid  = grids.find((g) => !g.classList.contains('catalogo-grid--packs')) as HTMLElement | undefined;
  if (!grid) return;
  if (!cursos.length) {
    grid.innerHTML = '<p style="color:#aaa;font-size:0.9rem;">No hay cursos disponibles aún.</p>';
    return;
  }
  grid.innerHTML = cursos.map((c, i) => htmlCurso(c, i)).join('');
}

async function revalidar() {
  let inicial: { packs?: any[]; cursos?: any[] } = {};
  try {
    const raw = document.getElementById('datos-build')?.textContent || '{}';
    inicial = JSON.parse(raw);
  } catch {}

  try {
    const [resCursos, resPacks] = await Promise.all([
      fetch('/api/cursos.php?publicos=1'),
      fetch('/api/packs.php'),
    ]);
    if (!resCursos.ok || !resPacks.ok) return;
    const dataCursos = await resCursos.json();
    const dataPacks  = await resPacks.json();

    const cursosNuevos = (dataCursos.cursos ?? []).filter((c: any) => c.precio).sort(porPrecio);
    const packsNuevos  = (dataPacks.packs   ?? []).filter((p: any) => p.precio).sort(porPrecio);

    const cursosCambian = huella(cursosNuevos, 'id') !== huella(inicial.cursos ?? [], 'id');
    const packsCambian  = huella(packsNuevos,  'id') !== huella(inicial.packs  ?? [], 'id');

    if (packsCambian)  pintarPacks(packsNuevos);
    if (cursosCambian) pintarCursos(cursosNuevos);
  } catch {
    // Sin red o API caída: el visitante sigue viendo el HTML del build.
  }
}

// Botones Comprar → /checkout (recoge nombre, dirección, DNI/NIF y la
// renuncia al desistimiento antes de pasar a Stripe).
document.addEventListener('click', (e) => {
  const btn = (e.target as HTMLElement).closest('.tarjeta-curso-cta') as HTMLButtonElement | null;
  if (!btn) return;
  e.preventDefault();
  if (esPreview) {
    window.mostrarToast('Modo preview — el pago no está activo', 'info');
    return;
  }
  const tipo = btn.dataset.tipo;
  const id   = Number(btn.dataset.id);
  if (!tipo || !id) return;
  window.location.href = `/checkout?tipo=${encodeURIComponent(tipo)}&id=${id}`;
});

// Revalidamos solo en producción real (sin ?preview).
if (!esPreview) revalidar();
</script>
