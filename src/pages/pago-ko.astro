---
/**
 * PÁGINA: /pago-ko
 * ----------------
 * Aterrizaje tras cancelar el pago en Stripe Checkout. Mensaje amable,
 * sin tono de error, con la cabecera y el pie corporativos para que la
 * usuaria no sienta que cayó en un sitio distinto. Llama de vuelta al
 * catálogo y, como secundario, a soporte por si fue un fallo real.
 */
import Plantilla from '../layouts/Plantilla.astro';
import CabeceraPublica from '../components/CabeceraPublica.astro';
import PiePagina from '../components/PiePagina.astro';
import '../styles/global.css';
---

<Plantilla titulo="Pago cancelado — Cursos Umme">
  <CabeceraPublica activa="cursos" />

  <main class="pago-estado">
    <div class="pago-estado-inner">
      <div class="pago-estado-icono" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="15" y1="9" x2="9" y2="15"/>
          <line x1="9" y1="9" x2="15" y2="15"/>
        </svg>
      </div>

      <h1>Pago cancelado</h1>
      <p class="pago-estado-msg">
        No se ha realizado ningún cargo. Tu cesta sigue ahí cuando estés lista — los cursos te esperan.
      </p>

      <div class="pago-estado-cta">
        <a href="/precios" class="cta cta--primary">Volver a los cursos →</a>
      </div>
    </div>
  </main>

  <PiePagina />
</Plantilla>

<!-- Estilos base .pago-estado-* viven en src/styles/global.css para
     compartirse con /pago-ok sin duplicar. -->

