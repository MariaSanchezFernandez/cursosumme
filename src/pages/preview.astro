---
// PÁGINA: Preview de componentes UX
// ---------------------------------
// Página de desarrollo para previsualizar visualmente toasts, botones
// con estado de carga y otros patrones UX sin tocar la API ni la BD.
//
// Todas las "acciones" son simuladas con setTimeout — cero llamadas
// a /api/. Es seguro abrirla en local o en producción.
//
// URL: /preview
//
// Cuando esté pulido el pack "polish UX", esta página se puede
// borrar o dejar como referencia interna.
import Plantilla from '../layouts/Plantilla.astro';
---

<Plantilla>
  <main class="prev-wrap">
    <header class="prev-header">
      <h1>Preview de componentes UX</h1>
      <p>
        Playground para probar visualmente toasts, botones con estado de
        carga y combinaciones. <strong>Cero llamadas a la API</strong> —
        las acciones se simulan con <code>setTimeout</code>.
      </p>
    </header>

    <!-- ─── Toasts ───────────────────────────────────────────────── -->

    <section class="prev-section">
      <h2>1. Sistema de toasts</h2>
      <p class="prev-section-desc">
        Notificaciones abajo-derecha. Auto-cierre a 4 s, pausa al pasar el
        ratón por encima, cerrables con la ×.
      </p>

      <div class="prev-grid">
        <button class="prev-btn prev-btn-success" data-toast="success">
          Mostrar toast Éxito
        </button>
        <button class="prev-btn prev-btn-error" data-toast="error">
          Mostrar toast Error
        </button>
        <button class="prev-btn prev-btn-warning" data-toast="warning">
          Mostrar toast Aviso
        </button>
        <button class="prev-btn prev-btn-info" data-toast="info">
          Mostrar toast Info
        </button>
        <button class="prev-btn prev-btn-neutral" data-toast="todos">
          Disparar los 4 a la vez
        </button>
        <button class="prev-btn prev-btn-neutral" data-toast="largo">
          Toast con texto largo
        </button>
      </div>
    </section>

    <!-- ─── Botones cargando ─────────────────────────────────────── -->

    <section class="prev-section">
      <h2>2. Botones con estado de carga</h2>
      <p class="prev-section-desc">
        El propio botón muestra un spinner + texto contextual mientras
        dura la acción. Anti doble-clic, restauración automática al
        terminar (también si la acción falla).
      </p>

      <div class="prev-grid">
        <button class="prev-btn prev-btn-coral" id="prevLoadOk">
          Guardar (simula éxito, 2 s)
        </button>
        <button class="prev-btn prev-btn-coral" id="prevLoadErr">
          Eliminar (simula error, 1.5 s)
        </button>
        <button class="prev-btn prev-btn-coral" id="prevLoadSlow">
          Subir vídeo (lento, 5 s)
        </button>
        <button class="prev-btn prev-btn-coral" id="prevLoadDoble">
          Probar doble clic (no debe duplicarse)
        </button>
      </div>
    </section>

    <!-- ─── Botón cargando + toast combinado ─────────────────────── -->

    <section class="prev-section">
      <h2>3. Combinado: botón cargando → toast</h2>
      <p class="prev-section-desc">
        Flujo real: pulsas, el botón gira, al terminar aparece un toast
        con el resultado. Es el patrón que usamos en todo el panel admin.
      </p>

      <div class="prev-grid">
        <button class="prev-btn prev-btn-coral" id="prevComboOk">
          Duplicar curso (acaba en éxito)
        </button>
        <button class="prev-btn prev-btn-coral" id="prevComboErr">
          Borrar alumno (acaba en error)
        </button>
      </div>
    </section>
  </main>
</Plantilla>

<script is:inline>
  // Helper local: promesa que se resuelve / rechaza tras N ms.
  function esperar(ms, ok) {
    return new Promise(function (resolve, reject) {
      setTimeout(function () { (ok ? resolve : reject)(); }, ms);
    });
  }

  // ── 1. Toasts ───────────────────────────────────────────────
  document.querySelectorAll('[data-toast]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var tipo = btn.getAttribute('data-toast');
      if (tipo === 'success') return window.toast.success('Curso guardado correctamente');
      if (tipo === 'error')   return window.toast.error('No se pudo subir el vídeo. Comprueba tu conexión.');
      if (tipo === 'warning') return window.toast.warning('Tu sesión caducará en 5 minutos', 8000);
      if (tipo === 'info')    return window.toast.info('Tienes 3 cursos nuevos asignados');
      if (tipo === 'todos') {
        window.toast.success('Curso duplicado');
        window.toast.error('Falló la actualización del título');
        window.toast.warning('Quedan 5 min de sesión');
        window.toast.info('Tienes un mensaje nuevo de soporte');
        return;
      }
      if (tipo === 'largo') {
        window.toast.info('Este es un mensaje largo de prueba para verificar cómo se comporta el toast cuando el contenido excede una línea, manteniendo la legibilidad y el espaciado.');
      }
    });
  });

  // ── 2. Botones cargando ─────────────────────────────────────
  document.getElementById('prevLoadOk').addEventListener('click', async function (e) {
    await window.botonCargando(e.currentTarget, 'Guardando…', function () {
      return esperar(2000, true);
    });
  });

  document.getElementById('prevLoadErr').addEventListener('click', async function (e) {
    try {
      await window.botonCargando(e.currentTarget, 'Eliminando…', function () {
        return esperar(1500, false);
      });
    } catch (err) { /* simulación: error capturado */ }
  });

  document.getElementById('prevLoadSlow').addEventListener('click', async function (e) {
    await window.botonCargando(e.currentTarget, 'Subiendo vídeo…', function () {
      return esperar(5000, true);
    });
  });

  document.getElementById('prevLoadDoble').addEventListener('click', async function (e) {
    // Dos llamadas seguidas: la segunda debe ignorarse
    var btn = e.currentTarget;
    window.botonCargando(btn, 'Procesando…', function () { return esperar(2000, true); });
    window.botonCargando(btn, 'Procesando…', function () { return esperar(2000, true); });
  });

  // ── 3. Combinado: botón cargando + toast ───────────────────
  document.getElementById('prevComboOk').addEventListener('click', async function (e) {
    await window.botonCargando(e.currentTarget, 'Duplicando…', function () {
      return esperar(1800, true);
    });
    window.toast.success('"Curso de prueba" duplicado correctamente');
  });

  document.getElementById('prevComboErr').addEventListener('click', async function (e) {
    try {
      await window.botonCargando(e.currentTarget, 'Eliminando…', function () {
        return esperar(1800, false);
      });
    } catch (err) {
      window.toast.error('No se pudo eliminar: tiene cursos asociados');
    }
  });
</script>

<style>
  .prev-wrap {
    max-width: 880px;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
    font-family: 'DM Sans', sans-serif;
    color: var(--color-text);
  }

  .prev-header {
    margin-bottom: 3rem;
    padding-bottom: 1.5rem;
    border-bottom: 1.5px solid var(--color-primary);
  }
  .prev-header h1 {
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 0.5rem;
  }
  .prev-header p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .prev-header code {
    background: var(--color-light);
    padding: 0.1em 0.4em;
    border-radius: 4px;
    font-family: 'Menlo', 'Consolas', monospace;
    font-size: 0.85em;
  }

  .prev-section {
    margin-bottom: 3rem;
    padding: 1.75rem;
    background: #fff;
    border: 1.5px solid var(--color-primary);
    border-radius: 14px;
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.05);
  }
  .prev-section h2 {
    font-size: 1.25rem;
    font-weight: 800;
    margin-bottom: 0.4rem;
  }
  .prev-section-desc {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
    margin-bottom: 1.5rem;
  }

  .prev-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 0.75rem;
  }

  .prev-btn {
    padding: 0.75rem 1rem;
    border: 1.5px solid transparent;
    border-radius: 10px;
    font-family: inherit;
    font-size: 0.92rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s, transform 0.1s;
  }
  .prev-btn:hover         { opacity: 0.88; }
  .prev-btn:active        { transform: translateY(1px); }
  .prev-btn:focus-visible { outline: 2px solid var(--color-accent); outline-offset: 2px; }

  .prev-btn-success { background: #e7f6f0; border-color: var(--color-primary); color: #1d6b4e; }
  .prev-btn-error   { background: #ffe5df; border-color: var(--color-coral);   color: #872f1f; }
  .prev-btn-warning { background: var(--color-secondary); border-color: var(--color-accent); color: #7a5400; }
  .prev-btn-info    { background: #fff;    border-color: var(--color-primary); color: var(--color-text); }
  .prev-btn-neutral { background: var(--color-light); border-color: var(--color-primary); color: var(--color-text); }
  .prev-btn-coral   { background: var(--color-coral); border-color: var(--color-coral); color: var(--color-text); }
</style>
