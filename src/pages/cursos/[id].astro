<script>
// Comprar curso vía Stripe Checkout. Mismo patrón que /precios.
document.querySelectorAll<HTMLButtonElement>('.cd-cta').forEach((btn) => {
  btn.addEventListener('click', async () => {
    await window.botonCargando(btn, 'Redirigiendo…', async () => {
      try {
        const res = await fetch('/api/stripe-checkout.php', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            tipo: btn.dataset.tipo,
            id: Number(btn.dataset.id),
          }),
        });
        const data = await res.json();
        if (data.ok && data.url) {
          window.location.href = data.url;
        } else {
          window.mostrarToast(data.mensaje || 'No se pudo iniciar el pago.', 'error');
        }
      } catch {
        window.mostrarToast('Error de conexión. Inténtalo de nuevo.', 'error');
      }
    });
  });
});

// IntersectionObserver para .animar-entrada / .animar-entrada-cascada
const obs = new IntersectionObserver(
  (entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
    });
  },
  { threshold: 0.15, rootMargin: '0px 0px -40px 0px' },
);
document.querySelectorAll('.animar-entrada, .animar-entrada-cascada').forEach((el) => obs.observe(el));
</script>
