---
/**
 * PÁGINA: Detalle de curso (/cursos/[id])
 * ---------------------------------------
 * Página pública con el detalle completo de un curso. Estructura:
 *  1. Hero a una columna centrada: badge, título, meta, precio + CTA comprar.
 *  2. Sección "Qué incluye" con la descripción HTML del curso ya
 *     sanitizada en el server por limpiarHtml.
 *  3. Sección "Índice de temas" — timeline numerado con título y duración.
 *  4. Sección "Cómo es la experiencia" — bullets fijos que recuerdan los
 *     beneficios de la plataforma (vídeo on-demand, materiales descargables,
 *     compra única, hasta 3 dispositivos).
 *  5. CTA final con precio y botón comprar.
 *  6. Atribución: el contenido es de Una Maestra Muy Especial bajo licencia.
 *
 * Una página estática por curso (generada en build vía getStaticPaths
 * leyendo de la API). Si el build no tiene conectividad, devolvemos []
 * y no se generan páginas; el siguiente deploy con conectividad las regenera.
 */
import Plantilla from '../../layouts/Plantilla.astro';
import CabeceraPublica from '../../components/CabeceraPublica.astro';
import PiePagina from '../../components/PiePagina.astro';
import { formatearDuracion } from '../../utils/duracion';

interface CursoBasico {
  id: number;
  titulo: string;
  etiqueta?: string;
  color?: string;
  imagen?: string;
  precio?: string | number;
  num_temas?: number | string;
}
interface Tema { id: number; titulo: string; duracion_seg?: number | null; }
interface CursoDetalle extends CursoBasico {
  descripcion?: string;
  nivel?: string;
  duracion_seg?: number | null;
  pack?: string;
  pack_color?: string;
  temas?: Tema[];
}

export async function getStaticPaths() {
  const BASE = 'http://cursosumme.es';
  let cursos: CursoBasico[] = [];
  try {
    const res = await fetch(`${BASE}/api/cursos.php?publicos=1`);
    if (res.ok) {
      const data = await res.json();
      cursos = (data.cursos ?? []) as CursoBasico[];
    }
  } catch { /* build sin conectividad */ }

  const paths = await Promise.all(
    cursos.map(async (c) => {
      let detalle: CursoDetalle = c;
      try {
        const r = await fetch(`${BASE}/api/cursos.php?publicos=1&id=${c.id}`);
        if (r.ok) {
          const j = await r.json();
          if (j.curso) detalle = j.curso as CursoDetalle;
        }
      } catch { /* fallback al básico */ }
      return { params: { id: String(c.id) }, props: { curso: detalle } };
    }),
  );
  return paths;
}

const { curso } = Astro.props as { curso: CursoDetalle };
const PALETA = ['#b3e8da','#b5c8e8','#d4c8e8','#fff8b7','#ffb5a7','#c8e8b5'];
const color = curso.color || PALETA[curso.id % PALETA.length];
const precioFmt = curso.precio
  ? parseFloat(String(curso.precio)).toFixed(2).replace('.', ',')
  : null;
const numTemas = Number(curso.num_temas ?? curso.temas?.length ?? 0);
const tituloPag = `${curso.titulo} — Cursos Umme`;
---

<Plantilla titulo={tituloPag}>
  <CabeceraPublica activa="cursos" />

  <main class="curso-detalle" style={`--curso-color: ${color};`}>

    <!-- HERO a dos columnas -->
    <section class="cd-hero">
      <div class="cd-hero-deco" aria-hidden="true"></div>

      <div class="cd-hero-grid">
        <div class="cd-hero-info">
          <p class="cd-breadcrumb">
            <a href="/precios">← Volver al catálogo</a>
          </p>

          <div class="cd-chips">
            {curso.etiqueta && <span class="cd-chip">{curso.etiqueta}</span>}
            {curso.pack && <span class="cd-chip cd-chip--pack">{curso.pack}</span>}
          </div>

          <h1 class="cd-titulo">{curso.titulo}</h1>

          <ul class="cd-meta">
            {numTemas > 0 && (
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                <span><strong>{numTemas}</strong> {numTemas === 1 ? 'tema' : 'temas'}</span>
              </li>
            )}
            {formatearDuracion(curso.duracion_seg) && (
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>{formatearDuracion(curso.duracion_seg)}</span>
              </li>
            )}
            {curso.nivel && (
              <li>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 3v18h18"/><path d="M7 14l4-4 4 4 5-5"/></svg>
                <span>{curso.nivel}</span>
              </li>
            )}
          </ul>

          <div class="cd-compra">
            {precioFmt && (
              <div class="cd-precio">
                <span class="cd-precio-valor">{precioFmt}</span>
                <span class="cd-precio-moneda">€</span>
              </div>
            )}
            <button
              type="button"
              class="cd-cta"
              data-tipo="curso"
              data-id={curso.id}
            >
              Comprar acceso →
            </button>
          </div>

          <p class="cd-confianza">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            Pago seguro con Stripe · Credenciales por correo tras el pago
          </p>
        </div>

      </div>
    </section>

    <!-- QUÉ INCLUYE -->
    <section class="cd-seccion">
      <div class="cd-seccion-inner">
        <header class="cd-seccion-header animar-entrada">
          <h2>Qué incluye este curso</h2>
        </header>

        {curso.descripcion ? (
          <div class="cd-descripcion animar-entrada" set:html={curso.descripcion} />
        ) : (
          <p class="cd-vacia animar-entrada">
            Pronto añadiremos más detalles. Mira el índice de temas para hacerte una idea
            o pulsa "Comprar acceso" para empezar ya.
          </p>
        )}
      </div>
    </section>

    <!-- CÓMO ES LA EXPERIENCIA -->
    <section class="cd-seccion">
      <div class="cd-seccion-inner">
        <header class="cd-seccion-header animar-entrada">
          <h2>Cómo es la experiencia</h2>
          <p>Pensado para que estudies a tu ritmo, desde donde quieras, con todo lo que necesitas a mano.</p>
        </header>
        <div class="cd-experiencia animar-entrada-cascada">
          <article class="cd-exp-item">
            <div class="cd-exp-icono">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
            </div>
            <h3>Vídeo on-demand</h3>
            <p>Lecciones en alta calidad para ver cuando tú decidas, sin horarios.</p>
          </article>
          <article class="cd-exp-item">
            <div class="cd-exp-icono">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            </div>
            <h3>Materiales descargables</h3>
            <p>Plantillas, checklists y documentos para trabajar offline cuando quieras.</p>
          </article>
          <article class="cd-exp-item">
            <div class="cd-exp-icono">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
            </div>
            <h3>Compra única</h3>
            <p>Sin suscripciones, sin renovaciones automáticas ni costes ocultos. Pagas una vez y listo.</p>
          </article>
          <article class="cd-exp-item">
            <div class="cd-exp-icono">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
            <h3>Hasta 3 dispositivos</h3>
            <p>Sigue el curso en ordenador, tablet o móvil — sin perder el progreso.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- CTA FINAL -->
    <section class="cd-cierre">
      <div class="cd-cierre-inner animar-entrada">
        <h2>Empieza con este curso</h2>
        {precioFmt && (
          <p class="cd-cierre-precio">Acceso completo por <strong>{precioFmt} €</strong></p>
        )}
        <button
          type="button"
          class="cd-cta cd-cta--grande"
          data-tipo="curso"
          data-id={curso.id}
        >
          Comprar acceso →
        </button>
        <p class="cd-cierre-pie">Pago único · Sin suscripción · Acceso inmediato tras el pago · Acceso hasta finalización de convocatoria</p>
      </div>
    </section>

    <!-- ATRIBUCIÓN DE CONTENIDO -->
    <aside class="cd-licencia">
      <p>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
        Materiales didácticos de <strong>Una Maestra Muy Especial</strong>, ofrecidos en Cursos Umme bajo licencia.
      </p>
    </aside>
  </main>

  <PiePagina />
</Plantilla>

<style is:global>
/* ───────────────────────────────────────────────────────────────
   Detalle de curso (/cursos/[id])
   Variables: --curso-color desde el .curso-detalle padre.
   ─────────────────────────────────────────────────────────────── */
.curso-detalle { background: #fff; }

/* Animaciones de entrada al scroll (mismas que en la landing) */
.animar-entrada {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  will-change: opacity, transform;
}
.animar-entrada.visible { opacity: 1; transform: translateY(0); }
.animar-entrada-cascada > * {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.6s ease, transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
}
.animar-entrada-cascada.visible > *           { opacity: 1; transform: none; }
.animar-entrada-cascada.visible > *:nth-child(1) { transition-delay: 0.00s; }
.animar-entrada-cascada.visible > *:nth-child(2) { transition-delay: 0.06s; }
.animar-entrada-cascada.visible > *:nth-child(3) { transition-delay: 0.12s; }
.animar-entrada-cascada.visible > *:nth-child(4) { transition-delay: 0.18s; }
.animar-entrada-cascada.visible > *:nth-child(5) { transition-delay: 0.24s; }
.animar-entrada-cascada.visible > *:nth-child(6) { transition-delay: 0.30s; }
.animar-entrada-cascada.visible > *:nth-child(7) { transition-delay: 0.36s; }
.animar-entrada-cascada.visible > *:nth-child(8) { transition-delay: 0.42s; }
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { animation: none !important; transition: none !important; }
  .animar-entrada, .animar-entrada-cascada > * { opacity: 1 !important; transform: none !important; }
  .cd-hero-deco { display: none !important; }
}

/* Reutilizamos el keyframes del hero de la landing */
@keyframes blobFlota1 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50%      { transform: translate(-22px, 18px) scale(1.06); }
}

/* ── HERO a una columna ────────────────────────────────────── */
.cd-hero {
  position: relative;
  padding: 4rem 1.5rem 4.5rem;
  overflow: hidden;
  background:
    radial-gradient(circle at 90% 10%, color-mix(in srgb, var(--curso-color) 65%, transparent), transparent 55%),
    radial-gradient(circle at 10% 90%, color-mix(in srgb, var(--curso-color) 45%, transparent), transparent 50%),
    linear-gradient(135deg,
      color-mix(in srgb, var(--curso-color) 25%, #ffffff) 0%,
      color-mix(in srgb, var(--curso-color) 50%, #ffffff) 100%);
}
.cd-hero-deco {
  position: absolute;
  width: 520px;
  height: 520px;
  border-radius: 50%;
  background: var(--curso-color);
  filter: blur(80px);
  opacity: 0.65;
  top: -160px;
  right: -140px;
  pointer-events: none;
  animation: blobFlota1 11s ease-in-out infinite;
}
.cd-hero-deco::after {
  content: '';
  position: absolute;
  width: 360px;
  height: 360px;
  border-radius: 50%;
  background: var(--curso-color);
  filter: blur(70px);
  opacity: 0.55;
  bottom: -700px;
  left: -240px;
}
.cd-hero-grid {
  max-width: 1100px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}
.cd-hero-info {
  display: flex;
  flex-direction: column;
  gap: 1.1rem;
}
.cd-breadcrumb { font-size: 0.85rem; margin: 0 0 0.4rem; }
.cd-breadcrumb a {
  color: var(--color-text-muted);
  text-decoration: none;
  font-weight: 600;
  transition: color 0.15s;
}
.cd-breadcrumb a:hover { color: var(--color-text); }

.cd-chips { display: flex; gap: 0.5rem; flex-wrap: wrap; }
.cd-chip {
  background: #fff;
  color: var(--color-text);
  padding: 0.35rem 0.8rem;
  border-radius: 999px;
  font-size: 0.68rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}
.cd-chip--pack { background: var(--color-secondary); }

.cd-titulo {
  font-size: clamp(1.9rem, 4.5vw, 2.9rem);
  font-weight: 800;
  letter-spacing: -0.02em;
  line-height: 1.1;
  margin: 0.3rem 0 0.4rem;
  color: var(--color-text);
}

.cd-meta {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem 1.5rem;
}
.cd-meta li {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.9rem;
  color: var(--color-text-muted);
}
.cd-meta li strong { color: var(--color-text); font-weight: 700; }
.cd-meta svg { color: var(--color-text); flex-shrink: 0; }

.cd-compra {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-top: 0.75rem;
  flex-wrap: wrap;
}
.cd-precio {
  background: #fff;
  padding: 0.85rem 1.25rem;
  border-radius: var(--radius-md);
  box-shadow: 0 4px 14px rgba(0,0,0,0.06);
  display: inline-flex;
  align-items: baseline;
  gap: 0.2rem;
}
.cd-precio-valor {
  font-size: 2.2rem;
  font-weight: 800;
  line-height: 1;
  color: var(--color-text);
  letter-spacing: -0.02em;
}
.cd-precio-moneda {
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--color-text-muted);
}
.cd-cta {
  background: var(--color-coral);
  color: var(--color-text);
  border: none;
  border-radius: var(--radius-sm);
  padding: 1rem 1.85rem;
  font-family: 'DM Sans', sans-serif;
  font-weight: 800;
  font-size: 1rem;
  cursor: pointer;
  min-height: 52px;
  transition: transform 0.18s cubic-bezier(0.34, 1.56, 0.64, 1),
              box-shadow 0.18s, opacity 0.15s;
  will-change: transform;
}
.cd-cta:hover {
  transform: translateY(-2px) scale(1.03);
  box-shadow: 0 12px 28px rgba(0,0,0,0.14);
  opacity: 0.95;
}
.cd-cta:active { transform: translateY(0) scale(0.98); }
.cd-cta:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

.cd-confianza {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  font-size: 0.78rem;
  color: var(--color-text-muted);
  margin: 0;
}

/* ── Secciones ─────────────────────────────────────────────── */
.cd-seccion {
  padding: 4rem 1.5rem;
}
.cd-seccion--clara { background: var(--color-light); }
.cd-seccion-inner {
  max-width: 1100px;
  margin: 0 auto;
}
.cd-seccion-header { margin-bottom: 1.75rem; }
.cd-seccion-header h2 {
  font-size: clamp(1.4rem, 2.5vw, 1.9rem);
  font-weight: 800;
  letter-spacing: -0.015em;
  margin: 0 0 0.5rem;
}
.cd-seccion-header p {
  font-size: 0.95rem;
  color: var(--color-text-muted);
  line-height: 1.6;
  margin: 0;
}

/* ── Descripción HTML del curso (estilo editorial Medium/Substack)
   Tipografía generosa, mucho aire, sin cajas con borde ni fondos.
   Los bloques custom del editor (.desc-card, .desc-stats, .desc-nota,
   .desc-bienvenida) se aplanan: títulos clásicos, números grandes,
   barras laterales en lugar de fondos. La columna mantiene medida
   de lectura cómoda (~720px) centrada para no cansar la vista.
   ─────────────────────────────────────────────────────────── */
.cd-descripcion {
  font-size: 1.13rem;
  line-height: 1.78;
  color: #1f1f1f;
  max-width: none;
  margin: 0;
  font-feature-settings: "kern" 1, "liga" 1;
}
.cd-descripcion > * + * { margin-top: 1.4rem; }

.cd-descripcion p {
  margin: 0;
}
.cd-descripcion p span { display: inline; }

.cd-descripcion em {
  font-style: italic;
  color: #1f1f1f;
}

.cd-descripcion strong {
  font-weight: 700;
  color: var(--color-text);
}

.cd-descripcion h2 {
  font-size: 1.85rem;
  font-weight: 800;
  letter-spacing: -0.02em;
  line-height: 1.2;
  color: var(--color-text);
  margin-top: 3rem;
  margin-bottom: 0.4rem;
}
.cd-descripcion h3 {
  font-size: 1.35rem;
  font-weight: 700;
  letter-spacing: -0.01em;
  line-height: 1.3;
  color: var(--color-text);
  margin-top: 2.5rem;
  margin-bottom: 0.3rem;
}

.cd-descripcion ul,
.cd-descripcion ol {
  margin: 0;
  padding-left: 0;
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0.85rem;
}
.cd-descripcion li {
  position: relative;
  padding-left: 1.6rem;
  line-height: 1.7;
}
.cd-descripcion li::before {
  content: '';
  position: absolute;
  left: 0.25rem;
  top: 0.78em;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--color-text);
}

.cd-descripcion blockquote {
  margin: 2.2rem 0;
  padding: 0.2rem 0 0.2rem 1.5rem;
  border-left: 4px solid var(--curso-color);
  font-size: 1.3rem;
  font-weight: 500;
  line-height: 1.5;
  letter-spacing: -0.01em;
  color: var(--color-text);
  font-style: italic;
}
.cd-descripcion blockquote p { margin: 0; }

/* ── Bloques custom del editor (aplanados, sin cajas) ──── */

/* .desc-card: el editor lo usa para listas tipo "Qué aprenderás".
   Eliminamos la caja: solo queda un h3 + lista, separados del
   resto por un poco más de margen vertical. */
.cd-descripcion .desc-card {
  margin: 2.5rem 0;
}
.cd-descripcion .desc-card h3 {
  margin-top: 0;
  margin-bottom: 1rem;
}

/* .desc-temario: bloque pensado expresamente para listar el temario
   del curso (10-20 bloques numerados). Cada item es una tarjeta con
   un número grande a la izquierda y el título a la derecha. La
   numeración la genera el CSS vía counter, así que el HTML solo
   necesita el título plano dentro del <li>. */
.cd-descripcion .desc-temario {
  margin: 2.5rem 0;
}
.cd-descripcion .desc-temario > p {
  margin: 0 0 1.1rem;
  color: var(--color-text-muted);
  font-size: 0.98rem;
  line-height: 1.55;
}
.cd-descripcion .desc-temario > p:last-child {
  margin: 1.25rem 0 0;
}
.cd-descripcion .desc-temario ol,
.cd-descripcion .desc-temario ul {
  list-style: none;
  padding: 0;
  margin: 0;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  /* Todas las filas miden lo mismo (la fila más alta), así los items
     con título de 2 líneas no dejan a sus compañeros de fila más
     bajitos. Sin esto el grid queda "escalonado". */
  grid-auto-rows: 1fr;
  gap: 0.55rem 0.75rem;
  counter-reset: temario;
}
.cd-descripcion .desc-temario li {
  counter-increment: temario;
  display: flex;
  /* align-items: center para que el texto del título quede centrado
     verticalmente cuando la card es más alta que su contenido
     (porque otra card de la fila tiene 2 líneas). El badge se estira
     a todo el alto vía align-self: stretch en ::before. */
  align-items: center;
  padding: 0 1rem 0 0;
  background: #fff;
  border: 1px solid #eef0ef;
  border-radius: var(--radius-sm);
  overflow: hidden;
  /* min-height dimensionado para 2 líneas siempre: ~26px por línea
     × 2 + margen visual ≈ 68px. Con esto TODAS las cards tienen el
     mismo alto (la de 2-líneas encaja; la de 1-línea se ve con texto
     centrado y un poco de aire). grid-auto-rows: 1fr no era suficiente
     porque el grid no tiene alto fijo y no propaga el alto máximo
     entre filas. */
  min-height: 68px;
  height: 100%;
  font-size: 0.92rem;
  line-height: 1.4;
  transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
}
.cd-descripcion .desc-temario li::before {
  content: counter(temario, decimal-leading-zero);
  flex-shrink: 0;
  width: 50px;
  /* align-self: stretch para que el badge mantenga su alto completo
     aunque el padre tenga align-items: center (que afecta al texto). */
  align-self: stretch;
  display: flex;
  align-items: center;
  justify-content: center;
  background: color-mix(in srgb, var(--curso-color, var(--color-primary)) 45%, #ffffff);
  color: var(--curso-color, var(--color-primary));
  filter: brightness(0.55) saturate(1.4);
  font-weight: 800;
  font-size: 0.95rem;
  letter-spacing: -0.01em;
  margin-right: 0.85rem;
  position: static;
  border-radius: 0;
  top: auto;
  left: auto;
  background-image: linear-gradient(
    180deg,
    transparent,
    rgba(0,0,0,0.04)
  );
}
.cd-descripcion .desc-temario li:hover {
  border-color: color-mix(in srgb, var(--curso-color, var(--color-primary)) 60%, transparent);
  transform: translateX(2px);
  box-shadow: 0 8px 18px -10px color-mix(in srgb, var(--curso-color, var(--color-primary)) 55%, rgba(0,0,0,0.08));
}
/* Items que llegan dentro de un wrapper (span/strong) — flex:1 para
   que el texto ocupe todo el ancho disponible y se centre vertical. */
.cd-descripcion .desc-temario li > * {
  align-self: center;
  flex: 1;
}
@media (max-width: 480px) {
  .cd-descripcion .desc-temario ol,
  .cd-descripcion .desc-temario ul {
    grid-template-columns: 1fr;
  }
  .cd-descripcion .desc-temario li::before { width: 44px; font-size: 0.88rem; }
}

/* .desc-stats: cifras destacadas en grid. Sin cajas — solo
   números enormes y label discreto, separados por una línea
   sutil arriba y abajo. */
.cd-descripcion .desc-stats {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
  gap: 1.5rem 2rem;
  margin: 2.5rem 0;
  padding: 1.75rem 0;
  border-top: 1px solid #eef0ef;
  border-bottom: 1px solid #eef0ef;
}
.cd-descripcion .desc-stat {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0.2rem;
}
.cd-descripcion .desc-stat strong {
  font-size: 2.4rem;
  font-weight: 800;
  line-height: 1;
  letter-spacing: -0.03em;
  color: var(--color-text);
}
.cd-descripcion .desc-stat span {
  font-size: 0.82rem;
  font-weight: 500;
  color: var(--color-text-muted);
  text-transform: none;
  letter-spacing: 0;
}

/* .desc-nota: barra lateral discreta a la izquierda, sin fondo. */
.cd-descripcion .desc-nota {
  margin: 2rem 0;
  padding: 0.2rem 0 0.2rem 1.25rem;
  border-left: 3px solid color-mix(in srgb, var(--curso-color) 70%, #ffffff);
  font-size: 1rem;
  line-height: 1.7;
  color: #2a2a2a;
}
.cd-descripcion .desc-nota p { margin: 0; }
.cd-descripcion .desc-nota strong {
  font-weight: 700;
}

/* .desc-bienvenida: bloque de bienvenida con etiqueta + contenido,
   destacado con fondo suave del color del curso para cerrar la sección. */
.cd-descripcion .desc-bienvenida {
  margin: 3rem 0 0;
  padding: 1.75rem 1.75rem 1.6rem;
  border-radius: var(--radius-md);
  background: color-mix(in srgb, var(--curso-color) 18%, #ffffff);
  border: 1px solid color-mix(in srgb, var(--curso-color) 35%, transparent);
}
.cd-descripcion .desc-bienvenida-tag {
  display: inline-block;
  font-size: 0.7rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.14em;
  color: var(--color-text);
  background: #fff;
  padding: 0.3rem 0.7rem;
  border-radius: 999px;
  margin-bottom: 0.85rem;
  box-shadow: 0 2px 6px rgba(0,0,0,0.06);
}
.cd-descripcion .desc-bienvenida-inner > * + * { margin-top: 0.8rem; }
.cd-descripcion .desc-bienvenida-inner p { margin: 0; line-height: 1.65; }
.cd-descripcion .desc-bienvenida br:only-child { display: none; }

/* ── Ocultar bloques del editor sin contenido real ───────────
   El RTE persiste estos contenedores aunque la usuaria los deje
   en blanco; sin estas reglas se ven sus márgenes, bordes y fondos
   como "huecos de diseño" entre párrafos. Cada regla pregunta
   ":hay dentro algo que merezca renderizarse?", y si no, oculta
   el bloque entero. */
.cd-descripcion .desc-impacto:not(:has(:where(p, h2, h3, h4):not(:empty))) { display: none; }
.cd-descripcion .desc-card:not(:has(:where(li, p):not(:empty))) { display: none; }
.cd-descripcion .desc-chips:not(:has(li)) { display: none; }
.cd-descripcion .desc-para-quien:not(:has(li)) { display: none; }
.cd-descripcion .desc-si:not(:has(li)),
.cd-descripcion .desc-no:not(:has(li)) { display: none; }
.cd-descripcion .desc-stat:not(:has(:where(strong, span):not(:empty))) { display: none; }
.cd-descripcion .desc-stats:not(:has(strong:not(:empty))) { display: none; }
.cd-descripcion .desc-bienvenida:not(:has(.desc-bienvenida-inner > *:not(:empty))) { display: none; }

/* .desc-impacto: frase potente destacada. Sin caja, solo tipografía
   grande con barra lateral de color para llamar la atención. */
.cd-descripcion .desc-impacto {
  margin: 2.5rem 0;
  padding: 0.4rem 0 0.4rem 1.5rem;
  border-left: 4px solid var(--curso-color);
  font-size: 1.35rem;
  font-weight: 600;
  line-height: 1.4;
  letter-spacing: -0.01em;
  color: var(--color-text);
}
.cd-descripcion .desc-impacto p { margin: 0; }
.cd-descripcion .desc-impacto em {
  font-style: italic;
  color: color-mix(in srgb, var(--color-text) 75%, transparent);
}

/* .desc-chips: pills/tags reales. Cada <li> es un chip con fondo del
   color del curso. Si la lista está vacía, se oculta. */
.cd-descripcion .desc-chips {
  margin: 2rem 0;
}
.cd-descripcion .desc-chips ul {
  flex-direction: row;
  flex-wrap: wrap;
  gap: 0.55rem;
}
.cd-descripcion .desc-chips li {
  padding: 0.5rem 0.95rem;
  background: color-mix(in srgb, var(--curso-color) 22%, #ffffff);
  border: 1px solid color-mix(in srgb, var(--curso-color) 40%, transparent);
  border-radius: 999px;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.2;
}
.cd-descripcion .desc-chips li::before { display: none; }

/* .desc-para-quien: dos columnas "es para ti" / "no es para ti".
   Tarjetas suaves diferenciadas con un símbolo (✓ / ✗) antes del título. */
.cd-descripcion .desc-para-quien {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem;
  margin: 2.5rem 0;
}
.cd-descripcion .desc-si,
.cd-descripcion .desc-no {
  padding: 1.4rem 1.5rem;
  border-radius: var(--radius-md);
  background: #fafafa;
  border: 1px solid #eef0ef;
}
.cd-descripcion .desc-si {
  background: color-mix(in srgb, #c8e8b5 30%, #ffffff);
  border-color: color-mix(in srgb, #c8e8b5 60%, transparent);
}
.cd-descripcion .desc-no {
  background: #f6f6f6;
  border-color: #ececec;
}
.cd-descripcion .desc-si h3,
.cd-descripcion .desc-no h3 {
  font-size: 1.02rem;
  font-weight: 800;
  margin: 0 0 0.85rem;
  padding-left: 1.85rem;
  position: relative;
  letter-spacing: -0.01em;
}
.cd-descripcion .desc-si h3::before,
.cd-descripcion .desc-no h3::before {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 22px;
  height: 22px;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 0.85rem;
  font-weight: 800;
  line-height: 1;
}
.cd-descripcion .desc-si h3::before {
  content: '✓';
  background: #6fbf6f;
  color: #fff;
}
.cd-descripcion .desc-no h3::before {
  content: '✗';
  background: #b8b8b8;
  color: #fff;
}
.cd-descripcion .desc-si ul,
.cd-descripcion .desc-no ul { gap: 0.55rem; }
.cd-descripcion .desc-si li,
.cd-descripcion .desc-no li {
  font-size: 0.95rem;
  line-height: 1.55;
  padding-left: 1.2rem;
}
.cd-descripcion .desc-si li::before {
  background: #6fbf6f;
  top: 0.7em;
}
.cd-descripcion .desc-no li::before {
  background: #b8b8b8;
  top: 0.7em;
}
@media (max-width: 640px) {
  .cd-descripcion .desc-para-quien { grid-template-columns: 1fr; }
}

.cd-vacia {
  color: var(--color-text-muted);
  font-size: 0.95rem;
  line-height: 1.7;
}

/* ── Experiencia (4 bullets con icono) ─────────────────────── */
.cd-experiencia {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1.25rem;
}
.cd-exp-item {
  background: var(--color-light);
  border-radius: var(--radius-md);
  padding: 1.5rem 1.4rem;
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.25s;
}
.cd-exp-item:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 22px rgba(0,0,0,0.06);
}
.cd-exp-icono {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  background: var(--color-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-text);
  margin-bottom: 0.9rem;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}
.cd-exp-icono svg { width: 22px; height: 22px; }
.cd-exp-item:hover .cd-exp-icono { transform: scale(1.12) rotate(-6deg); }
.cd-exp-item h3 {
  font-size: 0.98rem;
  font-weight: 800;
  margin: 0 0 0.35rem;
}
.cd-exp-item p {
  font-size: 0.85rem;
  color: var(--color-text-muted);
  line-height: 1.55;
  margin: 0;
}

/* ── Cierre / CTA final ──────────────────────────────────── */
.cd-cierre {
  padding: 4.5rem 1.5rem 5rem;
  background:
    radial-gradient(circle at 20% 80%, rgba(255,181,167,0.3), transparent 50%),
    radial-gradient(circle at 80% 20%, rgba(255,248,183,0.4), transparent 50%),
    color-mix(in srgb, var(--curso-color) 60%, #ffffff);
}
.cd-cierre-inner {
  max-width: 1100px;
  margin: 0 auto;
  text-align: center;
}
.cd-cierre h2 {
  font-size: clamp(1.6rem, 3vw, 2.1rem);
  font-weight: 800;
  letter-spacing: -0.02em;
  margin: 0 0 0.6rem;
}
.cd-cierre-precio {
  font-size: 1.05rem;
  color: var(--color-text);
  margin: 0 0 1.5rem;
}
.cd-cierre-precio strong { font-weight: 800; }
.cd-cta--grande {
  padding: 1.1rem 2.4rem;
  font-size: 1.08rem;
  min-height: 56px;
}
.cd-cierre-pie {
  margin-top: 1.25rem;
  font-size: 0.85rem;
  color: var(--color-text);
  opacity: 0.7;
}

/* ── Atribución ──────────────────────────────────────────── */
.cd-licencia {
  text-align: center;
  padding: 1.75rem 1.5rem 2.5rem;
  background: #fff;
}
.cd-licencia p {
  font-size: 0.82rem;
  color: var(--color-text-muted);
  margin: 0;
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
}
.cd-licencia strong { color: var(--color-text); font-weight: 700; }

/* ── Responsive ──────────────────────────────────────────── */
@media (max-width: 480px) {
  .cd-hero { padding: 2.5rem 1.25rem 3rem; }
  .cd-seccion { padding: 3rem 1.25rem; }
  .cd-cierre { padding: 3.5rem 1.25rem 4rem; }
  .cd-compra { width: 100%; }
  .cd-cta, .cd-precio { width: 100%; justify-content: center; }
}
</style>

<script>
// Comprar curso vía Stripe Checkout. Mismo patrón que /precios.
document.querySelectorAll<HTMLButtonElement>('.cd-cta').forEach((btn) => {
  btn.addEventListener('click', async () => {
    await window.botonCargando(btn, 'Redirigiendo…', async () => {
      try {
        const res = await fetch('/api/stripe-checkout.php', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            tipo: btn.dataset.tipo,
            id: Number(btn.dataset.id),
          }),
        });
        const data = await res.json();
        if (data.ok && data.url) {
          window.location.href = data.url;
        } else {
          window.mostrarToast(data.mensaje || 'No se pudo iniciar el pago.', 'error');
        }
      } catch {
        window.mostrarToast('Error de conexión. Inténtalo de nuevo.', 'error');
      }
    });
  });
});

// IntersectionObserver para .animar-entrada / .animar-entrada-cascada
const obs = new IntersectionObserver(
  (entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); }
    });
  },
  { threshold: 0.15, rootMargin: '0px 0px -40px 0px' },
);
document.querySelectorAll('.animar-entrada, .animar-entrada-cascada').forEach((el) => obs.observe(el));
</script>
