---
/**
 * PÁGINA: Login (/login)
 * ----------------------
 * Formulario de acceso para alumnas y administración. Antes vivía en `/`,
 * pero `/` se convirtió en la landing comercial pública, así que el login
 * tiene su propia URL dedicada.
 *
 * Flujo:
 *  1. Si ya hay una sesión vigente en sessionStorage, redirige al área
 *     privada que corresponda (/admin o /inicio) — el usuario no ve el
 *     formulario en absoluto.
 *  2. Si llegamos con `?expirada=1` (porque el interceptor global detectó
 *     un 401 con sesión guardada), mostramos un aviso explícito antes
 *     de que la alumna vuelva a teclear las credenciales.
 *  3. La pintura visual y la lógica del POST viven en `TarjetaLogin`.
 */
import Plantilla from '../layouts/Plantilla.astro';
import TarjetaLogin from '../components/TarjetaLogin.astro';
import FondoLogin from '../components/FondoLogin.astro';
import '../styles/index.css';
---

<Plantilla>
  <!-- Si ya hay sesión vigente (efímera o "Recordarme"), saltar el formulario
       y llevar al usuario directamente a su área privada. La hidratación de
       Plantilla ya copió localStorage→sessionStorage si correspondía, así que
       basta con leer sessionStorage. -->
  <script is:inline>
  (function () {
    try {
      var raw = sessionStorage.getItem('umme_session');
      if (!raw) return;
      var s = JSON.parse(raw);
      if (!s || !s.exp || Date.now() > s.exp) {
        sessionStorage.removeItem('umme_session');
        localStorage.removeItem('umme_session');
        return;
      }
      window.location.replace(s.rol === 'admin' ? '/admin' : '/inicio');
    } catch (e) {}
  })();
  </script>

  <!-- Si venimos redirigidos por sesión expirada (?expirada=1), avisamos al usuario -->
  <script is:inline>
  (function () {
    if (new URLSearchParams(window.location.search).get('expirada') !== '1') return;
    document.addEventListener('DOMContentLoaded', function () {
      var el = document.getElementById('login-error');
      if (!el) return;
      el.textContent  = 'Tu sesión ha caducado. Vuelve a iniciar sesión.';
      el.style.display = 'block';
      history.replaceState(null, '', '/login');
    });
  })();
  </script>

  <FondoLogin />
  <a href="/" class="login-volver" aria-label="Volver a Cursos Umme">
    <span aria-hidden="true">←</span> Volver a Cursos Umme
  </a>
  <main class="login-page">
    <TarjetaLogin />
  </main>
</Plantilla>

<style>
.login-volver {
  position: absolute;
  top: 1.25rem;
  left: 1.5rem;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.5rem 0.9rem;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(6px);
  border: 1px solid rgba(0, 0, 0, 0.06);
  border-radius: 999px;
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--color-text);
  text-decoration: none;
  transition: background 0.15s, transform 0.15s, border-color 0.15s;
}
.login-volver:hover {
  background: #fff;
  border-color: var(--color-primary);
  transform: translateX(-2px);
}
@media (max-width: 480px) {
  .login-volver { top: 0.85rem; left: 0.85rem; padding: 0.4rem 0.75rem; font-size: 0.78rem; }
}
</style>
