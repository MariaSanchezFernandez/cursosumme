---
/**
 * PÁGINA: /pago-ok
 * ----------------
 * Aterrizaje tras Stripe Checkout exitoso. Verifica el estado real del
 * pago contra el servidor antes de mostrar "completado" — el éxito
 * visible solo aparece cuando el webhook ha procesado la sesión.
 *
 * Tres estados visuales con misma plantilla corporativa (cabecera +
 * pie + tarjeta centrada con icono, h1, mensaje y CTA). Comparte las
 * clases .pago-estado-* con /pago-ko vía estilos globales.
 */
import Plantilla from '../layouts/Plantilla.astro';
import CabeceraPublica from '../components/CabeceraPublica.astro';
import PiePagina from '../components/PiePagina.astro';
import '../styles/global.css';
---

<Plantilla titulo="Procesando pago — Cursos Umme">
  <CabeceraPublica activa="cursos" />

  <main class="pago-estado">
    <div class="pago-estado-inner" id="estado-cargando">
      <div class="pago-estado-icono pago-estado-icono--neutro" aria-hidden="true">
        <span class="pago-estado-spinner"></span>
      </div>
      <h1>Procesando tu pago…</h1>
      <p class="pago-estado-msg">Esto suele tardar unos segundos. No cierres la pestaña.</p>
    </div>

    <div class="pago-estado-inner" id="estado-ok" style="display:none;">
      <div class="pago-estado-icono pago-estado-icono--ok" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
      <h1>¡Pago completado!</h1>
      <p class="pago-estado-msg">
        Recibirás un email en breve con tus credenciales de acceso.<br/>
        <strong>Revisa también la carpeta de spam</strong> si no lo ves en unos minutos.
      </p>
      <div class="pago-estado-cta">
        <a href="/login" class="cta cta--primary">Ir a la plataforma →</a>
      </div>
    </div>

    <div class="pago-estado-inner" id="estado-error" style="display:none;">
      <div class="pago-estado-icono" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="13"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      </div>
      <h1>Aún no hemos podido confirmar tu pago</h1>
      <p class="pago-estado-msg">
        Si has completado el pago, recibirás el email con tus accesos en unos minutos.<br/>
        Si crees que ha habido un problema, escribe a
        <a href="mailto:facturacion@cursosumme.es" class="pago-estado-mail">facturacion@cursosumme.es</a>.
      </p>
      <div class="pago-estado-cta">
        <a href="/login" class="cta cta--primary">Ir a la plataforma →</a>
      </div>
    </div>
  </main>

  <PiePagina />
</Plantilla>

<style is:global>
/* Variantes de color del icono para los distintos estados. La base
   .pago-estado-icono (coral) la define /pago-ko vía estilos globales;
   aquí solo añadimos los modificadores específicos. */
.pago-estado-icono--ok {
  background: color-mix(in srgb, var(--color-primary) 45%, #ffffff);
}
.pago-estado-icono--neutro {
  background: var(--color-light);
}
.pago-estado-spinner {
  width: 38px;
  height: 38px;
  border: 3px solid color-mix(in srgb, var(--color-text) 18%, #ffffff);
  border-top-color: var(--color-text);
  border-radius: 50%;
  animation: pagoEstadoSpin 0.9s linear infinite;
}
@keyframes pagoEstadoSpin { to { transform: rotate(360deg); } }
.pago-estado-mail {
  color: var(--color-text);
  font-weight: 700;
  text-decoration: underline;
  text-underline-offset: 3px;
}
.pago-estado-mail:hover { opacity: 0.75; }
</style>

<script>
// Verifica el pago en backend antes de pintar "completado". Si tras
// 15s (10 intentos × 1.5s) el webhook no ha actualizado el pago en BD,
// caemos a "error" amable: el dinero está bien en Stripe, solo no
// hemos podido confirmarlo aún del lado nuestro.
const params    = new URLSearchParams(location.search);
const sessionId = params.get('session_id') || '';

const elCargando = document.getElementById('estado-cargando')!;
const elOk       = document.getElementById('estado-ok')!;
const elError    = document.getElementById('estado-error')!;

function mostrar(estado: 'cargando' | 'ok' | 'error') {
  elCargando.style.display = estado === 'cargando' ? '' : 'none';
  elOk.style.display       = estado === 'ok'       ? '' : 'none';
  elError.style.display    = estado === 'error'    ? '' : 'none';
}

// Modo preview para revisar visualmente cada estado sin hacer un pago real:
//   /pago-ok/?preview=cargando | ok | error
// Solo activo en localhost — en producción se ignora para evitar que un
// enlace tipo /pago-ok/?preview=ok se use en phishing visual.
const esLocal = /^(localhost|127\.0\.0\.1|\[::1\])$/.test(location.hostname);
const preview = esLocal ? params.get('preview') : null;
if (preview === 'ok' || preview === 'error' || preview === 'cargando') {
  mostrar(preview);
} else if (!sessionId || !/^cs_[A-Za-z0-9_]{20,}$/.test(sessionId)) {
  mostrar('error');
} else {
  const MAX_INTENTOS  = 10;
  const INTERVALO_MS  = 1500;
  let intentos = 0;

  async function comprobar(): Promise<void> {
    intentos++;
    try {
      const res  = await fetch(`/api/pago-status.php?session_id=${encodeURIComponent(sessionId)}`);
      const data = await res.json();
      if (data.ok && data.estado === 'completado') {
        mostrar('ok');
        return;
      }
    } catch { /* reintentar */ }

    if (intentos >= MAX_INTENTOS) {
      mostrar('error');
    } else {
      setTimeout(comprobar, INTERVALO_MS);
    }
  }

  comprobar();
}
</script>
