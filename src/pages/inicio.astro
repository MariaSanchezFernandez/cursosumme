---
import Plantilla from '../layouts/Plantilla.astro';
import CabeceraApp from '../components/CabeceraApp.astro';
import PiePagina from '../components/PiePagina.astro';
import PanelDetalle from '../components/PanelDetalle.astro';
import '../styles/inicio.css';
import '../styles/TarjetaCurso.css';
---

<Plantilla>
  <CabeceraApp />

  <div id="banner-acceso" style="display:none;"></div>

  <div id="banner-vista-admin" style="display:none; background:#fff8e6; border-bottom:2px solid #f0c040; padding:0.55rem 2.5rem; font-size:0.8rem; font-weight:600; color:#7a5500; align-items:center; gap:0.75rem;">
    <svg viewBox="0 0 16 16" fill="none" width="14" height="14" style="flex-shrink:0;">
      <path d="M8 2a6 6 0 100 12A6 6 0 008 2z" stroke="currentColor" stroke-width="1.4"/>
      <path d="M8 7v4M8 5.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
    </svg>
    Estás viendo la plataforma como alumno (modo vista de administrador).
    <button onclick="window.close()" style="margin-left:auto; background:none; border:1px solid #c8a020; border-radius:5px; padding:0.2rem 0.6rem; font-size:0.75rem; font-weight:700; color:#7a5500; cursor:pointer;">
      Cerrar
    </button>
  </div>

  <main class="main">
    <div class="vista" id="vista">

      <!-- Columna izquierda: lista de cursos -->
      <div class="col-lista">
        <div class="seccion-header">
          <div>
            <h1>Mis cursos</h1>
            <p id="desc-cursos" style="color:var(--color-text-muted); font-size:0.88rem;"> </p>
          </div>
          <div class="filtros" id="filtros">
            <button class="filtro activo" data-filtro="todos">Todos</button>
          </div>
        </div>

        <section class="lista" id="lista-cursos">
          <!-- Skeletons mientras cargan los cursos (sustituidos por el render real) -->
          <div class="curso-skel" aria-hidden="true">
            <div class="skeleton skeleton-box curso-skel-img"></div>
            <div class="curso-skel-info">
              <div class="skeleton skeleton-text-lg skeleton-w-75"></div>
              <div class="skeleton skeleton-text skeleton-w-50"></div>
            </div>
          </div>
          <div class="curso-skel" aria-hidden="true">
            <div class="skeleton skeleton-box curso-skel-img"></div>
            <div class="curso-skel-info">
              <div class="skeleton skeleton-text-lg skeleton-w-90"></div>
              <div class="skeleton skeleton-text skeleton-w-50"></div>
            </div>
          </div>
          <div class="curso-skel" aria-hidden="true">
            <div class="skeleton skeleton-box curso-skel-img"></div>
            <div class="curso-skel-info">
              <div class="skeleton skeleton-text-lg skeleton-w-50"></div>
              <div class="skeleton skeleton-text skeleton-w-50"></div>
            </div>
          </div>
        </section>

      </div>

      <!-- Columna derecha: panel de detalle -->
      <PanelDetalle />

    </div>
  </main>

  <PiePagina />
</Plantilla>

<!-- GUARDIA DE RUTA -->
<script is:inline>
  (function () {
    try {
      // Modo vista-admin: cargar sesión temporal desde localStorage
      if (new URLSearchParams(window.location.search).get('vista-admin')) {
        const raw = localStorage.getItem('umme_vista_admin');
        if (raw) {
          const s = JSON.parse(raw);
          s.exp = Date.now() + 4 * 60 * 60 * 1000;
          sessionStorage.setItem('umme_session', JSON.stringify(s));
          localStorage.removeItem('umme_vista_admin');
          // Limpiar el parámetro de la URL
          history.replaceState(null, '', '/inicio');
        }
      }
      const raw = sessionStorage.getItem('umme_session');
      if (!raw) { window.location.replace('/'); return; }
      const s = JSON.parse(raw);
      if (!s || Date.now() > s.exp) {
        sessionStorage.removeItem('umme_session');
        localStorage.removeItem('umme_session');
        window.location.replace('/');
      }
    } catch { window.location.replace('/'); }
  })();
</script>

<script>
// Banner modo vista admin
try {
  const s = JSON.parse(sessionStorage.getItem('umme_session') || '{}');
  if (s.esVistaAdmin) document.getElementById('banner-vista-admin')!.style.display = 'flex';
} catch {}

// Banner fecha de expiración de acceso
(async () => {
  try {
    const s = JSON.parse(sessionStorage.getItem('umme_session') || '{}');
    if (s.rol === 'admin') return; // no aplica al admin

    let fechaBaja: string | null = s.fechaBaja ?? null;

    // Fallback: pedir al servidor si la sesión no tiene el dato
    if (!fechaBaja) {
      const res  = await fetch('/api/mi-acceso.php', { headers: { 'X-Token': s.token || '' } });
      const data = await res.json();
      if (data.ok && data.fecha_baja) {
        fechaBaja = data.fecha_baja;
        // Guardar para no volver a pedir en esta sesión
        s.fechaBaja = fechaBaja;
        sessionStorage.setItem('umme_session', JSON.stringify(s));
      }
    }

    if (!fechaBaja) return;

    const hoy    = new Date(); hoy.setHours(0, 0, 0, 0);
    const expira = new Date(fechaBaja + 'T00:00:00');
    const dias   = Math.ceil((expira.getTime() - hoy.getTime()) / 86400000);
    const banner = document.getElementById('banner-acceso') as HTMLElement;

    if (dias < 0) {
      // Ya expiró — no debería llegar aquí (login lo bloquea), pero por si acaso
      return;
    }

    let bg = '', borde = '', color = '', texto = '';
    const fechaFmt = expira.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' });

    if (dias <= 7) {
      bg = '#fff0f0'; borde = '#f5c6c6'; color = '#a33';
      texto = `⚠ Tu acceso expira en <strong>${dias} día${dias !== 1 ? 's' : ''}</strong> (${fechaFmt}). Contacta con tu administrador para renovarlo.`;
    } else if (dias <= 30) {
      bg = '#fff8e6'; borde = '#f0c040'; color = '#7a5500';
      texto = `Tu acceso expira el <strong>${fechaFmt}</strong> (en ${dias} días).`;
    } else {
      return; // Más de 30 días: no molestar
    }

    banner.innerHTML = `<div style="background:${bg};border-bottom:2px solid ${borde};padding:0.5rem 2.5rem;font-size:0.8rem;font-weight:600;color:${color};">${texto}</div>`;
    banner.style.display = 'block';
  } catch {}
})();

// ── Referencias DOM ───────────────────────────────────────────
const vista            = document.getElementById('vista')!;
const listaCursos      = document.getElementById('lista-cursos')!;
const filtrosWrap      = document.getElementById('filtros')!;
const descCursos       = document.getElementById('desc-cursos')!;
const detalleTit       = document.getElementById('detalleTitulo')!;
const listaTemas       = document.getElementById('listaTemas')!;
const panelSubtemas    = document.getElementById('panelSubtemas') as HTMLElement;
const btnVolver        = document.getElementById('btnVolver')!;
const btnToggleLista   = document.getElementById('btnToggleLista')!;
const leccionTit       = document.getElementById('leccionTitulo')!;
const leccionDesc      = document.getElementById('leccionDescripcion')!;
const videoPlayer      = document.getElementById('videoPlayer') as HTMLVideoElement;
const videoPlaceholder = document.getElementById('videoPlaceholder')!;
const videoBox         = videoPlaceholder.closest('.video-box') as HTMLElement;
const videoTitulo      = document.getElementById('videoTitulo')!;
const vdoWrapper        = document.getElementById('vdoWrapper')         as HTMLElement;
const vdoContainer      = document.getElementById('vdoPlayerContainer') as HTMLElement;
const vdoProcesando     = document.getElementById('vdoProcesando')      as HTMLElement;
const materialesLista  = document.getElementById('materialesLista')!;
const videoPlaylist    = document.getElementById('videoPlaylist') as HTMLElement;
const panelIntro       = document.getElementById('panelIntro')!;
const panelContenido   = document.getElementById('panelContenido')!;
const introDesc        = document.getElementById('introDescripcion')!;
const introTemaLista   = document.getElementById('introTemaLista')!;
const introCursoTitulo = document.getElementById('introCursoTitulo')!;
const introStats       = document.getElementById('introStats')!;

let todosCursos: any[] = [];
let visitedIds: Set<number>        = new Set();
let watchedMaterials: Set<number>  = new Set();
const PALETA = ['#b5d8cc','#b5c8e8','#d4c8e8','#e8d4b5','#e8c8b5','#c8e8b5'];
function colorCurso(c: any) { return c.color || c.pack_color || PALETA[Number(c.id) % PALETA.length]; }
function stripHtml(html: string, maxLen = 110): string {
  const tmp = document.createElement('div');
  tmp.innerHTML = html;
  const text = (tmp.textContent || '').replace(/\s+/g, ' ').trim();
  return text.length > maxLen ? text.slice(0, maxLen) + '…' : text;
}

// Sanitiza el HTML de descripciones: lista blanca estricta de tags y atributos.
// Ningún style ni class puede escaparse al layout global.
function normalizarRte(html: string): string {
  if (!html?.trim()) return '';
  const tmp = document.createElement('div');
  tmp.innerHTML = html;

  // Tags que se eliminan con todo su contenido
  const BORRAR = new Set(['script', 'style', 'iframe', 'object', 'embed', 'noscript', 'form', 'input', 'button']);
  // Tags permitidos → atributos seguros que pueden conservar
  const SAFE: Record<string, string[]> = {
    p: [], strong: [], em: [], u: [], s: [], br: [],
    ul: [], ol: [], li: [],
    h2: [], h3: [], h4: [],
    blockquote: [],
    a: ['href'],
  };

  function limpiar(el: Element): void {
    // Post-order: sanear hijos antes que el padre
    Array.from(el.children).forEach(limpiar);

    const tag = el.tagName.toLowerCase();

    if (BORRAR.has(tag)) { el.remove(); return; }

    if (tag in SAFE) {
      // Quitar todos los atributos no permitidos (style, class, onclick, data-*, etc.)
      Array.from(el.attributes).forEach(attr => {
        if (!SAFE[tag].includes(attr.name)) el.removeAttribute(attr.name);
      });
      // Evitar href javascript: o data:
      if (tag === 'a') {
        const href = (el.getAttribute('href') || '').trim();
        if (/^javascript:/i.test(href) || /^data:/i.test(href)) el.removeAttribute('href');
      }
    } else {
      // Tag no permitido (div, span, font, b, i, table, img…): desenvolver, sus hijos ya están limpios
      el.replaceWith(...Array.from(el.childNodes));
    }
  }

  Array.from(tmp.children).forEach(limpiar);

  // Eliminar elementos de bloque vacíos
  tmp.querySelectorAll('p, h2, h3, h4, li, blockquote').forEach(el => {
    if (!el.textContent?.trim() && !el.querySelector('br')) el.remove();
  });

  // Normalizar &nbsp; → espacio en nodos de texto
  const walk = (node: Node) => {
    if (node.nodeType === Node.TEXT_NODE) {
      node.textContent = (node.textContent || '').replace(/ /g, ' ');
    } else {
      node.childNodes.forEach(walk);
    }
  };
  walk(tmp);

  // Quitar <br> sueltos al inicio y al final
  while (tmp.firstChild instanceof HTMLBRElement) tmp.firstChild.remove();
  while (tmp.lastChild  instanceof HTMLBRElement) tmp.lastChild.remove();

  return tmp.innerHTML;
}

// Fade-in de un panel: pone display:flex y anima opacidad 0→1 en 150ms
function fadeInPanel(el: HTMLElement) {
  el.style.display = 'flex';
  el.style.opacity = '0';
  requestAnimationFrame(() => requestAnimationFrame(() => {
    el.style.transition = 'opacity 0.15s ease';
    el.style.opacity    = '1';
    setTimeout(() => { el.style.transition = ''; }, 160);
  }));
}

// ── Cargar cursos desde la BD ─────────────────────────────────
const sesion = JSON.parse(sessionStorage.getItem('umme_session') || '{}');

// Marca de agua repetida con email del alumno (patrón sobre todo el video)
const marcaAgua = document.getElementById('videoMarcaAgua') as HTMLElement;
if (marcaAgua && sesion.email) {
  const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="280" height="120">
    <text x="50%" y="55%" font-size="13" fill="rgba(255,255,255,0.13)"
      text-anchor="middle" dominant-baseline="middle"
      transform="rotate(-22, 140, 60)" font-family="sans-serif" font-weight="600">
      ${sesion.email}
    </text>
  </svg>`;
  const url = 'data:image/svg+xml,' + encodeURIComponent(svg);
  marcaAgua.style.backgroundImage = `url("${url}")`;
  marcaAgua.style.backgroundRepeat = 'repeat';
  marcaAgua.style.backgroundSize = '280px 120px';
}

// Bloquear clic derecho y arrastre en el video
videoPlayer.addEventListener('contextmenu', e => e.preventDefault());
videoPlayer.addEventListener('dragstart', e => e.preventDefault());

// Mostrar duración real del vídeo en el sidebar cuando carga
function actualizarDurSidebar() {
  const dur = videoPlayer.duration;
  if (!isFinite(dur) || dur <= 0) return;
  const totalSec = Math.round(dur);
  const h    = Math.floor(totalSec / 3600);
  const mins = Math.floor((totalSec % 3600) / 60);
  const secs = totalSec % 60;
  const durStr = h > 0
    ? `${h}h ${mins}min`
    : secs > 0 ? `${mins}min ${secs}s` : `${mins} min`;
  const activoBtn = listaTemas.querySelector('.tema-btn.activo');
  if (!activoBtn) return;
  let durSpan = activoBtn.querySelector('.tema-dur') as HTMLElement | null;
  if (!durSpan) {
    durSpan = document.createElement('span');
    durSpan.className = 'tema-dur';
    activoBtn.querySelector('.tema-info')!.appendChild(durSpan);
  }
  durSpan.textContent = durStr;
}
videoPlayer.addEventListener('loadedmetadata', actualizarDurSidebar);
videoPlayer.addEventListener('durationchange',  actualizarDurSidebar);

// Registrar progreso cuando el video termina
let temaActualId: number | null    = null;
let materialActualId: number | null = null;
let cursoActivo: any = null;

function marcarIconoTemaBtn(btn: HTMLElement, estado: 'completado' | 'parcial' | 'normal') {
  btn.classList.remove('completado', 'parcial');
  if (estado !== 'normal') btn.classList.add(estado);
  const svg = btn.querySelector('svg');
  if (!svg) return;
  const circle = svg.querySelector('circle');
  if (!circle) return;
  // Eliminar icono interior anterior
  svg.querySelectorAll('polygon, line, path[d*="M5 8"], path[d*="M8 5"]').forEach(el => el.remove());
  if (estado === 'completado') {
    const check = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    check.setAttribute('d', 'M5 8l2 2 4-4');
    check.setAttribute('stroke', 'currentColor');
    check.setAttribute('stroke-width', '1.5');
    check.setAttribute('stroke-linecap', 'round');
    check.setAttribute('stroke-linejoin', 'round');
    svg.appendChild(check);
  } else if (estado === 'parcial') {
    const dash = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    dash.setAttribute('d', 'M5 8h6');
    dash.setAttribute('stroke', 'currentColor');
    dash.setAttribute('stroke-width', '1.5');
    dash.setAttribute('stroke-linecap', 'round');
    svg.appendChild(dash);
  } else {
    const play = document.createElementNS('http://www.w3.org/2000/svg', 'polygon');
    play.setAttribute('points', '6.5,5 11.5,8 6.5,11');
    play.setAttribute('fill', 'currentColor');
    svg.appendChild(play);
  }
}

function actualizarProgresoUI(temaCompletado = false) {
  if (!cursoActivo) return;
  const temas = cursoActivo.temas ?? [];

  // Progreso por vídeos (gradual)
  const todosVideos = temas.flatMap((t: any) =>
    (t.materiales ?? []).filter((m: any) => m.tipo === 'video').map((m: any) => Number(m.id))
  );
  const totalVideos   = todosVideos.length;
  const watchedVideos = todosVideos.filter((id: number) => watchedMaterials.has(id)).length;
  const pct = totalVideos > 0 ? Math.round(watchedVideos / totalVideos * 100) : 0;
  const color = colorCurso(cursoActivo);

  // "X temas completados" — sigue contando temas completados al 100%
  const completados = temas.filter((t: any) => visitedIds.has(Number(t.id))).length;

  // Panel de detalle
  document.getElementById('temasCompletados')!.textContent = String(completados);
  const fillEl = document.getElementById('progresoFill');
  const pctEl  = document.getElementById('progresoPct');
  if (fillEl) fillEl.style.width = pct + '%';
  if (pctEl)  pctEl.textContent  = pct + '%';

  // Tarjeta en la lista de cursos
  const article = document.querySelector<HTMLElement>(`.curso[data-curso-id="${cursoActivo.id}"]`);
  if (article) {
    const fill    = article.querySelector<HTMLElement>('.curso-prog-fill');
    const pctSpan = article.querySelector<HTMLElement>('.curso-pct-span');
    if (fill)    fill.style.width = pct + '%';
    if (pctSpan) {
      pctSpan.textContent      = pct + '%';
      pctSpan.style.color      = pct === 100 ? '#1d7a52' : pct > 0 ? color : '#b5bfbb';
      pctSpan.style.fontWeight = pct > 0 ? '600' : '400';
    }
  }

  // Actualizar icono del tema activo en el sidebar
  const temaBtn = listaTemas.querySelector<HTMLElement>('.tema-btn.activo');
  if (temaBtn && temaActualId) {
    const tema = temas.find((t: any) => Number(t.id) === temaActualId);
    if (tema) {
      const videoIds = (tema.materiales ?? [])
        .filter((m: any) => m.tipo === 'video')
        .map((m: any) => Number(m.id));
      const vistosDelTema = videoIds.filter((id: number) => watchedMaterials.has(id)).length;
      if (temaCompletado || visitedIds.has(temaActualId)) {
        marcarIconoTemaBtn(temaBtn, 'completado');
      } else if (vistosDelTema > 0) {
        marcarIconoTemaBtn(temaBtn, 'parcial');
      }
    }
  }
}

function marcarPlaylistItemVisto(materialId: number) {
  const btn = videoPlaylist.querySelector<HTMLElement>(`.video-playlist-item[data-material-id="${materialId}"]`);
  if (!btn || btn.classList.contains('visto')) return;
  btn.classList.add('visto');
  const svg = btn.querySelector('svg');
  if (svg) svg.innerHTML = '<circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.3"/><path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>';
}

function registrarVideoVisto() {
  if (!sesion.userId || !temaActualId || !materialActualId) return;
  watchedMaterials.add(materialActualId);
  marcarPlaylistItemVisto(materialActualId);
  fetch('/api/progreso.php', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'X-Token': sesion.token || '' },
    body: JSON.stringify({ usuario_id: sesion.userId, material_id: materialActualId, tema_id: temaActualId }),
  }).then(r => r.json()).then(data => {
    if (!data.ok) return;
    if (data.tema_completado) visitedIds.add(temaActualId!);
    actualizarProgresoUI(data.tema_completado);
  }).catch(() => {});
}

videoPlayer.addEventListener('ended', registrarVideoVisto);

// VdoCipher postMessage cuando termina el vídeo DRM
window.addEventListener('message', (e) => {
  if (!String(e.origin).includes('vdocipher.com')) return;
  try {
    const msg = typeof e.data === 'string' ? JSON.parse(e.data) : e.data;
    const tipo = msg?.event ?? msg?.videoEvent?.type ?? msg?.eventType ?? '';
    if (tipo === 'ended' || tipo === 'video:ended') registrarVideoVisto();
  } catch {}
});

async function cargarCursos() {
  try {
    const authHeaders = { 'X-Token': sesion.token || '' };
    const [resCursos, resProgreso] = await Promise.all([
      fetch(`/api/mis-cursos.php?usuario_id=${sesion.userId}`, { headers: authHeaders }),
      fetch(`/api/progreso.php?usuario_id=${sesion.userId}`,   { headers: authHeaders }),
    ]);
    const data     = await resCursos.json();
    const dataProg = await resProgreso.json();

    if (dataProg.ok) {
      visitedIds       = new Set((dataProg.vistos as number[]).map(Number));
      watchedMaterials = new Set((dataProg.materiales_vistos as number[]).map(Number));
    }

    if (!data.ok) {
      listaCursos.innerHTML = window.htmlEstadoVacio({
        icono: '<svg viewBox="0 0 48 48" fill="none" width="48" height="48" aria-hidden="true"><circle cx="24" cy="24" r="20" stroke="#c8dcd3" stroke-width="2"/><path d="M24 16v8l5 3" stroke="#c8dcd3" stroke-width="2" stroke-linecap="round"/></svg>',
        titulo: 'No se pudieron cargar los cursos',
        sub:    'Comprueba tu conexión y recarga la página',
      });
      return;
    }

    todosCursos = data.cursos;

    if (todosCursos.length === 0) {
      listaCursos.innerHTML = window.htmlEstadoVacio({
        icono: '<svg viewBox="0 0 48 48" fill="none" width="48" height="48" aria-hidden="true"><circle cx="24" cy="24" r="20" stroke="#c8dcd3" stroke-width="2"/><path d="M15 18h18M15 24h18M15 30h11" stroke="#c8dcd3" stroke-width="2" stroke-linecap="round"/></svg>',
        titulo: 'Aún no tienes cursos',
        sub:    'Tu administrador te asignará los cursos en breve',
      });
      return;
    }

    descCursos.textContent = `${todosCursos.length} curso${todosCursos.length !== 1 ? 's' : ''} disponible${todosCursos.length !== 1 ? 's' : ''}`;

    // Filtros dinámicos según etiquetas
    const etiquetas = [...new Set(todosCursos.map((c: any) => c.etiqueta))] as string[];
    etiquetas.forEach(etiqueta => {
      const btn = document.createElement('button');
      btn.className          = 'filtro';
      btn.dataset.filtro     = etiqueta;
      btn.textContent        = etiqueta;
      filtrosWrap.appendChild(btn);
    });

    renderCursos(todosCursos);
    setupFiltros();
  } catch {
    listaCursos.innerHTML = window.htmlEstadoVacio({
      icono: '<svg viewBox="0 0 48 48" fill="none" width="48" height="48" aria-hidden="true"><circle cx="24" cy="24" r="20" stroke="#c8dcd3" stroke-width="2"/><path d="M24 16v8l5 3" stroke="#c8dcd3" stroke-width="2" stroke-linecap="round"/></svg>',
      titulo: 'No se pudieron cargar los cursos',
      sub:    'Comprueba tu conexión y recarga la página',
    });
  }
}

// ── Renderizar tarjetas agrupadas por pack/etiqueta ──────────
function renderCursos(cursos: any[]) {
  listaCursos.innerHTML = '';

  // Agrupar por etiqueta
  const grupos = new Map<string, any[]>();
  cursos.forEach((curso: any) => {
    const key = curso.etiqueta || 'Sin categoría';
    if (!grupos.has(key)) grupos.set(key, []);
    grupos.get(key)!.push(curso);
  });

  grupos.forEach((listaCursosPack, etiqueta) => {
    const section = document.createElement('section');
    section.className = 'pack-grupo';

    const header = document.createElement('button');
    header.className = 'pack-header';
    header.innerHTML = `
      <span class="pack-nombre">${etiqueta}</span>
      <span class="pack-badge">${listaCursosPack.length} curso${listaCursosPack.length !== 1 ? 's' : ''}</span>
      <svg class="pack-chevron" viewBox="0 0 16 16" fill="none" width="14" height="14">
        <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    `;

    const packBody = document.createElement('div');
    packBody.className = 'pack-cursos expandido';
    header.classList.add('abierto');

    listaCursosPack.forEach((curso: any) => {
      const numTemas = curso.temas?.length ?? 0;
      const durTotal = calcularDuracionTotal(curso.temas ?? [], curso.duracion_seg);

      const completados = (curso.temas ?? []).filter((t: any) => visitedIds.has(Number(t.id))).length;
      const todosVids = (curso.temas ?? []).flatMap((t: any) => (t.materiales ?? []).filter((m: any) => m.tipo === 'video').map((m: any) => Number(m.id)));
      const watchedVids = todosVids.filter((id: number) => watchedMaterials.has(id)).length;
      const pct = todosVids.length > 0 ? Math.round(watchedVids / todosVids.length * 100) : 0;
      const color = colorCurso(curso);

      const article = document.createElement('article');
      article.className = 'curso';
      article.dataset.cursoId = String(curso.id);
      article.innerHTML = `
        ${curso.imagen ? `<div class="curso-fila-img"><img src="${curso.imagen}" alt="" /></div>` : ''}
        <button class="curso-fila">
          ${!curso.imagen ? `<div class="curso-acento" style="background:${color}"></div>` : ''}
          <div class="curso-info">
            <h2>${curso.titulo}</h2>
            ${curso.descripcion?.trim() ? `<p class="curso-desc-preview">${stripHtml(curso.descripcion.trim())}</p>` : ''}
            <div class="curso-meta">
              <span>${numTemas} tema${numTemas !== 1 ? 's' : ''}</span>
              ${durTotal ? `<span>·</span><span>${durTotal}</span>` : ''}
              ${numTemas > 0 ? `<span>·</span><span class="curso-pct-span" style="color:${pct === 100 ? '#1d7a52' : pct > 0 ? color : '#b5bfbb'}; font-weight:${pct > 0 ? 600 : 400}">${pct}%</span>` : ''}
            </div>
          </div>
          <svg class="chevron-fila" viewBox="0 0 16 16" fill="none">
            <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        ${numTemas > 0 ? `<div class="curso-prog-bar"><div class="curso-prog-fill" style="width:${pct}%; background:${color}"></div></div>` : ''}
      `;
      article.addEventListener('click', () => abrirCurso(curso, article));
      packBody.appendChild(article);
    });

    header.addEventListener('click', () => {
      const expandido = packBody.classList.toggle('expandido');
      header.classList.toggle('abierto', expandido);
    });

    section.appendChild(header);
    section.appendChild(packBody);
    listaCursos.appendChild(section);
  });
}

// ── Formato humano de una duración en segundos ───────────────
// Redondea al minuto más cercano y devuelve "2h 5min" / "45 min" /
// "" para 0 segundos. Es la fuente única de verdad de cómo se
// presenta una duración al alumno.
function formatearDuracion(segundos: number): string {
  if (!segundos || segundos <= 0) return '';
  const mins = Math.round(segundos / 60);
  if (mins <= 0) return '';
  const h = Math.floor(mins / 60);
  const m = mins % 60;
  return h > 0 ? (m > 0 ? `${h}h ${m}min` : `${h}h`) : `${m} min`;
}

// ── Duración total del curso ─────────────────────────────────
// 1º: si la API trae curso.duracion_seg (calculada en BD a partir
//     de los vídeos), úsala — es exacta.
// 2º: si no, sumar duracion_seg de cada tema.
// 3º: por compatibilidad con cursos antiguos sin vídeos
//     instrumentados, si no hay segundos pero los temas tienen
//     t.duracion textual, sumar los minutos parseados.
function calcularDuracionTotal(temas: any[], cursoSeg?: number): string {
  if (cursoSeg && cursoSeg > 0) return formatearDuracion(cursoSeg);
  let totalSeg = 0;
  let totalMinFallback = 0;
  for (const t of temas) {
    if (typeof t.duracion_seg === 'number' && t.duracion_seg > 0) {
      totalSeg += t.duracion_seg;
    } else {
      const n = parseInt(t.duracion);
      if (!isNaN(n)) totalMinFallback += n;
    }
  }
  if (totalSeg > 0) return formatearDuracion(totalSeg + totalMinFallback * 60);
  if (totalMinFallback > 0) return formatearDuracion(totalMinFallback * 60);
  return '';
}

// Duración a mostrar para un tema concreto: prefiere los segundos
// reales si existen, si no cae al texto manual t.duracion.
function duracionTemaTexto(t: any): string {
  if (typeof t.duracion_seg === 'number' && t.duracion_seg > 0) {
    return formatearDuracion(t.duracion_seg);
  }
  return t.duracion ? `${t.duracion} min` : '';
}

// ── Abrir panel de detalle ────────────────────────────────────
function abrirCurso(curso: any, articleEl: HTMLElement) {
  cursoActivo = curso;
  const totalTemas = curso.temas?.length ?? 0;
  const completadosTemas = (curso.temas ?? []).filter((t: any) => visitedIds.has(Number(t.id))).length;
  const todosVidsDetalle = (curso.temas ?? []).flatMap((t: any) => (t.materiales ?? []).filter((m: any) => m.tipo === 'video').map((m: any) => Number(m.id)));
  const watchedVidsDetalle = todosVidsDetalle.filter((id: number) => watchedMaterials.has(id)).length;
  const pctDetalle = todosVidsDetalle.length > 0 ? Math.round(watchedVidsDetalle / todosVidsDetalle.length * 100) : 0;

  detalleTit.textContent = curso.titulo;
  document.getElementById('temasTotal')!.textContent       = String(totalTemas);
  document.getElementById('temasCompletados')!.textContent = String(completadosTemas);
  const fillEl = document.getElementById('progresoFill');
  const pctEl  = document.getElementById('progresoPct');
  if (fillEl) fillEl.style.width = pctDetalle + '%';
  if (pctEl)  pctEl.textContent  = pctDetalle + '%';

  // Color del curso para CSS custom property
  const color = colorCurso(curso);
  document.getElementById('colDetalle')!.style.setProperty('--curso-color', color);

  // ── Lista de temas en sidebar ────────────────────────────
  listaTemas.innerHTML = '';

  // Botón "Presentación" al inicio del sidebar para volver a la intro del curso
  const liPresentacion = document.createElement('li');
  liPresentacion.className = 'tema-item tema-item-presentacion';
  liPresentacion.innerHTML = `
    <button class="tema-btn tema-btn-presentacion activo">
      <span class="tema-icono" style="--curso-color:${color}">
        <svg viewBox="0 0 16 16" fill="none" width="14" height="14" style="display:block">
          <path d="M2 7L8 2l6 5v7a1 1 0 01-1 1H3a1 1 0 01-1-1V7z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
          <path d="M6 15V9h4v6" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/>
        </svg>
      </span>
      <span class="tema-info">
        <span class="tema-texto">Presentación</span>
      </span>
    </button>
  `;
  const btnPresentacion = liPresentacion.querySelector<HTMLButtonElement>('.tema-btn')!;
  btnPresentacion.addEventListener('click', () => {
    listaTemas.querySelectorAll('.tema-btn').forEach(b => b.classList.remove('activo'));
    btnPresentacion.classList.add('activo');
    panelSubtemas.style.flex     = '0 0 0';
    panelSubtemas.style.opacity  = '0';
    panelContenido.style.display = 'none';
    fadeInPanel(panelIntro);
    ocultarReproductores();
    temaActualId = null;
  });
  listaTemas.appendChild(liPresentacion);

  (curso.temas ?? []).forEach((tema: any, idx: number) => {
    const li = document.createElement('li');
    li.className = 'tema-item';
    const tieneVideo = tema.materiales?.some((m: any) => m.tipo === 'video');
    const yaVisto = visitedIds.has(Number(tema.id));
    const videoIds = (tema.materiales ?? []).filter((m: any) => m.tipo === 'video').map((m: any) => Number(m.id));
    const vistosDelTema = videoIds.filter((id: number) => watchedMaterials.has(id)).length;
    const esParcial = !yaVisto && vistosDelTema > 0;
    li.innerHTML = `
      <button class="tema-btn">
        <span class="tema-icono" style="--curso-color:${color}">
          <svg viewBox="0 0 16 16" fill="none" width="14" height="14" style="display:block">
            <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.3"/>
            ${yaVisto
              ? '<path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>'
              : esParcial
                ? '<path d="M5 8h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>'
                : tieneVideo
                  ? '<polygon points="6.5,5 11.5,8 6.5,11" fill="currentColor"/>'
                  : '<line x1="5" y1="8" x2="11" y2="8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>'}
          </svg>
        </span>
        <span class="tema-info">
          <span class="tema-texto">${idx + 1}. ${tema.titulo}</span>
          ${(() => { const d = duracionTemaTexto(tema); return d ? `<span class="tema-dur">${d}</span>` : ''; })()}
        </span>
      </button>
    `;
    const btn = li.querySelector('.tema-btn')!;
    if (yaVisto) btn.classList.add('completado');
    else if (esParcial) btn.classList.add('parcial');
    btn.addEventListener('click', () => seleccionarTema(tema, li));
    listaTemas.appendChild(li);
  });

  // ── Panel intro: título, imagen, descripción, stats e índice ──
  introCursoTitulo.textContent = curso.titulo;

  const introImgWrap = document.getElementById('introCursoBanner') as HTMLElement;
  if (curso.imagen) {
    (introImgWrap.querySelector('img') as HTMLImageElement).src = curso.imagen;
    introImgWrap.style.display = '';
  } else {
    introImgWrap.style.display = 'none';
  }

  const descTexto = normalizarRte(curso.descripcion || '');
  introDesc.innerHTML = descTexto;
  introDesc.style.display = descTexto ? '' : 'none';

  // Stats: nº temas + duración total
  const numTemas  = (curso.temas ?? []).length;
  const durTotal  = calcularDuracionTotal(curso.temas ?? [], curso.duracion_seg);
  introStats.innerHTML = `
    <span class="intro-stat">
      <svg viewBox="0 0 16 16" fill="none" width="14" height="14"><rect x="2" y="3" width="12" height="10" rx="1.5" stroke="currentColor" stroke-width="1.4"/><path d="M5 6h6M5 9h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
      ${numTemas} tema${numTemas !== 1 ? 's' : ''}
    </span>
    ${durTotal ? `<span class="intro-stat">
      <svg viewBox="0 0 16 16" fill="none" width="14" height="14"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.4"/><path d="M8 5v3l2 2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
      ${durTotal}
    </span>` : ''}
  `;

  introTemaLista.innerHTML = '';
  (curso.temas ?? []).forEach((tema: any, idx: number) => {
    const li  = document.createElement('li');
    const btn = document.createElement('button');
    btn.className = 'intro-tema-item';
    const tieneVideo = tema.materiales?.some((m: any) => m.tipo === 'video');
    const dur = duracionTemaTexto(tema);
    btn.innerHTML = `
      <span class="intro-tema-icono">
        ${tieneVideo
          ? `<svg viewBox="0 0 16 16" fill="none" width="15" height="15"><polygon points="5,3 13,8 5,13" fill="currentColor"/></svg>`
          : `<svg viewBox="0 0 16 16" fill="none" width="15" height="15"><path d="M4 2h6l4 4v8a1 1 0 01-1 1H4a1 1 0 01-1-1V3a1 1 0 011-1z" stroke="currentColor" stroke-width="1.4"/><path d="M10 2v4h4" stroke="currentColor" stroke-width="1.4"/></svg>`
        }
      </span>
      <span class="intro-tema-info">
        <span class="intro-tema-titulo">${idx + 1}. ${tema.titulo}</span>
        ${tema.descripcion?.trim() ? `<span class="intro-tema-desc">${stripHtml(tema.descripcion.trim(), 120)}</span>` : ''}
      </span>
      ${dur ? `<span class="intro-tema-dur">${dur}</span>` : ''}
    `;
    btn.addEventListener('click', () => {
      const liSidebar = listaTemas.querySelectorAll<HTMLElement>('.tema-item:not(.tema-item-presentacion)')[idx];
      if (liSidebar) liSidebar.querySelector<HTMLButtonElement>('.tema-btn')!.click();
    });
    li.appendChild(btn);
    introTemaLista.appendChild(li);
  });

  // Mostrar intro, ocultar sidebar y tabs/video
  panelSubtemas.style.flex    = '0 0 0';
  panelSubtemas.style.opacity = '0';
  panelContenido.style.display = 'none';
  fadeInPanel(panelIntro);

  document.querySelectorAll('.curso').forEach(c => c.classList.remove('activo'));
  articleEl.classList.add('activo');
  vista.classList.add('con-detalle');
}

// ── Ocultar todos los reproductores ──────────────────────────
function ocultarReproductores() {
  videoPlayer.pause();
  videoPlayer.src             = '';
  videoPlayer.style.display   = 'none';
  vdoWrapper.style.display    = 'none';
  vdoContainer.innerHTML      = '';
  vdoProcesando.style.display = 'none';
}

// ── Reproducir un material de vídeo concreto ─────────────────
async function reproducirVideo(videoMat: any) {
  materialActualId = videoMat.id ?? null;
  ocultarReproductores();
  if (videoMat.vdocipher_video_id) {
    // Vídeo VdoCipher DRM (Widevine + FairPlay)
    if (videoMat.vdo_status === 'ready') {
      const res = await fetch(
        `/api/vdocipher-otp.php?material_id=${videoMat.id}&usuario_id=${sesion.userId}&token=${encodeURIComponent(sesion.token || '')}`
      );
      const data = await res.json();
      if (data.ok) {
        vdoWrapper.style.display = 'block';
        vdoContainer.innerHTML   = '';
        const vdoEl = document.createElement('vdocipher-player');
        vdoEl.setAttribute('otp',          data.otp);
        vdoEl.setAttribute('playbackInfo', data.playbackInfo);
        if (data.player) vdoEl.setAttribute('player', data.player);
        vdoEl.style.cssText = 'width:100%;height:100%;display:block;';
        vdoContainer.appendChild(vdoEl);
      }
    } else {
      vdoProcesando.style.display = 'block';
    }
  } else {
    // Vídeo local
    videoPlayer.src           = `/api/video.php?material_id=${videoMat.id}&usuario_id=${sesion.userId}&token=${encodeURIComponent(sesion.token || '')}`;
    videoPlayer.style.display = 'block';
  }
}

// ── Seleccionar tema: reproducir vídeo + materiales ───────────
async function seleccionarTema(tema: any, liEl: HTMLElement) {
  // Pasar de intro a panel de contenido (mostrar sidebar)
  panelSubtemas.style.flex    = '0 0 250px';
  panelSubtemas.style.opacity = '1';
  panelIntro.style.display    = 'none';
  fadeInPanel(panelContenido);

  listaTemas.querySelectorAll('.tema-btn').forEach(b => b.classList.remove('activo'));
  liEl.querySelector('.tema-btn')!.classList.add('activo');
  leccionTit.textContent  = tema.titulo;
  leccionDesc.innerHTML = normalizarRte(tema.descripcion || '');
  temaActualId = tema.id ?? null;

  const videosMat = (tema.materiales ?? []).filter((m: any) => m.tipo === 'video');
  if (videosMat.length > 0) {
    videoBox.style.display         = '';
    videoPlaceholder.style.display = 'none';

    if (videosMat.length > 1) {
      videoPlaylist.style.display = '';
      videoPlaylist.innerHTML = '';
      videosMat.forEach((mat: any, idx: number) => {
        const nombre = mat.nombre.replace(/\.[^.]+$/, '');
        const visto  = watchedMaterials.has(Number(mat.id));
        const btn = document.createElement('button');
        btn.className = 'video-playlist-item' + (idx === 0 ? ' activo' : '') + (visto ? ' visto' : '');
        btn.dataset.materialId = String(mat.id);
        btn.innerHTML = `
          <svg viewBox="0 0 16 16" fill="none" width="13" height="13">
            ${visto
              ? '<circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.3"/><path d="M5 8l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>'
              : '<polygon points="4,3 13,8 4,13" fill="currentColor"/>'}
          </svg>
          <span>${idx + 1}. ${nombre}</span>
        `;
        btn.addEventListener('click', () => {
          videoPlaylist.querySelectorAll('.video-playlist-item').forEach(b => b.classList.remove('activo'));
          btn.classList.add('activo');
          reproducirVideo(mat);
        });
        videoPlaylist.appendChild(btn);
      });
    } else {
      videoPlaylist.style.display = 'none';
    }

    reproducirVideo(videosMat[0]);
  } else {
    ocultarReproductores();
    videoBox.style.display         = 'none';
    videoPlaylist.style.display    = 'none';
    videoPlaceholder.style.display = 'flex';
    videoTitulo.textContent        = 'Sin vídeo en este tema';
  }

  const docs = (tema.materiales ?? []).filter((m: any) => m.tipo === 'documento');
  materialesLista.innerHTML = '';

  if (docs.length === 0) {
    materialesLista.innerHTML = '<p style="font-size:0.85rem; color:#aaa; padding:0.5rem 0;">No hay materiales en este tema.</p>';
  } else {
    docs.forEach((mat: any) => {
      const kb  = mat.tamano_kb > 1024 ? `${(mat.tamano_kb / 1024).toFixed(1)} MB` : `${mat.tamano_kb} KB`;
      const ext = mat.nombre.split('.').pop()?.toUpperCase() ?? 'DOC';
      const a   = document.createElement('a');
      a.className = 'material-item';
      a.href      = mat.ruta;
      a.target    = '_blank';
      a.rel       = 'noopener';
      a.innerHTML = `
        <svg viewBox="0 0 20 20" fill="none">
          <path d="M5 3h8l4 4v10a1 1 0 01-1 1H5a1 1 0 01-1-1V4a1 1 0 011-1z" stroke="currentColor" stroke-width="1.4"/>
          <path d="M13 3v4h4" stroke="currentColor" stroke-width="1.4"/>
        </svg>
        <div>
          <p class="material-nombre">${mat.nombre}</p>
          <p class="material-meta">${ext} · ${kb}</p>
        </div>
      `;
      materialesLista.appendChild(a);
    });
  }
}

// ── Toggle panel izquierdo ────────────────────────────────────
btnToggleLista.addEventListener('click', () => {
  vista.classList.toggle('lista-oculta');
  const oculta = vista.classList.contains('lista-oculta');
  btnToggleLista.title = oculta ? 'Mostrar panel de cursos' : 'Ocultar panel de cursos';
});

// ── Cerrar panel ──────────────────────────────────────────────
btnVolver.addEventListener('click', () => {
  vista.classList.remove('con-detalle', 'lista-oculta');
  document.querySelectorAll('.curso').forEach(c => c.classList.remove('activo'));
  ocultarReproductores();
  videoPlaceholder.style.display = 'flex';
  videoTitulo.textContent        = 'Selecciona un tema';
  panelSubtemas.style.flex    = '0 0 0';
  panelSubtemas.style.opacity = '0';
  panelIntro.style.display       = 'none';
  panelContenido.style.display   = 'none';
});

// ── Filtros ───────────────────────────────────────────────────
function setupFiltros() {
  filtrosWrap.querySelectorAll('.filtro').forEach(btn => {
    btn.addEventListener('click', () => {
      filtrosWrap.querySelectorAll('.filtro').forEach(b => b.classList.remove('activo'));
      btn.classList.add('activo');
      const filtro = (btn as HTMLElement).dataset.filtro;
      renderCursos(filtro === 'todos' ? todosCursos : todosCursos.filter((c: any) => c.etiqueta === filtro));
    });
  });
}

// ── Tabs ──────────────────────────────────────────────────────
document.querySelectorAll<HTMLButtonElement>('.tab').forEach(tab => {
  tab.addEventListener('click', () => {
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('activo'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('activo'));
    tab.classList.add('activo');
    document.getElementById(`tab-${tab.dataset.tab}`)!.classList.add('activo');
  });
});

cargarCursos();
</script>
