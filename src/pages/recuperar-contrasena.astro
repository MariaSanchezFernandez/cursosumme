---
/**
 * PÁGINA: Recuperar contraseña
 * ----------------------------
 * Formulario para que el usuario introduzca y repita su nueva contraseña.
 *
 * ESTADO ACTUAL: Solo visual. Sin lógica ni validación.
 * PENDIENTE:     Conectar con sistema de autenticación y recuperación
 *                cuando esté definida la arquitectura de backend.
 */
import Plantilla from '../layouts/Plantilla.astro';
import FondoLogin from '../components/FondoLogin.astro';
import CampoFormulario from '../components/CampoFormulario.astro';
import Boton from '../components/Boton.astro';
import '../styles/recuperar-contrasena.css';
---

<Plantilla>
  <FondoLogin />

  <main class="pagina">
    <div class="tarjeta">
      <div class="cabecera">
        <h1>Nueva contraseña</h1>
        <p>Introduce tu nueva contraseña</p>
      </div>

      <form>
        <CampoFormulario
          label="Nueva contraseña"
          type="password"
          id="nueva-contrasena"
          name="nueva-contrasena"
          placeholder="••••••••"
        />
        <CampoFormulario
          label="Repite la contraseña"
          type="password"
          id="repetir-contrasena"
          name="repetir-contrasena"
          placeholder="••••••••"
        />
        <Boton text="Guardar contraseña" type="submit" />
      </form>

      <a href="/login" class="volver">← Volver al inicio de sesión</a>
    </div>
  </main>
</Plantilla>
