---
import PlantillaAdmin from '../../layouts/PlantillaAdmin.astro';
---

<PlantillaAdmin titulo="Mi perfil" paginaActual="perfil">

  <div style="max-width:560px; margin:0 auto; display:flex; flex-direction:column; gap:1.5rem;">

    <!-- Datos personales -->
    <div class="tabla-wrap">
      <div class="tabla-header">
        <span class="tabla-titulo">Datos de la cuenta</span>
      </div>
      <div style="padding:1.5rem;">
        <form id="form-datos">
          <div class="pf-campo">
            <label class="pf-label">Nombre</label>
            <input id="inp-nombre" type="text" class="pf-input" required />
          </div>
          <div class="pf-campo">
            <label class="pf-label">Apellidos</label>
            <input id="inp-apellidos" type="text" class="pf-input" required />
          </div>
          <div class="pf-campo">
            <label class="pf-label">Email</label>
            <input id="inp-email" type="email" class="pf-input" required />
          </div>
          <div id="msg-datos" style="display:none; font-size:0.82rem; margin-top:0.5rem;"></div>
          <button type="submit" class="btn-admin primario" style="margin-top:1rem;">
            Guardar cambios
          </button>
        </form>
      </div>
    </div>

    <!-- Cambiar contraseña -->
    <div class="tabla-wrap">
      <div class="tabla-header">
        <span class="tabla-titulo">Cambiar contraseña</span>
      </div>
      <div style="padding:1.5rem;">
        <form id="form-password">
          <div class="pf-campo">
            <label class="pf-label">Nueva contraseña</label>
            <div class="pf-pwd-wrap">
              <input id="inp-pwd1" type="password" class="pf-input" minlength="6" placeholder="Mínimo 6 caracteres" required />
              <button type="button" class="pf-pwd-toggle" aria-label="Mostrar contraseña" data-pwd-target="inp-pwd1">
                <svg class="icono-ojo" viewBox="0 0 20 20" fill="none" width="18" height="18" aria-hidden="true">
                  <path d="M2 10s3-5 8-5 8 5 8 5-3 5-8 5-8-5-8-5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                  <circle cx="10" cy="10" r="2.5" stroke="currentColor" stroke-width="1.5"/>
                </svg>
                <svg class="icono-ojo-tachado" viewBox="0 0 20 20" fill="none" width="18" height="18" aria-hidden="true" style="display:none;">
                  <path d="M3 3l14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <path d="M6.5 6.5C4 8 2 10 2 10s3 5 8 5c1.35 0 2.55-.35 3.6-.85M9 5.05C9.33 5.02 9.66 5 10 5c5 0 8 5 8 5s-.9 1.5-2.5 3" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
          </div>
          <div class="pf-campo">
            <label class="pf-label">Repetir contraseña</label>
            <div class="pf-pwd-wrap">
              <input id="inp-pwd2" type="password" class="pf-input" minlength="6" required />
              <button type="button" class="pf-pwd-toggle" aria-label="Mostrar contraseña" data-pwd-target="inp-pwd2">
                <svg class="icono-ojo" viewBox="0 0 20 20" fill="none" width="18" height="18" aria-hidden="true">
                  <path d="M2 10s3-5 8-5 8 5 8 5-3 5-8 5-8-5-8-5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                  <circle cx="10" cy="10" r="2.5" stroke="currentColor" stroke-width="1.5"/>
                </svg>
                <svg class="icono-ojo-tachado" viewBox="0 0 20 20" fill="none" width="18" height="18" aria-hidden="true" style="display:none;">
                  <path d="M3 3l14 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  <path d="M6.5 6.5C4 8 2 10 2 10s3 5 8 5c1.35 0 2.55-.35 3.6-.85M9 5.05C9.33 5.02 9.66 5 10 5c5 0 8 5 8 5s-.9 1.5-2.5 3" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>
          </div>
          <div id="msg-pwd" style="display:none; font-size:0.82rem; margin-top:0.5rem;"></div>
          <button type="submit" class="btn-admin primario" style="margin-top:1rem;">
            Cambiar contraseña
          </button>
        </form>
      </div>
    </div>

  </div>

</PlantillaAdmin>

<script>
const s: any = (() => { try { return JSON.parse(sessionStorage.getItem('umme_session') || '{}'); } catch { return {}; } })();

// ── Cargar datos actuales ─────────────────────────────────────
async function cargarDatos() {
  if (!s.userId) return;
  const res  = await fetch(`/api/perfil-admin.php?usuario_id=${s.userId}`);
  const data = await res.json();
  if (!data.ok) return;
  (document.getElementById('inp-nombre')    as HTMLInputElement).value = data.admin.nombre;
  (document.getElementById('inp-apellidos') as HTMLInputElement).value = data.admin.apellidos;
  (document.getElementById('inp-email')     as HTMLInputElement).value = data.admin.email;
}
cargarDatos();

// ── Toggle mostrar/ocultar contraseña ─────────────────────────
document.querySelectorAll<HTMLButtonElement>('.pf-pwd-toggle').forEach((btn) => {
  btn.addEventListener('click', () => {
    const targetId = btn.getAttribute('data-pwd-target');
    if (!targetId) return;
    const input = document.getElementById(targetId) as HTMLInputElement | null;
    if (!input) return;
    const mostrando = input.type === 'text';
    input.type = mostrando ? 'password' : 'text';
    btn.setAttribute('aria-label', mostrando ? 'Mostrar contraseña' : 'Ocultar contraseña');
    (btn.querySelector('.icono-ojo') as HTMLElement).style.display = mostrando ? '' : 'none';
    (btn.querySelector('.icono-ojo-tachado') as HTMLElement).style.display = mostrando ? 'none' : '';
  });
});

function mostrarMsg(id: string, texto: string, ok: boolean) {
  const el = document.getElementById(id)!;
  el.textContent = texto;
  el.style.color  = ok ? 'var(--color-primary)' : '#c33';
  el.style.display = 'block';
  setTimeout(() => { el.style.display = 'none'; }, 3500);
}

// ── Guardar datos ─────────────────────────────────────────────
document.getElementById('form-datos')!.addEventListener('submit', async (e) => {
  e.preventDefault();
  const nombre    = (document.getElementById('inp-nombre')    as HTMLInputElement).value.trim();
  const apellidos = (document.getElementById('inp-apellidos') as HTMLInputElement).value.trim();
  const email     = (document.getElementById('inp-email')     as HTMLInputElement).value.trim();

  const res  = await fetch('/api/perfil-admin.php', {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ usuario_id: s.userId, nombre, apellidos, email }),
  });
  const data = await res.json();
  if (data.ok) {
    // Actualizar sesión local
    const sesion = JSON.parse(sessionStorage.getItem('umme_session') || '{}');
    sesion.nombre = nombre;
    sesion.email  = email;
    sessionStorage.setItem('umme_session', JSON.stringify(sesion));
    mostrarMsg('msg-datos', 'Datos actualizados correctamente.', true);
  } else {
    mostrarMsg('msg-datos', data.error || 'Error al guardar.', false);
  }
});

// ── Cambiar contraseña ────────────────────────────────────────
document.getElementById('form-password')!.addEventListener('submit', async (e) => {
  e.preventDefault();
  const pwd1 = (document.getElementById('inp-pwd1') as HTMLInputElement).value;
  const pwd2 = (document.getElementById('inp-pwd2') as HTMLInputElement).value;

  if (pwd1 !== pwd2) {
    mostrarMsg('msg-pwd', 'Las contraseñas no coinciden.', false);
    return;
  }

  const submitBtn = (e.target as HTMLFormElement).querySelector('button[type="submit"]') as HTMLButtonElement;
  await window.botonCargando(submitBtn, 'Guardando…', async () => {
    const res  = await fetch('/api/cambiar-password.php', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ usuario_id: s.userId, password_nueva: pwd1 }),
    });
    const data = await res.json();
    mostrarMsg('msg-pwd', data.mensaje || (data.ok ? 'Contraseña actualizada.' : 'Error.'), data.ok);
    if (data.ok) {
      (document.getElementById('inp-pwd1') as HTMLInputElement).value = '';
      (document.getElementById('inp-pwd2') as HTMLInputElement).value = '';
    }
  });
});
</script>

<style>
.pf-campo {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  margin-bottom: 1rem;
}
.pf-label {
  font-size: 0.78rem;
  font-weight: 700;
  color: var(--color-text-muted);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}
.pf-input {
  padding: 0.55rem 0.75rem;
  border: 1px solid #e0ece6;
  border-radius: 8px;
  font-size: 0.88rem;
  font-family: inherit;
  color: var(--color-text);
  background: #fafcfb;
  outline: none;
  transition: border-color 0.15s;
}
.pf-input:focus {
  border-color: var(--color-primary);
}
.pf-pwd-wrap {
  position: relative;
  display: flex;
}
.pf-pwd-wrap .pf-input {
  flex: 1;
  padding-right: 2.6rem;
}
.pf-pwd-toggle {
  position: absolute;
  right: 0.4rem;
  top: 50%;
  transform: translateY(-50%);
  width: 30px;
  height: 30px;
  border: none;
  background: transparent;
  cursor: pointer;
  color: #888;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6px;
  padding: 0;
  transition: color 0.15s, background 0.15s;
}
.pf-pwd-toggle:hover {
  color: var(--color-text);
  background: rgba(0,0,0,0.04);
}
.pf-pwd-toggle:focus-visible {
  outline: 2px solid var(--color-primary);
  outline-offset: 1px;
}
</style>
