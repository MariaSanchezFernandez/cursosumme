    let descPrev = wrap.querySelector('.tema-desc-preview') as HTMLElement | null;
    if (descripcion) {
      if (!descPrev) {
        descPrev = document.createElement('span');
        descPrev.className = 'tema-desc-preview';
        wrap.appendChild(descPrev);
      }
      descPrev.textContent = descripcion;
    } else if (descPrev) {
      descPrev.remove();
    }
    card.dataset.dirty = '';
    actualizarDurDisplay();
    return true;
  }
  (card as any).guardarTema = guardarTema;

  const marcarTemaDirty = () => {
    card.dataset.dirty = '1';
    marcarDirty();
  };
  editPanel.querySelector('.input-titulo-tema')!.addEventListener('input', marcarTemaDirty);
  editPanel.querySelector('.input-dur-tema')!.addEventListener('input', marcarTemaDirty);
  (editPanel.querySelector('.input-desc-tema') as HTMLElement).addEventListener('input', marcarTemaDirty);

  editPanel.querySelector('.btn-guardar-tema')!.addEventListener('click', async () => {
