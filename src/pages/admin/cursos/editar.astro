      mostrarMsg(data.mensaje || 'Error al eliminar', 'error');
    }
  });

  // ── Upload vídeo ──────────────────────────────────────────
  const formVideo     = cuerpo.querySelector('.form-upload-video') as HTMLFormElement;
  const progresoVideo = formVideo.querySelector('.upload-progreso') as HTMLElement;
  const progresoBarra = formVideo.querySelector('.upload-progreso-fill') as HTMLElement;
  const progresoTxt   = formVideo.querySelector('.upload-progreso-txt') as HTMLElement;
  const btnSubirVideo = formVideo.querySelector('button[type="submit"]') as HTMLButtonElement;
  formVideo.addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = formVideo.querySelector('.input-video') as HTMLInputElement;
    if (!input.files?.length) return;
    const archivo = input.files[0];
    const MAX_VIDEO = 2048 * 1024 * 1024;
    if (archivo.size > MAX_VIDEO) {
      const mb = (archivo.size / 1024 / 1024).toFixed(0);
      mostrarMsg(`El vídeo pesa ${mb} MB y supera el límite de 2 GB. Comprímelo antes de subirlo.`, 'error');
      (window as any).logAppError?.('upload', `Vídeo rechazado en cliente (${mb} MB > 2 GB)`, { detalle: archivo.name + ' · tema=' + tema.id });
      input.value = '';
      return;
    }
    progresoVideo.style.display = 'flex';
    progresoBarra.style.width = '0%';
    progresoTxt.textContent = '0%';
    btnSubirVideo.disabled = true;
    await subirArchivo(cuerpo, tema, archivo, 'video', (pct) => {
      progresoBarra.style.width = pct + '%';
      progresoTxt.textContent = pct + '%';
    });
    progresoVideo.style.display = 'none';
    btnSubirVideo.disabled = false;
    input.value = '';
  });

  // ── Upload documento ──────────────────────────────────────
  const formDoc = cuerpo.querySelector('.form-upload-doc') as HTMLFormElement;
  const msgDoc  = formDoc.querySelector('.subiendo-msg') as HTMLElement;
  formDoc.addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = formDoc.querySelector('.input-doc') as HTMLInputElement;
    if (!input.files?.length) return;
    const archivo = input.files[0];
    const MAX_DOC = 100 * 1024 * 1024;
    if (archivo.size > MAX_DOC) {
      const mb = (archivo.size / 1024 / 1024).toFixed(0);
      mostrarMsg(`El archivo pesa ${mb} MB y supera el límite de 100 MB.`, 'error');
      (window as any).logAppError?.('upload', `Documento rechazado en cliente (${mb} MB > 100 MB)`, { detalle: archivo.name + ' · tema=' + tema.id });
      input.value = '';
      return;
    }
    msgDoc.style.display = 'inline';
    (formDoc.querySelector('button[type="submit"]') as HTMLButtonElement).disabled = true;
    await subirArchivo(cuerpo, tema, archivo, 'documento');
    msgDoc.style.display = 'none';
    (formDoc.querySelector('button[type="submit"]') as HTMLButtonElement).disabled = false;
    input.value = '';
  });

  return card;
}

// ── Cargar materiales de un tema ──────────────────────────────
async function cargarMateriales(card: HTMLElement, temaId: number) {
  const res  = await fetch(`/api/materiales.php?tema_id=${temaId}`);
  const data = await res.json();
  if (!data.ok) return;
  for (const mat of data.materiales) {
    const lista = card.querySelector(
      mat.tipo === 'video' ? '.mat-lista-video' : '.mat-lista-doc'
    ) as HTMLElement;
    if (lista) lista.appendChild(crearFilaMat(mat));
  }
}

function crearFilaMat(mat: any): HTMLElement {
  const kb    = mat.tamano_kb > 1024 ? `${(mat.tamano_kb/1024).toFixed(1)} MB` : `${mat.tamano_kb} KB`;
  const icono = mat.tipo === 'video'
    ? `<svg viewBox="0 0 16 16" fill="none" width="13" height="13"><rect x="1" y="2.5" width="10" height="11" rx="1.5" stroke="currentColor" stroke-width="1.3"/><path d="M11 6.5l4-1.5v6l-4-1.5V6.5z" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round"/></svg>`
    : `<svg viewBox="0 0 16 16" fill="none" width="13" height="13"><path d="M3 1.5h7l3.5 3.5V14a.5.5 0 01-.5.5H3a.5.5 0 01-.5-.5V2a.5.5 0 01.5-.5z" stroke="currentColor" stroke-width="1.3"/><path d="M10 1.5V5H13.5" stroke="currentColor" stroke-width="1.3"/></svg>`;
  const div   = document.createElement('div');
  div.className = 'mat-fila';

  function renderNormal() {
    div.innerHTML = `
      <span class="mat-icono">${icono}</span>
      <a href="${urlMaterial(mat)}" target="_blank" class="mat-nombre" title="${mat.nombre}">${mat.nombre}</a>
      <span class="mat-tam">${kb}</span>
      <button class="mat-rename" title="Renombrar" style="width:22px;height:22px;border-radius:5px;border:1px solid #e8eeec;background:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;padding:0;flex-shrink:0;">
        <svg viewBox="0 0 14 14" fill="none" width="12" height="12">
          <path d="M9.5 2.5l2 2-7 7H2.5v-2l7-7z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
        </svg>
      </button>
      <button class="mat-del" title="Eliminar">✕</button>
    `;
    div.querySelector('.mat-rename')!.addEventListener('click', renderEditar);
    div.querySelector('.mat-del')!.addEventListener('click', async () => {
      if (!confirm(`¿Eliminar "${mat.nombre}"?`)) return;
      const res  = await fetch(`/api/materiales.php?id=${mat.id}`, { method: 'DELETE' });
      const data = await res.json();
      if (data.ok) div.remove(); else mostrarMsg('Error al eliminar', 'error');
    });
  }

  function renderEditar() {
    div.innerHTML = `
      <span class="mat-icono">${icono}</span>
      <input type="text" class="mat-nombre-input form-input" value="${mat.nombre}" style="flex:1;padding:0.25rem 0.5rem;font-size:0.78rem;" />
      <button class="mat-save" style="width:28px;height:28px;border-radius:5px;border:1px solid #b6e0cc;background:#f0faf5;cursor:pointer;color:#2e7d55;font-size:0.9rem;flex-shrink:0;">✓</button>
      <button class="mat-cancelar-rename" style="width:28px;height:28px;border-radius:5px;border:1px solid #e8eeec;background:#fff;cursor:pointer;color:#888;flex-shrink:0;">✕</button>
    `;
    const input = div.querySelector('.mat-nombre-input') as HTMLInputElement;
    input.focus(); input.select();

    async function guardar() {
      const nuevoNombre = input.value.trim();
      if (!nuevoNombre) return;
      const res  = await fetch('/api/materiales.php', {
        method: 'PUT', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ id: mat.id, nombre: nuevoNombre }),
      });
      const data = await res.json();
      if (data.ok) { mat.nombre = nuevoNombre; renderNormal(); }
      else mostrarMsg('Error al renombrar', 'error');
    }
    div.querySelector('.mat-save')!.addEventListener('click', guardar);
    div.querySelector('.mat-cancelar-rename')!.addEventListener('click', renderNormal);
    input.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') guardar();
      if (e.key === 'Escape') renderNormal();
    });
  }

  renderNormal();
  return div;
}

// ── Subir archivo ─────────────────────────────────────────────
function leerDuracionVideo(archivo: File): Promise<number> {
  return new Promise(resolve => {
    const url     = URL.createObjectURL(archivo);
    const v       = document.createElement('video');
    let resuelto  = false;
    const terminar = (dur: number) => {
      if (resuelto) return;
      resuelto = true;
      URL.revokeObjectURL(url);
      resolve(dur);
    };
    v.preload          = 'metadata';
    v.onloadedmetadata = () => terminar(Math.round(v.duration) || 0);
    v.onerror          = () => terminar(0);
    v.src              = url;
    // Si el navegador no puede leer el metadata en 8s, continuar sin duración
    setTimeout(() => terminar(0), 8000);
  });
}

// Chunk de 800 MB: por debajo del límite nginx de IONOS (1024 MB) con margen
// para overhead de multipart, y reduce el número de peticiones para vídeos grandes.
const CHUNK_SIZE = 800 * 1024 * 1024;

function actualizarDuracionTrasSubida(cuerpo: HTMLElement, tema: any, durMin: number): void {
  const card      = cuerpo.closest('.tema-card') as HTMLElement;
  const editPanel = card.querySelector('.tema-editar-panel') as HTMLElement;
  const inputDur  = editPanel.querySelector('.input-dur-tema') as HTMLInputElement;
  if (!inputDur.value || inputDur.value === '0') {
    inputDur.value = String(durMin);
    const pill = card.querySelector('.tema-dur-pill') as HTMLElement;
    if (pill) { pill.textContent = durMin + ' min'; pill.style.display = ''; }
    fetch('/api/temas.php', {
      method: 'PUT', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ id: tema.id, titulo: tema.titulo, duracion: String(durMin), orden: tema.orden }),
    }).then(() => actualizarDurDisplay());
  }
}

function subirArchivoChunked(
  cuerpo: HTMLElement,
  tema: any,
  archivo: File,
  durMin: number,
  onProgress?: (pct: number) => void
): Promise<void> {
  return new Promise(async (resolve) => {
    const uploadId    = (crypto as any).randomUUID?.()?.replace(/-/g, '') ??
                        (Date.now().toString(36) + Math.random().toString(36).slice(2) + Math.random().toString(36).slice(2)).slice(0, 32);
    const totalChunks = Math.ceil(archivo.size / CHUNK_SIZE);
    const detalle     = `video · ${archivo.name} · ${(archivo.size/1024/1024).toFixed(1)} MB · tema=${tema.id} · chunks=${totalChunks}`;

    for (let i = 0; i < totalChunks; i++) {
      const inicio = i * CHUNK_SIZE;
      const fin    = Math.min(inicio + CHUNK_SIZE, archivo.size);
      const blob   = archivo.slice(inicio, fin);

      const fd = new FormData();
      fd.append('upload_id',       uploadId);
      fd.append('chunk_index',     String(i));
      fd.append('total_chunks',    String(totalChunks));
      fd.append('tema_id',         String(tema.id));
      fd.append('nombre_original', archivo.name);
      if (i === totalChunks - 1 && durMin > 0) fd.append('duracion', String(durMin));
      fd.append('chunk', blob, archivo.name + '.part' + i);

      const bytesPrevios  = inicio;
      const totalBytes    = archivo.size;
      const esUltimo      = (i === totalChunks - 1);

      const resultado = await new Promise<{ ok: boolean; data?: any; status?: number; texto?: string }>((res) => {
        const xhr = new XMLHttpRequest();
        if (onProgress) {
          xhr.upload.addEventListener('progress', (e) => {
            if (e.lengthComputable) {
              const subidoAhora = bytesPrevios + e.loaded;
              onProgress(Math.min(99, Math.round((subidoAhora / totalBytes) * 100)));
            }
          });
        }
        xhr.addEventListener('load',  () => {
          if (xhr.status < 200 || xhr.status >= 300) { res({ ok: false, status: xhr.status, texto: xhr.responseText }); return; }
          try { res({ ok: true, data: JSON.parse(xhr.responseText) }); }
          catch { res({ ok: false, texto: xhr.responseText }); }
        });
        xhr.addEventListener('error',   () => res({ ok: false, texto: 'network' }));
        xhr.addEventListener('timeout', () => res({ ok: false, texto: 'timeout' }));
        xhr.addEventListener('abort',   () => res({ ok: false, texto: 'abort' }));
        xhr.open('POST', '/api/upload-chunk.php');
        xhr.send(fd);
      });

      if (!resultado.ok) {
        const msg = `Fallo al subir el chunk ${i + 1}/${totalChunks}${resultado.status ? ` (HTTP ${resultado.status})` : ''}`;
        mostrarMsg(msg, 'error');
        (window as any).logAppError?.('upload', msg, { detalle: detalle + ' · respuesta=' + (resultado.texto || '').slice(0, 200) });
        resolve(); return;
      }

      if (!resultado.data?.ok) {
        mostrarMsg(resultado.data?.mensaje || `Error al procesar el chunk ${i + 1}`, 'error');
        (window as any).logAppError?.('upload', `Chunk ${i} rechazado: ${resultado.data?.mensaje || 'sin mensaje'}`, { detalle });
        resolve(); return;
      }

      if (esUltimo) {
        const lista = cuerpo.querySelector('.mat-lista-video') as HTMLElement;
        lista.appendChild(crearFilaMat(resultado.data.material));
        if (durMin > 0) actualizarDuracionTrasSubida(cuerpo, tema, durMin);
        if (onProgress) onProgress(100);
        mostrarMsg('✓ Vídeo subido correctamente.', 'ok');
      }
    }

    resolve();
  });
}

function subirArchivo(
  cuerpo: HTMLElement,
  tema: any,
  archivo: File,
  tipo: string,
  onProgress?: (pct: number) => void
): Promise<void> {
  return new Promise(async (resolve) => {
    let durMin = 0;
    if (tipo === 'video') {
      try {
        const seg = await leerDuracionVideo(archivo);
        durMin = seg > 0 ? Math.ceil(seg / 60) : 0;
      } catch { durMin = 0; }
    }

    // Vídeos grandes → chunked para esquivar el límite nginx de 1 GB
    if (tipo === 'video' && archivo.size >= CHUNK_SIZE) {
      await subirArchivoChunked(cuerpo, tema, archivo, durMin, onProgress);
      resolve(); return;
    }

    const fd = new FormData();
    fd.append('archivo', archivo);
    fd.append('tema_id', String(tema.id));
    fd.append('tipo',    tipo);
    if (durMin > 0) fd.append('duracion', String(durMin));

    const xhr = new XMLHttpRequest();

    if (onProgress) {
      xhr.upload.addEventListener('progress', (e) => {
        if (e.lengthComputable) onProgress(Math.round((e.loaded / e.total) * 100));
      });
    }

    const detalle = `${tipo} · ${archivo.name} · ${(archivo.size/1024/1024).toFixed(1)} MB · tema=${tema.id}`;

    xhr.addEventListener('load', () => {
      if (xhr.status < 200 || xhr.status >= 300) {
        mostrarMsg(`Error del servidor (${xhr.status}). El archivo puede ser demasiado grande.`, 'error');
        (window as any).logAppError?.('upload', `Servidor devolvió ${xhr.status} al subir ${tipo}`, { detalle: detalle + ' · respuesta=' + (xhr.responseText || '').slice(0, 200) });
        resolve(); return;
      }
      try {
        const data = JSON.parse(xhr.responseText);
        if (!data.ok) {
          mostrarMsg(data.mensaje || 'Error al subir el archivo', 'error');
          (window as any).logAppError?.('upload', `Upload rechazado: ${data.mensaje || 'sin mensaje'}`, { detalle });
          resolve(); return;
        }

        const lista = cuerpo.querySelector(
          tipo === 'video' ? '.mat-lista-video' : '.mat-lista-doc'
        ) as HTMLElement;
        lista.appendChild(crearFilaMat(data.material));

        if (tipo === 'video' && durMin > 0) actualizarDuracionTrasSubida(cuerpo, tema, durMin);
        mostrarMsg(`✓ ${tipo === 'video' ? 'Vídeo' : 'Archivo'} subido correctamente.`, 'ok');
      } catch (err) {
        mostrarMsg('Error al procesar la respuesta del servidor.', 'error');
        (window as any).logAppError?.('upload', 'JSON inválido en respuesta de upload', { detalle: detalle + ' · respuesta=' + (xhr.responseText || '').slice(0, 200), stack: (err as any)?.stack });
      }
      resolve();
    });

    xhr.addEventListener('error', () => {
      mostrarMsg('Error de conexión al subir. Comprueba el tamaño del archivo.', 'error');
      (window as any).logAppError?.('upload', 'Error de red al subir archivo', { detalle });
      resolve();
    });

    xhr.addEventListener('timeout', () => {
      mostrarMsg('La subida tardó demasiado y se canceló.', 'error');
      (window as any).logAppError?.('upload', 'Timeout al subir archivo', { detalle });
      resolve();
    });

    xhr.addEventListener('abort', () => {
      (window as any).logAppError?.('upload', 'Subida cancelada por el usuario', { detalle });
      resolve();
    });

    xhr.open('POST', '/api/upload.php');
    xhr.send(fd);
  });
}

// ── Añadir nuevo tema ─────────────────────────────────────────
const btnNuevo    = document.getElementById('btn-mostrar-nuevo-tema') as HTMLButtonElement;
const nuevoWrap   = document.getElementById('form-nuevo-tema-wrap')!;
const btnCancelar = document.getElementById('btn-cancelar-tema') as HTMLButtonElement;
const btnCrear    = document.getElementById('btn-crear-tema') as HTMLButtonElement;
const inputNuevo  = document.getElementById('nuevo-tema-titulo') as HTMLInputElement;

btnNuevo.addEventListener('click', () => {
  const visible = nuevoWrap.style.display !== 'none';
  nuevoWrap.style.display = visible ? 'none' : 'block';
  if (!visible) inputNuevo.focus();
});
btnCancelar.addEventListener('click', () => { nuevoWrap.style.display = 'none'; });

btnCrear.addEventListener('click', async () => {
  const titulo = inputNuevo.value.trim();
  if (!titulo) { inputNuevo.focus(); return; }

  btnCrear.disabled    = true;
  btnCrear.textContent = 'Añadiendo…';

  const res  = await fetch('/api/temas.php', {
    method: 'POST', headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ curso_id: cursoId, titulo, duracion: '' }),
  });
  const data = await res.json();

  btnCrear.disabled    = false;
  btnCrear.textContent = 'Añadir tema';

  if (!data.ok) { mostrarMsg(data.mensaje || 'Error al crear el tema', 'error'); return; }

  const nuevoTema = { id: data.id, titulo, duracion: '', descripcion: '', orden: data.orden };
  temasVacio.style.display = 'none';
  const card = await crearTemaCard(nuevoTema);
  temasLista.appendChild(card);
  card.scrollIntoView({ behavior: 'smooth', block: 'start' });

  inputNuevo.value        = '';
  nuevoWrap.style.display = 'none';
  mostrarMsg('✓ Tema añadido. Ya puedes subir el vídeo y los materiales.', 'ok');
});

inputNuevo.addEventListener('keydown', (e: KeyboardEvent) => {
  if (e.key === 'Enter') btnCrear.click();
  if (e.key === 'Escape') { nuevoWrap.style.display = 'none'; }
});

// ── Editor de texto enriquecido ──────────────────────────────
function rteExec(btn: HTMLElement) {
  const val = btn.dataset.val;
  if (val) {
    const cur = document.queryCommandValue('formatBlock').toLowerCase();
    document.execCommand('formatBlock', false, cur === val ? 'p' : val);
  } else {
    document.execCommand(btn.dataset.cmd!, false, undefined);
  }
}
function actualizarEstado(wrap: HTMLElement) {
  wrap.querySelectorAll<HTMLElement>('.rte-btn[data-cmd]').forEach(btn => {
    try {
      btn.classList.toggle('activo', btn.dataset.val
        ? document.queryCommandValue('formatBlock').toLowerCase() === btn.dataset.val
        : document.queryCommandState(btn.dataset.cmd!));
    } catch {}
  });
}
(function initRTE() {
  const wrap   = document.getElementById('descripcion-editor')!.closest('.rte-wrap') as HTMLElement;
  const editor = document.getElementById('descripcion-editor')!;
  wrap.querySelectorAll<HTMLButtonElement>('.rte-btn').forEach(btn => {
    btn.addEventListener('mousedown', e => { e.preventDefault(); rteExec(btn); actualizarEstado(wrap); });
  });
  editor.addEventListener('keyup',  () => actualizarEstado(wrap));
  editor.addEventListener('mouseup', () => actualizarEstado(wrap));
})();

