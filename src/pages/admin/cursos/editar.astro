    const titulo      = (editPanel.querySelector('.input-titulo-tema') as HTMLInputElement).value.trim();
    const duracion    = (editPanel.querySelector('.input-dur-tema')    as HTMLInputElement).value.trim();
    const descEl = editPanel.querySelector('.input-desc-tema') as HTMLElement;
    const descripcion = descEl.innerHTML.trim() === '<br>' ? '' : descEl.innerHTML.trim();
