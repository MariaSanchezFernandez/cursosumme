      card.remove();
      if (!temasLista.children.length) temasVacio.style.display = 'block';
      mostrarMsg('✓ Tema eliminado.', 'ok');
    } else mostrarMsg(data.mensaje || 'Error', 'error');
  });

  // Upload vídeo
  const formVideo     = card.querySelector('.form-upload-video') as HTMLFormElement;
  const progresoVideo = formVideo.querySelector('.upload-progreso') as HTMLElement;
  const progresoBarra = formVideo.querySelector('.upload-progreso-fill') as HTMLElement;
  const progresoTxt   = formVideo.querySelector('.upload-progreso-txt') as HTMLElement;
  const btnSubirVideo = formVideo.querySelector('button') as HTMLButtonElement;
  formVideo.addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = card.querySelector('.input-video') as HTMLInputElement;
    if (!input.files?.length) return;
    const archivo = input.files[0];
    const MAX_VIDEO = 3584 * 1024 * 1024;
    if (archivo.size > MAX_VIDEO) {
      const mb = (archivo.size / 1024 / 1024).toFixed(0);
      mostrarMsg(`El vídeo pesa ${mb} MB y supera el límite de 3.5 GB. Comprímelo antes de subirlo.`, 'error');
      (window as any).logAppError?.('upload', `Vídeo rechazado en cliente (${mb} MB > 3.5 GB)`, { detalle: archivo.name + ' · tema=' + tema.id });
      input.value = '';
      return;
    }
    progresoVideo.style.display = 'flex';
    progresoBarra.style.width = '0%';
    progresoTxt.textContent = '0%';
    btnSubirVideo.disabled = true;
    await subirArchivo(card, tema, archivo, 'video', (pct) => {
      progresoBarra.style.width = pct + '%';
      progresoTxt.textContent = pct + '%';
    });
    progresoVideo.style.display = 'none';
    btnSubirVideo.disabled = false;
    input.value = '';
  });

  // Upload doc
  const formDoc = card.querySelector('.form-upload-doc') as HTMLFormElement;
  const msgDoc  = card.querySelector('.form-upload-doc .subiendo-msg') as HTMLElement;
  formDoc.addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = card.querySelector('.input-doc') as HTMLInputElement;
    if (!input.files?.length) return;
    const archivo = input.files[0];
    const MAX_DOC = 100 * 1024 * 1024;
    if (archivo.size > MAX_DOC) {
      const mb = (archivo.size / 1024 / 1024).toFixed(0);
      mostrarMsg(`El archivo pesa ${mb} MB y supera el límite de 100 MB.`, 'error');
      (window as any).logAppError?.('upload', `Documento rechazado en cliente (${mb} MB > 100 MB)`, { detalle: archivo.name + ' · tema=' + tema.id });
      input.value = '';
      return;
    }
    msgDoc.style.display = 'inline';
    (formDoc.querySelector('button') as HTMLButtonElement).disabled = true;
    await subirArchivo(card, tema, archivo, 'documento');
    msgDoc.style.display = 'none';
    (formDoc.querySelector('button') as HTMLButtonElement).disabled = false;
    input.value = '';
  });

  // Inicializar RTE del tema
  const temaWrap   = card.querySelector('.rte-wrap') as HTMLElement;
  const temaEditor = card.querySelector('.input-desc-tema') as HTMLElement;
  temaWrap?.querySelectorAll<HTMLButtonElement>('.rte-btn').forEach(btn => {
    btn.addEventListener('mousedown', e => { e.preventDefault(); rteExec(btn); actualizarEstado(temaWrap); });
  });
  temaEditor?.addEventListener('keyup',  () => actualizarEstado(temaWrap));
  temaEditor?.addEventListener('mouseup', () => actualizarEstado(temaWrap));

  return card;
}

function crearFilaMat(mat: any): HTMLElement {
  const kb    = mat.tamano_kb > 1024 ? `${(mat.tamano_kb/1024).toFixed(1)} MB` : `${mat.tamano_kb} KB`;
  const icono = mat.tipo === 'video' ? '🎬' : '📄';
  const div   = document.createElement('div');
  div.className = 'mat-fila';

  function renderNormal() {
    // Botón descarga solo para vídeos (los documentos ya se sirven directos).
    const btnDescargaHTML = mat.tipo === 'video'
      ? `<a class="mat-descarga" href="${urlDescargaVideo(mat)}" download="${mat.nombre}" title="Descargar">
           <svg viewBox="0 0 14 14" fill="none" width="13" height="13">
             <path d="M7 1.5v8M3.5 6L7 9.5 10.5 6M2 12h10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
           </svg>
         </a>`
      : '';
    div.innerHTML = `
      <span class="mat-icono">${icono}</span>
      <a href="${urlMaterial(mat)}" target="_blank" class="mat-nombre" title="${mat.nombre}">${mat.nombre}</a>
      <span class="mat-tam">${kb}</span>
      ${btnDescargaHTML}
      <button class="mat-rename" title="Renombrar">
        <svg viewBox="0 0 14 14" fill="none" width="13" height="13">
          <path d="M9.5 2.5l2 2-7 7H2.5v-2l7-7z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
        </svg>
      </button>
      <button class="mat-del" title="Eliminar">✕</button>
    `;
    div.querySelector('.mat-rename')!.addEventListener('click', renderEditar);
    div.querySelector('.mat-del')!.addEventListener('click', async () => {
      if (!confirm(`¿Eliminar "${mat.nombre}"?`)) return;
      const res  = await fetch(`/api/materiales.php?id=${mat.id}`, { method: 'DELETE' });
      const data = await res.json();
      if (data.ok) div.remove(); else mostrarMsg('Error al eliminar', 'error');
    });
  }

  function renderEditar() {
    div.innerHTML = `
      <span class="mat-icono">${icono}</span>
      <input type="text" class="mat-nombre-input" value="${mat.nombre}" />
      <button class="mat-save" title="Guardar">✓</button>
      <button class="mat-cancelar-rename" title="Cancelar">✕</button>
    `;
    const input = div.querySelector('.mat-nombre-input') as HTMLInputElement;
    input.focus(); input.select();

    async function guardar() {
      const nuevoNombre = input.value.trim();
      if (!nuevoNombre) return;
      const res  = await fetch('/api/materiales.php', {
        method: 'PUT', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ id: mat.id, nombre: nuevoNombre }),
      });
      const data = await res.json();
      if (data.ok) { mat.nombre = nuevoNombre; renderNormal(); }
      else mostrarMsg('Error al renombrar', 'error');
    }
    div.querySelector('.mat-save')!.addEventListener('click', guardar);
    div.querySelector('.mat-cancelar-rename')!.addEventListener('click', renderNormal);
    input.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') guardar();
      if (e.key === 'Escape') renderNormal();
    });
  }

  renderNormal();
  return div;
}

function leerDuracionVideo(archivo: File): Promise<number> {
  return new Promise(resolve => {
    const url = URL.createObjectURL(archivo);
    const v   = document.createElement('video');
    v.preload  = 'metadata';
    v.onloadedmetadata = () => { URL.revokeObjectURL(url); resolve(v.duration); };
    v.onerror          = () => { URL.revokeObjectURL(url); resolve(0); };
    v.src = url;
  });
}

function subirArchivo(
  card: HTMLElement,
  tema: any,
  archivo: File,
  tipo: string,
  onProgress?: (pct: number) => void
): Promise<void> {
  return new Promise(async (resolve) => {
    let durMin = 0;
    if (tipo === 'video') {
      const seg = await leerDuracionVideo(archivo);
      durMin = seg > 0 ? Math.ceil(seg / 60) : 0;
    }

    const fd = new FormData();
    fd.append('archivo', archivo);
    fd.append('tema_id', String(tema.id));
    fd.append('tipo',    tipo);
    if (durMin > 0) fd.append('duracion', String(durMin));

    const xhr = new XMLHttpRequest();

    if (onProgress) {
      xhr.upload.addEventListener('progress', (e) => {
        if (e.lengthComputable) onProgress(Math.round((e.loaded / e.total) * 100));
      });
    }

    const detalle = `${tipo} · ${archivo.name} · ${(archivo.size/1024/1024).toFixed(1)} MB · tema=${tema.id}`;

    xhr.addEventListener('load', async () => {
      if (xhr.status < 200 || xhr.status >= 300) {
        mostrarMsg(`Error del servidor (${xhr.status}). El archivo puede ser demasiado grande.`, 'error');
        (window as any).logAppError?.('upload', `Servidor devolvió ${xhr.status} al subir ${tipo}`, { detalle: detalle + ' · respuesta=' + (xhr.responseText || '').slice(0, 200) });
        resolve(); return;
      }
      try {
        const data = JSON.parse(xhr.responseText);
        if (!data.ok) {
          mostrarMsg(data.mensaje || 'Error al subir', 'error');
          (window as any).logAppError?.('upload', `Upload rechazado: ${data.mensaje || 'sin mensaje'}`, { detalle });
          resolve(); return;
        }

        const lista = card.querySelector(tipo === 'video' ? `.mat-lista-video-${tema.id}` : `.mat-lista-doc-${tema.id}`) as HTMLElement;
        lista.appendChild(crearFilaMat(data.material));

        if (tipo === 'video' && durMin > 0) {
          const inputDur = card.querySelector('.input-dur-tema') as HTMLInputElement;
          if (!inputDur.value || inputDur.value === '0') {
            inputDur.value = String(durMin);
            const durLabel = document.getElementById(`dur-label-${tema.id}`);
            if (durLabel) { durLabel.textContent = durMin + ' min'; durLabel.style.display = ''; }
            await fetch('/api/temas.php', {
              method: 'PUT', headers: {'Content-Type':'application/json'},
              body: JSON.stringify({ id: tema.id, titulo: tema.titulo, duracion: String(durMin), orden: tema.orden }),
            });
            await guardarDuracionCurso();
          }
        }
        mostrarMsg(`✓ ${tipo === 'video' ? 'Vídeo' : 'Archivo'} subido.`, 'ok');
      } catch (err) {
        mostrarMsg('Error al procesar la respuesta del servidor.', 'error');
        (window as any).logAppError?.('upload', 'JSON inválido en respuesta de upload', { detalle: detalle + ' · respuesta=' + (xhr.responseText || '').slice(0, 200), stack: (err as any)?.stack });
      }
      resolve();
    });

    xhr.addEventListener('error', () => {
      mostrarMsg('Error de conexión al subir.', 'error');
      (window as any).logAppError?.('upload', 'Error de red al subir archivo', { detalle });
      resolve();
    });

    xhr.addEventListener('timeout', () => {
      mostrarMsg('La subida tardó demasiado y se canceló.', 'error');
      (window as any).logAppError?.('upload', 'Timeout al subir archivo', { detalle });
      resolve();
    });

    xhr.addEventListener('abort', () => {
      (window as any).logAppError?.('upload', 'Subida cancelada por el usuario', { detalle });
      resolve();
    });

    xhr.open('POST', '/api/upload.php');
    xhr.send(fd);
  });
}

// ── Editor de texto enriquecido ───────────────────────────────
function rteExec(btn: HTMLElement) {
  const val = btn.dataset.val;
  if (val) {
    const cur = document.queryCommandValue('formatBlock').toLowerCase();
    document.execCommand('formatBlock', false, cur === val ? 'p' : val);
  } else {
    document.execCommand(btn.dataset.cmd!, false, undefined);
  }
}
function actualizarEstado(wrap: HTMLElement) {
  wrap.querySelectorAll<HTMLElement>('.rte-btn[data-cmd]').forEach(btn => {
    try {
      btn.classList.toggle('activo', btn.dataset.val
        ? document.queryCommandValue('formatBlock').toLowerCase() === btn.dataset.val
        : document.queryCommandState(btn.dataset.cmd!));
    } catch {}
  });
}
// Init RTE de descripción del curso
(function() {
  const wrap   = document.getElementById('descripcion-editor')!.closest('.rte-wrap') as HTMLElement;
  const editor = document.getElementById('descripcion-editor')!;
  wrap.querySelectorAll<HTMLButtonElement>('.rte-btn').forEach(btn => {
    btn.addEventListener('mousedown', e => { e.preventDefault(); rteExec(btn); actualizarEstado(wrap); });
  });
  editor.addEventListener('keyup',   () => actualizarEstado(wrap));
  editor.addEventListener('mouseup', () => actualizarEstado(wrap));
})();
</script>
