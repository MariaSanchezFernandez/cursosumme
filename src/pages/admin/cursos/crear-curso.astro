// ── Duración total ─────────────────────────────────────────────
function calcularDuracionTotal(): string {
  let total = 0;
  document.querySelectorAll<HTMLInputElement>('.input-dur-tema').forEach(inp => {
    const n = parseInt(inp.value);
    if (!isNaN(n) && n > 0) total += n;
  });
  if (!total) return '';
  const h = Math.floor(total / 60), m = total % 60;
  return h > 0 ? (m > 0 ? `${h}h ${m}min` : `${h}h`) : `${m} min`;
}

async function guardarDuracionCurso() {
  if (!cursoId) return;
  const dur = calcularDuracionTotal();
  const res = await fetch('/api/cursos.php');
  const data = await res.json();
  const c = data.cursos?.find((x: any) => x.id == cursoId);
  if (!c) return;
  await fetch('/api/cursos.php', {
    method: 'PUT', headers: {'Content-Type':'application/json'},
    body: JSON.stringify({ id: cursoId, titulo: c.titulo, etiqueta: c.etiqueta, nivel: c.nivel, duracion: dur, activo: c.activo }),
  });
}

