---
import PlantillaAdmin from '../../layouts/PlantillaAdmin.astro';
---

<PlantillaAdmin titulo="Cursos" paginaActual="cursos">

  <!-- Barra superior -->
  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem; flex-wrap:wrap; gap:0.75rem;">
    <div style="display:flex; align-items:center; gap:0.75rem; flex-wrap:wrap; flex:1;">
      <div style="display:flex; gap:0.5rem; flex-wrap:wrap;" id="filtros-pack"></div>
      <input id="buscador-cursos" type="search" placeholder="Buscar curso…" autocomplete="off"
        style="border:1px solid var(--color-borde); border-radius:6px; padding:0.35rem 0.7rem; font-size:0.82rem; width:200px; outline:none;">
    </div>
    <div style="display:flex; gap:0.5rem;">
      <button id="btn-nuevo-pack" class="btn-admin">
        <svg viewBox="0 0 16 16" fill="none">
          <rect x="1" y="3" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.4"/>
          <path d="M1 6h14" stroke="currentColor" stroke-width="1.4"/>
          <path d="M5 6v7" stroke="currentColor" stroke-width="1.4"/>
        </svg>
        Gestionar packs
      </button>
      <a href="/admin/cursos/crear-curso" class="btn-admin primario">
        <svg viewBox="0 0 16 16" fill="none">
          <path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
        Nuevo curso
      </a>
    </div>
  </div>

  <div id="estado-carga" style="padding:2rem 0; color:#aaa; font-size:0.85rem;">
    Cargando cursos…
  </div>

  <div id="contenido-cursos"></div>

  <div id="estado-vacio" style="display:none; padding:3rem; text-align:center; background:#fff;
    border:1px dashed #ddd; border-radius:14px; color:#aaa; font-size:0.85rem;">
    No hay cursos aún.
    <a href="/admin/cursos/crear-curso" style="color:inherit; font-weight:600;">Crear el primero →</a>
  </div>

</PlantillaAdmin>

<!-- ── Panel gestión de packs ──────────────────────────────── -->
<div id="overlay-pack" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.35); z-index:100;"></div>

<div id="panel-pack" style="display:none; position:fixed; top:0; right:0; height:100vh; width:420px; max-width:100vw;
  background:#fff; box-shadow:-4px 0 24px rgba(0,0,0,0.1); z-index:101; flex-direction:column;">

  <div style="padding:1.5rem 1.5rem 1rem; border-bottom:1px solid #f0f5f2; display:flex; align-items:center; gap:0.75rem;">
    <div style="flex:1;">
      <p id="panel-titulo" style="font-size:0.95rem; font-weight:800; margin:0 0 0.1rem;">Gestionar packs</p>
      <p id="panel-subtitulo" style="font-size:0.75rem; color:#aaa; margin:0;">Agrupa cursos existentes en packs</p>
    </div>
    <button id="btn-cerrar-panel" style="background:none; border:none; cursor:pointer; padding:0.25rem; color:#aaa; font-size:1.2rem;">✕</button>
  </div>

  <!-- Selector de pack existente o nuevo -->
  <div style="padding:1rem 1.5rem; border-bottom:1px solid #f0f5f2;">
    <div style="display:flex; gap:0.5rem; align-items:flex-end;">
      <div style="flex:1;">
        <label style="font-size:0.75rem; font-weight:700; color:#666; display:block; margin-bottom:0.35rem;">Nombre del pack</label>
        <input id="pack-nombre-input" class="form-input" type="text" placeholder="Ej. Pack Bienvenida, Pack Derechos…"
          style="width:100%; box-sizing:border-box;" />
      </div>
      <div id="pack-selector-wrap" style="min-width:110px;">
        <label style="font-size:0.75rem; font-weight:700; color:#666; display:block; margin-bottom:0.35rem;">Pack existente</label>
        <select id="pack-selector" class="form-input" style="width:100%;">
          <option value="">— Nuevo —</option>
        </select>
      </div>
    </div>
    <p style="font-size:0.72rem; color:#aaa; margin:0.5rem 0 0;">
      Selecciona un pack existente para editarlo, o escribe un nombre nuevo para crearlo.
    </p>
  </div>

  <!-- Precio y Stripe del pack -->
  <div style="padding:0.75rem 1.5rem; border-bottom:1px solid #f0f5f2; display:flex; gap:0.75rem;">
    <div style="flex:1;">
      <label style="font-size:0.75rem; font-weight:700; color:#666; display:block; margin-bottom:0.35rem;">Precio (€)</label>
      <input id="pack-precio-input" class="form-input" type="number" min="0" step="0.01" placeholder="Ej. 49.00"
        style="width:100%; box-sizing:border-box;" />
    </div>
    <div style="flex:2;">
      <label style="font-size:0.75rem; font-weight:700; color:#666; display:block; margin-bottom:0.35rem;">Stripe Price ID</label>
      <input id="pack-spid-input" class="form-input" type="text" placeholder="price_..."
        style="width:100%; box-sizing:border-box;" />
    </div>
  </div>

  <!-- Lista de cursos con checkboxes -->
  <div style="flex:1; overflow-y:auto; padding:1rem 1.5rem;">
    <p style="font-size:0.72rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:#aaa; margin:0 0 0.75rem;">
      Cursos en este pack
    </p>
    <div id="pack-cursos-lista" style="display:flex; flex-direction:column; gap:0.5rem;"></div>
  </div>

  <!-- Footer con acciones -->
  <div style="padding:1rem 1.5rem; border-top:1px solid #f0f5f2; display:flex; flex-direction:column; gap:0.5rem;">
    <div id="panel-msg" style="display:none; padding:0.6rem 0.8rem; border-radius:7px; font-size:0.8rem;"></div>
    <div style="display:flex; gap:0.5rem;">
      <button id="btn-guardar-pack" class="btn-admin primario" style="flex:1; justify-content:center;">
        Guardar pack
      </button>
      <button id="btn-disolver-pack" class="btn-admin" style="color:#c33; border-color:#f5c6c6; display:none;">
        Disolver
      </button>
      <button id="btn-cancelar-pack" class="btn-admin">
        Cancelar
      </button>
    </div>
  </div>
</div>

<style is:global>
.pack-section { margin-bottom: 2rem; }
.pack-header {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  margin-bottom: 0.75rem;
  border-radius: 8px;
  padding: 0.3rem 0.4rem;
  margin-left: -0.4rem;
  transition: background 0.18s;
}
.pack-header.colapsable { cursor: pointer; }
.pack-header.colapsable:hover { background: rgba(0,0,0,0.03); }
.pack-chevron {
  width: 14px; height: 14px; flex-shrink: 0; color: #bbb;
  transition: transform 0.3s ease;
}
.pack-grid-wrap {
  display: grid;
  grid-template-rows: 0fr;
  transition: grid-template-rows 0.35s ease;
}
.pack-grid-wrap.abierto { grid-template-rows: 1fr; }
.pack-grid-inner {
  overflow: hidden;
  min-height: 0;
  padding-top: 0;
  transition: padding-top 0.35s ease;
}
.pack-grid-wrap.abierto .pack-grid-inner { padding-top: 0.25rem; }
.pack-label {
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: #a0b0aa;
}
.pack-linea { flex: 1; height: 1px; background: #e8eeed; }
.pack-count { font-size: 0.65rem; color: #bbb; font-weight: 600; }
.btn-editar-pack {
  font-size: 0.65rem;
  padding: 0.15rem 0.5rem;
  border: 1px solid #e4ede9;
  border-radius: 6px;
  background: #fff;
  cursor: pointer;
  color: #6a8a7d;
  font-family: inherit;
  font-weight: 600;
}
.btn-editar-pack:hover { background: var(--color-light); border-color: var(--color-primary); }
.cursos-cards {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1rem;
}
.curso-card {
  background: #fff;
  border: 1px solid #e4ede9;
  border-radius: 14px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  transition: box-shadow 0.15s, transform 0.15s;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.curso-card:hover { box-shadow: 0 4px 18px rgba(0,0,0,0.09); transform: translateY(-1px); }
.curso-card-img { width: 100%; aspect-ratio: 21 / 9; overflow: hidden; }
.curso-card-img img { width: 100%; height: 100%; object-fit: cover; background: #f3f6f4; display: block; }
.curso-card-acento-top { height: 4px; }
.curso-card-body { padding: 1.1rem 1.25rem; flex: 1; display: flex; flex-direction: column; gap: 0.55rem; }
.curso-card-top { display: flex; align-items: flex-start; gap: 0.75rem; }
.curso-acento { width: 4px; border-radius: 3px; flex-shrink: 0; align-self: stretch; min-height: 36px; }
.curso-card-titulo { font-size: 0.9rem; font-weight: 700; color: var(--color-text); flex: 1; line-height: 1.3; }
.curso-card-meta { display: flex; flex-wrap: wrap; gap: 0.35rem; align-items: center; }
.curso-tag { font-size: 0.68rem; padding: 0.15rem 0.55rem; border-radius: 20px; background: #f0f5f2; color: #6a8a7d; font-weight: 600; }
.curso-tag.activo   { background: #e8f5ee; color: #2e7d55; }
.curso-tag.inactivo { background: #f5e8e8; color: #a33; }
.curso-card-footer {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0.7rem 1.25rem;
  border-top: 1px solid #f0f4f2;
  background: #fafcfb;
}
.curso-stats { display: flex; align-items: center; gap: 0.35rem; flex-wrap: wrap; }
.curso-temas { font-size: 0.75rem; color: var(--color-text-muted); }
.curso-stat-sep { font-size: 0.7rem; color: var(--color-text-muted); opacity: 0.5; }
.curso-progreso-badge { font-size: 0.72rem; font-weight: 700; background: #e8f4ee; color: #2e7d55; border-radius: 20px; padding: 0.1rem 0.5rem; }
.curso-card-acciones { display: flex; gap: 0.4rem; align-items: center; }
.btn-card-dup {
  width: 30px; height: 30px; border-radius: 8px; border: 1px solid #d8e8e0;
  background: #fff; cursor: pointer; display: flex; align-items: center;
  justify-content: center; color: #3a7a5a; flex-shrink: 0;
}
.btn-card-dup:hover { background: #eef6f1; }
.btn-card-del {
  width: 30px; height: 30px; border-radius: 8px; padding: 0;
  border: 1px solid #f5c6c6; background: #fff; cursor: pointer;
  display: flex; align-items: center; justify-content: center; color: #c33;
  transition: background 0.12s;
}
.btn-card-del:hover { background: #fdf0f0; }
.btn-filtro {
  padding: 0.35rem 0.85rem; border: 1.5px solid #e4ede9; border-radius: 20px;
  background: #fff; font-family: inherit; font-size: 0.75rem; font-weight: 600;
  color: var(--color-text-muted); cursor: pointer;
  transition: background 0.12s, border-color 0.12s, color 0.12s;
}
.btn-filtro:hover, .btn-filtro.activo {
  background: var(--color-light); border-color: var(--color-primary); color: var(--color-text);
}
/* Checkbox item en el panel */
.pack-curso-item {
  display: flex; align-items: center; gap: 0.75rem;
  padding: 0.65rem 0.9rem; border: 1.5px solid #e4ede9; border-radius: 9px;
  cursor: pointer; transition: border-color 0.12s, background 0.12s;
}
.pack-curso-item:hover { border-color: var(--color-primary); background: #f4faf8; }
.pack-curso-item.checked { border-color: var(--color-primary); background: var(--color-light); }
.pack-curso-item input[type="checkbox"] { width: 16px; height: 16px; flex-shrink: 0; accent-color: var(--color-primary); }
.pack-curso-item-titulo { font-size: 0.83rem; font-weight: 600; flex: 1; }
.pack-curso-item-cat { font-size: 0.72rem; color: #aaa; }
</style>

<script>
const PALETA = ['#b5d8cc','#b5c8e8','#d4c8e8','#e8d4b5','#e8c8b5','#c8e8b5'];
const PALETA_COLORES = ['#b5d8cc','#b5c8e8','#d4c8e8','#e8d4b5','#e8c8b5','#c8e8b5','#f5b5c0','#c0d4f5'];
let todosLosCursos: any[] = [];

// ── Cargar cursos ──────────────────────────────────────────────
async function cargarCursos() {
  try {
    const res  = await fetch('/api/cursos.php');
    const data = await res.json();

    document.getElementById('estado-carga')!.style.display = 'none';

    if (!data.ok || data.cursos.length === 0) {
      document.getElementById('estado-vacio')!.style.display = 'block';
      return;
    }

    todosLosCursos = data.cursos;
    construirFiltros();
    renderizarCursos('todos');
    actualizarSelectorPacks();

  } catch {
    document.getElementById('estado-carga')!.textContent = 'Error al cargar los cursos.';
  }
}

// ── Filtros por pack ───────────────────────────────────────────
function construirFiltros() {
  const packs = [...new Set(todosLosCursos.map((c: any) => c.pack || ''))].filter(Boolean) as string[];
  const wrap  = document.getElementById('filtros-pack')!;
  wrap.innerHTML = '';

  const btnTodos = crearBtnFiltro('Todos', 'todos', true);
  wrap.appendChild(btnTodos);
  packs.forEach(pack => wrap.appendChild(crearBtnFiltro(pack, pack, false)));
  if (todosLosCursos.some((c: any) => !c.pack)) {
    wrap.appendChild(crearBtnFiltro('Sin pack', '__sin_pack__', false));
  }
}

function crearBtnFiltro(texto: string, pack: string, activo: boolean): HTMLButtonElement {
  const btn = document.createElement('button');
  btn.className = `btn-filtro${activo ? ' activo' : ''}`;
  btn.dataset.pack = pack;
  btn.textContent = texto;
  btn.addEventListener('click', () => {
    document.querySelectorAll<HTMLButtonElement>('.btn-filtro').forEach(b => b.classList.remove('activo'));
    btn.classList.add('activo');
    renderizarCursos(pack);
  });
  return btn;
}

// ── Renderizar tarjetas ────────────────────────────────────────
let filtroPack = 'todos';
let filtroTexto = '';

document.getElementById('buscador-cursos')!.addEventListener('input', (e) => {
  filtroTexto = (e.target as HTMLInputElement).value.trim().toLowerCase();
  renderizarCursos(filtroPack);
});

function renderizarCursos(filtro: string) {
  filtroPack = filtro;
  const contenido = document.getElementById('contenido-cursos')!;
  contenido.innerHTML = '';

  let lista: any[] = todosLosCursos;
  if (filtro === '__sin_pack__') lista = todosLosCursos.filter((c: any) => !c.pack);
  else if (filtro !== 'todos')   lista = todosLosCursos.filter((c: any) => c.pack === filtro);

  if (filtroTexto) {
    lista = lista.filter((c: any) =>
      c.titulo.toLowerCase().includes(filtroTexto) ||
      (c.etiqueta || '').toLowerCase().includes(filtroTexto)
    );
  }

  const grupos = new Map<string, any[]>();
  for (const c of lista) {
    const key = c.pack || '__sin_pack__';
    if (!grupos.has(key)) grupos.set(key, []);
    grupos.get(key)!.push(c);
  }


  grupos.forEach((cursos, pack) => {
    const section = document.createElement('div');
    section.className = 'pack-section';

    const packColor = cursos.find((c: any) => c.pack_color)?.pack_color || null;
    const esPack    = pack !== '__sin_pack__';
    let   headerEl: HTMLElement | null = null;

    if (filtro === 'todos' || grupos.size > 1) {
      const header = document.createElement('div');
      header.className = 'pack-header colapsable';
      const label = esPack ? pack : 'Individuales';
      header.innerHTML = `
        <svg class="pack-chevron" viewBox="0 0 14 14" fill="none">
          <path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="pack-label">${label}</span>
        <div class="pack-linea"></div>
        <span class="pack-count">${cursos.length} curso${cursos.length !== 1 ? 's' : ''}</span>
      `;
      if (esPack) {
        const btnColorPack = document.createElement('button');
        btnColorPack.className = 'btn-color-pack';
        btnColorPack.title = 'Color del pack';
        btnColorPack.style.background = packColor || '#ddd';
        const packActual = pack;
        btnColorPack.addEventListener('click', (e) => {
          e.stopPropagation();
          document.querySelectorAll('.pack-paleta-color').forEach(p => p.remove());
          const paleta = document.createElement('div');
          paleta.className = 'pack-paleta-color';
          PALETA_COLORES.forEach(color => {
            const dot = document.createElement('button');
            dot.type = 'button';
            dot.className = `color-dot-btn${packColor === color ? ' seleccionado' : ''}`;
            dot.style.background = color;
            dot.title = color;
            dot.addEventListener('click', async () => {
              btnColorPack.style.background = color;
              paleta.remove();
              section.querySelectorAll('.curso-acento').forEach(el => {
                (el as HTMLElement).style.background = color;
              });
              await Promise.all(cursos.map((c: any) =>
                fetch('/api/cursos.php', {
                  method: 'PUT', headers: {'Content-Type':'application/json'},
                  body: JSON.stringify({ id: c.id, titulo: c.titulo, etiqueta: c.etiqueta,
                    nivel: c.nivel, duracion: c.duracion, activo: c.activo,
                    pack: packActual, pack_color: color }),
                })
              ));
              todosLosCursos.forEach(c => { if (c.pack === packActual) c.pack_color = color; });
            });
            paleta.appendChild(dot);
          });
          const wrapEl = btnColorPack.parentElement!;
          wrapEl.style.position = 'relative';
          wrapEl.appendChild(paleta);
          const cerrar = () => { paleta.remove(); document.removeEventListener('click', cerrar); };
          setTimeout(() => document.addEventListener('click', cerrar), 0);
        });
        header.appendChild(btnColorPack);

        const btnEditar = document.createElement('button');
        btnEditar.className = 'btn-editar-pack';
        btnEditar.textContent = 'Editar pack';
        btnEditar.addEventListener('click', (e) => { e.stopPropagation(); abrirPanelEditar(pack); });
        header.appendChild(btnEditar);
      }
      section.appendChild(header);
      headerEl = header;
    }

    // Wrapper colapsable — abierto si no hay cabecera (filtro específico)
    const gridWrap  = document.createElement('div');
    gridWrap.className = 'pack-grid-wrap';
    const gridInner = document.createElement('div');
    gridInner.className = 'pack-grid-inner';

    const grid = document.createElement('div');
    grid.className = 'cursos-cards';
    cursos.forEach((c: any) => {
      const acento = c.color || c.pack_color || packColor || PALETA[Number(c.id) % PALETA.length];
      const card = document.createElement('div');
      card.className = 'curso-card';
      card.innerHTML = `
        ${c.imagen ? `<div class="curso-card-img"><img src="${c.imagen}" alt="" /></div>` : `<div class="curso-card-acento-top" style="background:${acento}"></div>`}
        <div class="curso-card-body">
          <div class="curso-card-top">
            ${!c.imagen ? `<div class="curso-acento" style="background:${acento}"></div>` : ''}
            <span class="curso-card-titulo">${c.titulo}</span>
          </div>
          <div class="curso-card-meta">
            <span class="curso-tag">${c.etiqueta}</span>
            ${c.duracion ? `<span class="curso-tag">⏱ ${c.duracion}</span>` : ''}
            <span class="curso-tag ${c.activo == 1 ? 'activo' : 'inactivo'}">${c.activo == 1 ? '● Activo' : '● Inactivo'}</span>
            <span class="curso-tag precio-badge" style="cursor:pointer;background:${c.precio ? '#e8f4ee' : '#f5f5f5'};color:${c.precio ? '#1d7a52' : '#999'};" title="Editar precio">
              ${c.precio ? parseFloat(c.precio).toFixed(2) + ' €' : '+ Precio'}
            </span>
          </div>
        </div>
        <div class="curso-card-footer">
          <div class="curso-stats">
            <span class="curso-temas"><strong>${c.num_temas}</strong> tema${c.num_temas != 1 ? 's' : ''}</span>
            <span class="curso-stat-sep">·</span>
            <span class="curso-temas"><strong>${c.alumnos_count}</strong> alumno${c.alumnos_count != 1 ? 's' : ''}</span>
            ${c.alumnos_count > 0 ? `<span class="curso-stat-sep">·</span><span class="curso-progreso-badge" title="Progreso medio de los alumnos">${c.progreso_medio}%</span>` : ''}
          </div>
          <div class="curso-card-acciones">
            <button class="btn-color-curso btn-card-color" title="Color del curso" style="width:30px;height:30px;border-radius:50%;border:2px solid rgba(0,0,0,0.15);cursor:pointer;flex-shrink:0;padding:0;background:${acento};position:relative;"></button>
            <button class="btn-card-dup" data-id="${c.id}" data-titulo="${c.titulo}" title="Duplicar curso">
              <svg viewBox="0 0 14 14" fill="none" width="13" height="13">
                <rect x="4" y="4" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.3"/>
                <path d="M2 10V2h8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
            </button>
            <a href="/admin/cursos/editar?id=${c.id}" class="btn-admin" style="font-size:0.75rem; padding:0; height:30px; line-height:30px; display:inline-flex; align-items:center; padding:0 0.7rem;">
              Editar
            </a>
            <button class="btn-card-del" data-id="${c.id}" data-titulo="${c.titulo}" title="Eliminar curso">
              <svg viewBox="0 0 14 14" fill="none" width="13" height="13">
                <path d="M2 4h10M5 4V2.5h4V4M5.5 6.5v4M8.5 6.5v4M3 4l.75 7.5h6.5L11 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </div>
      `;

      const btnColorCurso = card.querySelector('.btn-card-color') as HTMLButtonElement;
      const acentoEl = card.querySelector('.curso-acento') as HTMLElement;
      btnColorCurso.addEventListener('click', (e) => {
        e.stopPropagation();
        document.querySelectorAll('.curso-paleta-color').forEach(p => p.remove());
        const paleta = document.createElement('div');
        paleta.className = 'curso-paleta-color';
        paleta.style.cssText = 'display:flex;flex-wrap:wrap;gap:0.35rem;padding:0.4rem 0.75rem;background:#fff;border:1px solid #e4ede9;border-radius:8px;box-shadow:0 3px 12px rgba(0,0,0,0.12);position:fixed;z-index:9999;';
        PALETA_COLORES.forEach(color => {
          const dot = document.createElement('button');
          dot.type = 'button';
          dot.className = `color-dot-btn${(c.color === color) ? ' seleccionado' : ''}`;
          dot.style.background = color;
          dot.title = color;
          dot.addEventListener('click', async () => {
            c.color = color;
            btnColorCurso.style.background = color;
            acentoEl.style.background = color;
            paleta.remove();
            await fetch('/api/cursos.php', {
              method: 'PUT', headers: {'Content-Type':'application/json'},
              body: JSON.stringify({ id: c.id, titulo: c.titulo, etiqueta: c.etiqueta,
                nivel: c.nivel, duracion: c.duracion, activo: c.activo,
                pack: c.pack || null, pack_color: c.pack_color || null, color }),
            });
          });
          paleta.appendChild(dot);
        });
        document.body.appendChild(paleta);
        // Position below the button
        const rect = btnColorCurso.getBoundingClientRect();
        paleta.style.top  = `${rect.bottom + 6}px`;
        paleta.style.left = `${rect.left - paleta.offsetWidth + rect.width}px`;
        const cerrar = () => { paleta.remove(); document.removeEventListener('click', cerrar); };
        setTimeout(() => document.addEventListener('click', cerrar), 0);
      });

      card.querySelector('.btn-card-dup')!.addEventListener('click', async (e) => {
        e.preventDefault();
        const btn    = e.currentTarget as HTMLButtonElement;
        const id     = Number(btn.dataset.id);
        const titulo = btn.dataset.titulo || '';
        if (!confirm(`¿Duplicar el curso "${titulo}"?\nSe creará una copia inactiva con todos sus temas y materiales.\n\n⚠ Los alumnos no se copian: deberás asignarlos manualmente a la copia desde su ficha de alumno.`)) return;
        btn.disabled = true;
        const res  = await fetch('/api/cursos.php', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ accion: 'duplicar', id }),
        });
        const data = await res.json();
        if (data.ok) {
          await cargarCursos();
        } else {
          btn.disabled = false;
          alert(data.mensaje || 'Error al duplicar el curso');
        }
      });

      card.querySelector('.precio-badge')!.addEventListener('click', async (e) => {
        e.stopPropagation();
        const precioActual = c.precio ? String(parseFloat(c.precio).toFixed(2)) : '';
        const spidActual   = c.stripe_price_id ?? '';
        const nuevoPrecio  = prompt('Precio del curso (€), deja vacío para quitar:', precioActual);
        if (nuevoPrecio === null) return;
        const nuevoSpid = prompt('Stripe Price ID (price_...):', spidActual);
        if (nuevoSpid === null) return;
        await fetch('/api/cursos.php', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            id: c.id, titulo: c.titulo, etiqueta: c.etiqueta,
            nivel: c.nivel, duracion: c.duracion, activo: c.activo,
            pack: c.pack, pack_color: c.pack_color, color: c.color, imagen: c.imagen,
            precio: nuevoPrecio || null,
            stripe_price_id: nuevoSpid || null,
          }),
        });
        c.precio           = nuevoPrecio ? parseFloat(nuevoPrecio) : null;
        c.stripe_price_id  = nuevoSpid || null;
        const badge = card.querySelector('.precio-badge') as HTMLElement;
        badge.textContent   = c.precio ? parseFloat(c.precio).toFixed(2) + ' €' : '+ Precio';
        badge.style.background = c.precio ? '#e8f4ee' : '#f5f5f5';
        badge.style.color      = c.precio ? '#1d7a52' : '#999';
      });

      card.querySelector('.btn-card-del')!.addEventListener('click', async (e) => {
        e.preventDefault();
        const btn    = e.currentTarget as HTMLButtonElement;
        const id     = Number(btn.dataset.id);
        const titulo = btn.dataset.titulo || '';
        if (!confirm(`¿Eliminar el curso "${titulo}"?\nSe borrarán todos sus temas y archivos.`)) return;
        btn.disabled = true;
        const res  = await fetch(`/api/cursos.php?id=${id}`, { method: 'DELETE' });
        const data = await res.json();
        if (data.ok) {
          todosLosCursos = todosLosCursos.filter(x => x.id !== id);
          construirFiltros();
          renderizarCursos('todos');
          actualizarSelectorPacks();
        } else {
          btn.disabled = false;
          alert(data.mensaje || 'Error al eliminar el curso');
        }
      });

      grid.appendChild(card);
    });

    gridInner.appendChild(grid);
    gridWrap.appendChild(gridInner);
    section.appendChild(gridWrap);
    contenido.appendChild(section);

    // Siempre empezar expandido
    gridWrap.classList.add('abierto');

    // Click en cabecera para expandir/colapsar
    if (headerEl) {
      const chevron = headerEl.querySelector<HTMLElement>('.pack-chevron');
      if (chevron) chevron.style.transform = 'rotate(90deg)';
      headerEl.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('button')) return;
        const isOpen = gridWrap.classList.toggle('abierto');
        if (chevron) chevron.style.transform = isOpen ? 'rotate(90deg)' : 'rotate(0deg)';
      });
    }
  });
}

// ── Panel de packs ─────────────────────────────────────────────
const overlay      = document.getElementById('overlay-pack')!;
const panel        = document.getElementById('panel-pack')!;
const inputNombre  = document.getElementById('pack-nombre-input') as HTMLInputElement;
const inputPrecio  = document.getElementById('pack-precio-input') as HTMLInputElement;
const inputSpid    = document.getElementById('pack-spid-input') as HTMLInputElement;
const selector     = document.getElementById('pack-selector') as HTMLSelectElement;
const listaDiv     = document.getElementById('pack-cursos-lista')!;
const btnDisolver  = document.getElementById('btn-disolver-pack') as HTMLButtonElement;
const panelMsg     = document.getElementById('panel-msg')!;

// Packs de Stripe cargados desde BD
let packsBD: any[] = [];
async function cargarPacksBD() {
  const res  = await fetch('/api/packs.php');
  const data = await res.json();
  packsBD = data.packs ?? [];
}
cargarPacksBD();

function mostrarPanelMsg(texto: string, tipo: 'ok' | 'error') {
  panelMsg.textContent      = texto;
  panelMsg.style.display    = 'block';
  panelMsg.style.background = tipo === 'ok' ? '#f0faf5' : '#fdf0f0';
  panelMsg.style.border     = `1px solid ${tipo === 'ok' ? '#b6e0cc' : '#f5c6c6'}`;
  panelMsg.style.color      = tipo === 'ok' ? '#2e7d55' : '#a33';
  setTimeout(() => { panelMsg.style.display = 'none'; }, 4000);
}

function actualizarSelectorPacks() {
  const packs = [...new Set(todosLosCursos.map((c: any) => c.pack).filter(Boolean))] as string[];
  selector.innerHTML = '<option value="">— Nuevo pack —</option>';
  packs.forEach(p => {
    const opt = document.createElement('option');
    opt.value = p; opt.textContent = p;
    selector.appendChild(opt);
  });
}

function rellenarDatosPack(nombrePack: string) {
  const packBD = packsBD.find(p => p.nombre === nombrePack || p.etiqueta === nombrePack);
  inputPrecio.value = packBD?.precio ? String(parseFloat(packBD.precio).toFixed(2)) : '';
  inputSpid.value   = packBD?.stripe_price_id ?? '';
}

function abrirPanel() {
  overlay.style.display = 'block';
  panel.style.display   = 'flex';
  panelMsg.style.display = 'none';
  inputNombre.value = '';
  inputPrecio.value = '';
  inputSpid.value   = '';
  selector.value    = '';
  btnDisolver.style.display = 'none';
  renderListaCursos('');
  inputNombre.focus();
}

function abrirPanelEditar(pack: string) {
  abrirPanel();
  selector.value    = pack;
  inputNombre.value = pack;
  btnDisolver.style.display = 'inline-flex';
  renderListaCursos(pack);
  rellenarDatosPack(pack);
}

function cerrarPanel() {
  overlay.style.display = 'none';
  panel.style.display   = 'none';
}

function renderListaCursos(packActual: string) {
  listaDiv.innerHTML = '';
  todosLosCursos.forEach(c => {
    const checked = c.pack === packActual && packActual !== '';
    const item = document.createElement('label');
    item.className = `pack-curso-item${checked ? ' checked' : ''}`;
    item.innerHTML = `
      <input type="checkbox" ${checked ? 'checked' : ''} data-id="${c.id}" />
      <div style="flex:1; min-width:0;">
        <div class="pack-curso-item-titulo">${c.titulo}</div>
        <div class="pack-curso-item-cat">${c.etiqueta}</div>
      </div>
    `;
    const cb = item.querySelector('input') as HTMLInputElement;
    cb.addEventListener('change', () => {
      item.classList.toggle('checked', cb.checked);
    });
    listaDiv.appendChild(item);
  });
}

// Sincronizar selector → input nombre
selector.addEventListener('change', () => {
  const v = selector.value;
  inputNombre.value = v;
  btnDisolver.style.display = v ? 'inline-flex' : 'none';
  renderListaCursos(v);
  if (v) rellenarDatosPack(v);
  else { inputPrecio.value = ''; inputSpid.value = ''; }
});

// Abrir con botón principal
document.getElementById('btn-nuevo-pack')!.addEventListener('click', abrirPanel);
document.getElementById('btn-cerrar-panel')!.addEventListener('click', cerrarPanel);
document.getElementById('btn-cancelar-pack')!.addEventListener('click', cerrarPanel);
overlay.addEventListener('click', cerrarPanel);

// ── Guardar pack ───────────────────────────────────────────────
document.getElementById('btn-guardar-pack')!.addEventListener('click', async () => {
  const nombre = inputNombre.value.trim();
  if (!nombre) { mostrarPanelMsg('Escribe el nombre del pack.', 'error'); return; }

  const packAnterior = selector.value;
  const checks = listaDiv.querySelectorAll<HTMLInputElement>('input[type="checkbox"]');

  const btn = document.getElementById('btn-guardar-pack') as HTMLButtonElement;
  btn.disabled = true; btn.textContent = 'Guardando…';

  const promesas: Promise<any>[] = [];

  checks.forEach(cb => {
    const id = Number(cb.dataset.id);
    const curso = todosLosCursos.find(c => c.id == id);
    if (!curso) return;

    const nuevoPackValor = cb.checked ? nombre : null;
    const packActualCurso = curso.pack ?? null;

    // Solo actualizar si cambia
    const debeActualizar =
      (cb.checked && packActualCurso !== nombre) ||
      (!cb.checked && packActualCurso === packAnterior && packAnterior !== '');

    if (!debeActualizar) return;

    promesas.push(
      fetch('/api/cursos.php', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id:         curso.id,
          titulo:     curso.titulo,
          etiqueta:   curso.etiqueta,
          nivel:      curso.nivel,
          duracion:   curso.duracion,
          activo:     curso.activo,
          pack:       nuevoPackValor,
          pack_color: cb.checked ? (curso.pack_color || null) : null,
          color:      curso.color || null,
        }),
      })
    );
  });

  await Promise.all(promesas);

  // Guardar precio y stripe_price_id del pack en packs.php
  const precio = inputPrecio.value.trim();
  const spid   = inputSpid.value.trim();
  const packBDExistente = packsBD.find(p => p.nombre === nombre || p.etiqueta === nombre);
  const etiquetasPack = [...new Set(
    todosLosCursos.filter((c: any) => c.pack === nombre || listaDiv.querySelector<HTMLInputElement>(`input[data-id="${c.id}"]`)?.checked)
      .map((c: any) => c.etiqueta)
  )].join(',') || nombre;

  if (packBDExistente) {
    await fetch(`/api/packs.php?id=${packBDExistente.id}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: packBDExistente.id, nombre, descripcion: packBDExistente.descripcion,
        precio: precio || null, stripe_price_id: spid || null, etiqueta: packBDExistente.etiqueta, activo: 1 }),
    });
  } else if (precio || spid) {
    await fetch('/api/packs.php', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ nombre, precio: precio || null, stripe_price_id: spid || null, etiqueta: nombre }),
    });
  }
  await cargarPacksBD();

  btn.disabled = false; btn.textContent = 'Guardar pack';
  mostrarPanelMsg(`✓ Pack "${nombre}" guardado.`, 'ok');

  // Recargar lista
  const res  = await fetch('/api/cursos.php');
  const data = await res.json();
  if (data.ok) {
    todosLosCursos = data.cursos;
    construirFiltros();
    renderizarCursos('todos');
    actualizarSelectorPacks();
  }

  setTimeout(cerrarPanel, 1200);
});

// ── Disolver pack ──────────────────────────────────────────────
btnDisolver.addEventListener('click', async () => {
  const nombre = inputNombre.value.trim();
  if (!confirm(`¿Disolver el pack "${nombre}"? Los cursos quedarán sin pack.`)) return;

  btnDisolver.disabled = true;
  const cursosPack = todosLosCursos.filter(c => c.pack === nombre);
  await Promise.all(cursosPack.map(curso =>
    fetch('/api/cursos.php', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: curso.id, titulo: curso.titulo, etiqueta: curso.etiqueta,
        nivel: curso.nivel, duracion: curso.duracion, activo: curso.activo, pack: null, pack_color: null }),
    })
  ));

  btnDisolver.disabled = false;
  const res  = await fetch('/api/cursos.php');
  const data = await res.json();
  if (data.ok) {
    todosLosCursos = data.cursos;
    construirFiltros();
    renderizarCursos('todos');
    actualizarSelectorPacks();
  }
  cerrarPanel();
});

cargarCursos();
</script>
