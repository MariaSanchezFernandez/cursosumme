---
import PlantillaAdmin from '../../../layouts/PlantillaAdmin.astro';
---

<PlantillaAdmin titulo="Alumnos" paginaActual="alumnos">

  <div class="tabla-wrap">
    <div class="tabla-header">
      <span class="tabla-titulo">Todos los alumnos</span>
      <div style="display:flex; gap:0.6rem; align-items:center; flex-wrap:wrap;">
        <div style="position:relative;">
          <svg style="position:absolute;left:0.6rem;top:50%;transform:translateY(-50%);pointer-events:none;" viewBox="0 0 16 16" fill="none" width="13" height="13">
            <circle cx="6.5" cy="6.5" r="4" stroke="#aaa" stroke-width="1.4"/>
            <path d="M10 10l3 3" stroke="#aaa" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          <input id="buscar-alumno" type="text" placeholder="Buscar por nombre o email…"
            style="padding:0.42rem 0.75rem 0.42rem 2rem; border:1px solid #d8e4df; border-radius:8px;
            font-family:inherit; font-size:0.8rem; color:var(--color-text); outline:none;
            background:#fff; width:230px; transition:border-color 0.15s;"
            oninput="filtrarAlumnos()"
            onfocus="this.style.borderColor='var(--color-primary)'"
            onblur="this.style.borderColor='#d8e4df'" />
        </div>
        <a href="/admin/alumnos/crear-alumno" class="btn-admin primario">
          <svg viewBox="0 0 16 16" fill="none">
            <path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          </svg>
          Nuevo alumno
        </a>
      </div>
    </div>

    <!-- Filtros por origen del alumno. La selección se guarda en el
         hash de la URL para que un refresco/compartido mantenga la vista. -->
    <div class="filtros-origen" id="filtros-origen">
      <button type="button" class="chip-filtro activo" data-origen="todos">
        Todos <span class="chip-contador" id="contador-todos">—</span>
      </button>
      <button type="button" class="chip-filtro" data-origen="rocio">
        De Rocío <span class="chip-contador" id="contador-rocio">—</span>
      </button>
      <button type="button" class="chip-filtro" data-origen="compradores">
        Compradores <span class="chip-contador" id="contador-compradores">—</span>
      </button>
    </div>

    <div id="estado-carga" class="alumnos-skel" aria-hidden="true">
      <!-- Skeletons mientras cargan los alumnos -->
      <div class="alumno-skel-row">
        <div class="skeleton skeleton-circle alumno-skel-avatar"></div>
        <div class="alumno-skel-cols">
          <div class="skeleton skeleton-text skeleton-w-75"></div>
          <div class="skeleton skeleton-text-sm skeleton-w-50"></div>
        </div>
      </div>
      <div class="alumno-skel-row">
        <div class="skeleton skeleton-circle alumno-skel-avatar"></div>
        <div class="alumno-skel-cols">
          <div class="skeleton skeleton-text skeleton-w-50"></div>
          <div class="skeleton skeleton-text-sm skeleton-w-75"></div>
        </div>
      </div>
      <div class="alumno-skel-row">
        <div class="skeleton skeleton-circle alumno-skel-avatar"></div>
        <div class="alumno-skel-cols">
          <div class="skeleton skeleton-text skeleton-w-90"></div>
          <div class="skeleton skeleton-text-sm skeleton-w-25"></div>
        </div>
      </div>
      <div class="alumno-skel-row">
        <div class="skeleton skeleton-circle alumno-skel-avatar"></div>
        <div class="alumno-skel-cols">
          <div class="skeleton skeleton-text skeleton-w-50"></div>
          <div class="skeleton skeleton-text-sm skeleton-w-50"></div>
        </div>
      </div>
    </div>

    <table id="tabla-alumnos" style="display:none;">
      <thead>
        <tr>
          <th style="width:44px;"></th>
          <th>Nombre</th>
          <th class="col-email">Email</th>
          <th>Cursos</th>
          <th class="col-alta">Alta</th>
          <th class="col-acceso">Acceso hasta</th>
          <th></th>
        </tr>
      </thead>
      <tbody id="tbody-alumnos"></tbody>
    </table>

    <div id="estado-vacio" class="estado-vacio" style="display:none;">
      <svg viewBox="0 0 48 48" fill="none" width="48" height="48" aria-hidden="true">
        <circle cx="24" cy="24" r="20" stroke="#c8dcd3" stroke-width="2"/>
        <circle cx="24" cy="20" r="5" stroke="#c8dcd3" stroke-width="1.8"/>
        <path d="M13 37c0-6.1 4.9-10 11-10s11 3.9 11 10" stroke="#c8dcd3" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <p class="estado-vacio-titulo">Aún no hay alumnos</p>
      <p class="estado-vacio-sub">Crea el primero para que puedan acceder a los cursos</p>
      <a href="/admin/alumnos/crear-alumno" class="estado-vacio-cta">Crear primer alumno</a>
    </div>
  </div>

</PlantillaAdmin>

<script>
const estadoCarga = document.getElementById('estado-carga')!;
const tabla       = document.getElementById('tabla-alumnos')!;
const tbody       = document.getElementById('tbody-alumnos')!;
const estadoVacio = document.getElementById('estado-vacio')!;

async function cargarAlumnos() {
  try {
    const res  = await fetch('/api/alumnos.php');
    const data = await res.json();
    estadoCarga.style.display = 'none';

    if (!data.ok || data.alumnos.length === 0) {
      estadoVacio.style.display = 'block';
      return;
    }

    tabla.style.display = 'table';
    const hoy = new Date(); hoy.setHours(0,0,0,0);
    tbody.innerHTML = data.alumnos.map((a: any) => {
      const fechaAlta = a.fecha_alta ? new Date(a.fecha_alta).toLocaleDateString('es-ES') : '—';

      let badgeBaja = '—';
      if (a.fecha_baja) {
        const fin  = new Date(a.fecha_baja + 'T00:00:00');
        const dias = Math.round((fin.getTime() - hoy.getTime()) / 86400000);
        const fechaStr = fin.toLocaleDateString('es-ES');
        if (dias < 0) {
          badgeBaja = `<span style="font-size:0.72rem;font-weight:700;padding:0.2rem 0.55rem;border-radius:12px;background:#fdf0f0;color:#c33;">Expirada</span>`;
        } else if (dias <= 30) {
          badgeBaja = `<span style="font-size:0.72rem;font-weight:700;padding:0.2rem 0.55rem;border-radius:12px;background:#fff8e6;color:#a06010;" title="${fechaStr}">${dias}d restantes</span>`;
        } else {
          badgeBaja = `<span style="font-size:0.72rem;color:#888;">${fechaStr}</span>`;
        }
      }

      const avatarStyle = 'width:36px;height:36px;border-radius:50%;object-fit:cover;border:2px solid #e4ede9;display:block;';
      const avatarHtml = a.foto_perfil
        ? `<img src="${a.foto_perfil}" alt="" style="${avatarStyle}" />`
        : `<div style="width:36px;height:36px;border-radius:50%;background:var(--color-light);display:flex;align-items:center;justify-content:center;font-size:0.78rem;font-weight:800;color:var(--color-text);border:2px solid #e4ede9;flex-shrink:0;">${(a.nombre?.[0] || '?').toUpperCase()}</div>`;

      // origen: 'rocio' si el admin lo marcó explícitamente; 'comprador'
      // en cualquier otro caso (alumno entrado vía Stripe Checkout o
      // creado a mano sin marcar la casilla "alumna de Rocío").
      const esRocio = Number(a.es_alumna_rocio) === 1;
      const origen  = esRocio ? 'rocio' : 'comprador';

      return `
        <tr data-origen="${origen}">
          <td style="padding:0.5rem 0.75rem;">${avatarHtml}</td>
          <td class="td-nombre">
            ${a.nombre} ${a.apellidos}
            <span class="td-email-movil">${a.email}</span>
          </td>
          <td class="td-email col-email">${a.email}</td>
          <td>
            ${a.num_cursos > 0
              ? `<span class="badge-modulos">${a.num_cursos}</span>`
              : `<span class="badge-modulos vacio">—</span>`}
          </td>
          <td class="col-alta">${fechaAlta}</td>
          <td class="col-acceso">${badgeBaja}</td>
          <td>
            <a href="/admin/alumnos/detalle?id=${a.id}" class="btn-admin">
              Ver detalle
              <svg viewBox="0 0 16 16" fill="none">
                <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </td>
        </tr>
      `;
    }).join('');
    // Aplicar filtro inicial (hash) + calcular contadores de los chips.
    filtrarAlumnos();
  } catch {
    estadoCarga.textContent = 'Error al cargar los alumnos.';
  }
}

cargarAlumnos();

// ── Filtros por origen (chips) ─────────────────────────────
type OrigenFiltro = 'todos' | 'rocio' | 'compradores';
let origenActivo: OrigenFiltro = 'todos';

// Recuperar filtro previo de la URL (hash) para que un refresco mantenga la vista.
const hashInicial = location.hash.replace('#', '') as OrigenFiltro;
if (['rocio', 'compradores'].includes(hashInicial)) {
  origenActivo = hashInicial;
}

document.querySelectorAll<HTMLButtonElement>('.chip-filtro').forEach(btn => {
  if (btn.dataset.origen === origenActivo) btn.classList.add('activo');
  else btn.classList.remove('activo');
  btn.addEventListener('click', () => {
    origenActivo = (btn.dataset.origen as OrigenFiltro) || 'todos';
    document.querySelectorAll('.chip-filtro').forEach(b => b.classList.remove('activo'));
    btn.classList.add('activo');
    // Reflejar en hash: vacío para "todos" para no ensuciar la URL.
    if (origenActivo === 'todos') history.replaceState(null, '', location.pathname + location.search);
    else history.replaceState(null, '', '#' + origenActivo);
    filtrarAlumnos();
  });
});

function filtrarAlumnos() {
  const q = (document.getElementById('buscar-alumno') as HTMLInputElement).value.toLowerCase().trim();
  const filas = tbody.querySelectorAll<HTMLTableRowElement>('tr');
  let visibles = 0;
  let totRocio = 0, totComp = 0;
  filas.forEach(fila => {
    const nombre = fila.querySelector('.td-nombre')?.textContent?.toLowerCase() || '';
    const email  = fila.querySelector('.td-email')?.textContent?.toLowerCase()  || '';
    const origen = fila.dataset.origen as OrigenFiltro | undefined;
    if (origen === 'rocio') totRocio++;
    else if (origen === 'comprador') totComp++;

    const coincideBusqueda = !q || nombre.includes(q) || email.includes(q);
    const coincideOrigen   = origenActivo === 'todos'
      || (origenActivo === 'rocio' && origen === 'rocio')
      || (origenActivo === 'compradores' && origen === 'comprador');
    const visible = coincideBusqueda && coincideOrigen;
    fila.style.display = visible ? '' : 'none';
    if (visible) visibles++;
  });

  // Contadores en los chips
  const totTotal = totRocio + totComp;
  const setContador = (id: string, n: number) => {
    const el = document.getElementById(id);
    if (el) el.textContent = String(n);
  };
  setContador('contador-todos', totTotal);
  setContador('contador-rocio', totRocio);
  setContador('contador-compradores', totComp);

  // "Sin resultados" si la combinación búsqueda + filtro no da nada.
  let sinRes = document.getElementById('sin-resultados');
  if (!sinRes) {
    sinRes = document.createElement('div');
    sinRes.id = 'sin-resultados';
    sinRes.style.cssText = 'padding:1.5rem; text-align:center; color:#aaa; font-size:0.85rem;';
    tabla.after(sinRes);
  }
  if (visibles === 0 && (q || origenActivo !== 'todos')) {
    sinRes.textContent = q
      ? 'No hay alumnos que coincidan con la búsqueda.'
      : (origenActivo === 'rocio'
          ? 'No hay alumnos marcados como de Rocío.'
          : 'Aún no hay compradores registrados.');
    sinRes.style.display = 'block';
  } else {
    sinRes.style.display = 'none';
  }
}

(window as any).filtrarAlumnos = filtrarAlumnos;
</script>

<style>
  /* Chips de filtro por origen */
  .filtros-origen {
    display: flex;
    gap: 0.5rem;
    padding: 0.85rem 1.5rem;
    border-bottom: 1px solid #eef3f0;
    flex-wrap: wrap;
  }
  .chip-filtro {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.85rem;
    border: 1px solid #d8e4df;
    border-radius: 20px;
    background: #fff;
    color: var(--color-text-muted);
    font-family: inherit;
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.12s, border-color 0.12s, color 0.12s;
  }
  .chip-filtro:hover {
    background: #f4f9f6;
    border-color: var(--color-primary);
    color: var(--color-text);
  }
  .chip-filtro.activo {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #fff;
  }
  .chip-contador {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    padding: 0 0.4rem;
    height: 18px;
    border-radius: 10px;
    background: rgba(0, 0, 0, 0.06);
    font-size: 0.7rem;
    font-weight: 700;
  }
  .chip-filtro.activo .chip-contador {
    background: rgba(255, 255, 255, 0.22);
    color: #fff;
  }

  /* Skeletons de filas de alumno mientras carga la tabla */
  .alumnos-skel {
    padding: 0.5rem 0;
  }
  .alumno-skel-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1.5rem;
    border-bottom: 1px solid #eef3f0;
  }
  .alumno-skel-avatar {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
  }
  .alumno-skel-cols {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  /* Email apilado bajo el nombre — solo visible en móvil.
     Las filas de la tabla se inyectan por JS en runtime y NO llevan el
     marcador de scope de Astro, así que estas reglas que tocan celdas
     deben ir con :global() ancladas bajo #tabla-alumnos (elemento estático,
     sí scoped) para aplicarse a las celdas inyectadas sin filtrarse a otras
     páginas. Sin esto, el email se mostraba pegado al nombre en escritorio. */
  #tabla-alumnos :global(.td-email-movil) {
    display: none;
    font-size: 0.74rem;
    color: var(--color-text-muted);
    margin-top: 0.15rem;
  }

  /* ── Responsive móvil ── */
  @media (max-width: 768px) {
    /* Ocultamos columnas secundarias para que la tabla quepa
       en pantalla sin scroll horizontal */
    #tabla-alumnos :global(.col-email),
    #tabla-alumnos :global(.col-alta),
    #tabla-alumnos :global(.col-acceso) {
      display: none;
    }

    /* El email pasa a mostrarse bajo el nombre */
    #tabla-alumnos :global(.td-email-movil) { display: block; }

    /* Sin min-width fijo: la tabla se adapta al ancho disponible */
    #tabla-alumnos { min-width: 0; }

    /* La fila de búsqueda + botón ocupa el ancho completo y se apila */
    #buscar-alumno { width: 100% !important; box-sizing: border-box; }
    .tabla-header { flex-wrap: wrap; gap: 0.75rem; }
    .tabla-header > div { width: 100%; }
  }
</style>
