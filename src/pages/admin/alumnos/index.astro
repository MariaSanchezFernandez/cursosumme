---
import PlantillaAdmin from '../../../layouts/PlantillaAdmin.astro';
---

<PlantillaAdmin titulo="Alumnos" paginaActual="alumnos">

  <div class="tabla-wrap">
    <div class="tabla-header">
      <span class="tabla-titulo">Todos los alumnos</span>
      <div style="display:flex; gap:0.6rem; align-items:center; flex-wrap:wrap;">
        <div style="position:relative;">
          <svg style="position:absolute;left:0.6rem;top:50%;transform:translateY(-50%);pointer-events:none;" viewBox="0 0 16 16" fill="none" width="13" height="13">
            <circle cx="6.5" cy="6.5" r="4" stroke="#aaa" stroke-width="1.4"/>
            <path d="M10 10l3 3" stroke="#aaa" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          <input id="buscar-alumno" type="text" placeholder="Buscar por nombre o email…"
            style="padding:0.42rem 0.75rem 0.42rem 2rem; border:1px solid #d8e4df; border-radius:8px;
            font-family:inherit; font-size:0.8rem; color:var(--color-text); outline:none;
            background:#fff; width:230px; transition:border-color 0.15s;"
            oninput="filtrarAlumnos()"
            onfocus="this.style.borderColor='var(--color-primary)'"
            onblur="this.style.borderColor='#d8e4df'" />
        </div>
        <a href="/admin/alumnos/crear-alumno" class="btn-admin primario">
          <svg viewBox="0 0 16 16" fill="none">
            <path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          </svg>
          Nuevo alumno
        </a>
      </div>
    </div>

    <div id="estado-carga" class="alumnos-skel" aria-hidden="true">
      <!-- Skeletons mientras cargan los alumnos -->
      <div class="alumno-skel-row">
        <div class="skeleton skeleton-circle alumno-skel-avatar"></div>
        <div class="alumno-skel-cols">
          <div class="skeleton skeleton-text skeleton-w-75"></div>
          <div class="skeleton skeleton-text-sm skeleton-w-50"></div>
        </div>
      </div>
      <div class="alumno-skel-row">
        <div class="skeleton skeleton-circle alumno-skel-avatar"></div>
        <div class="alumno-skel-cols">
          <div class="skeleton skeleton-text skeleton-w-50"></div>
          <div class="skeleton skeleton-text-sm skeleton-w-75"></div>
        </div>
      </div>
      <div class="alumno-skel-row">
        <div class="skeleton skeleton-circle alumno-skel-avatar"></div>
        <div class="alumno-skel-cols">
          <div class="skeleton skeleton-text skeleton-w-90"></div>
          <div class="skeleton skeleton-text-sm skeleton-w-25"></div>
        </div>
      </div>
      <div class="alumno-skel-row">
        <div class="skeleton skeleton-circle alumno-skel-avatar"></div>
        <div class="alumno-skel-cols">
          <div class="skeleton skeleton-text skeleton-w-50"></div>
          <div class="skeleton skeleton-text-sm skeleton-w-50"></div>
        </div>
      </div>
    </div>

    <table id="tabla-alumnos" style="display:none;">
      <thead>
        <tr>
          <th style="width:44px;"></th>
          <th>Nombre</th>
          <th>Email</th>
          <th>Cursos</th>
          <th>Alta</th>
          <th>Acceso hasta</th>
          <th></th>
        </tr>
      </thead>
      <tbody id="tbody-alumnos"></tbody>
    </table>

    <div id="estado-vacio" style="display:none; padding:2rem 1.5rem; color:#aaa; font-size:0.85rem;">
      No hay alumnos todavía.
      <a href="/admin/alumnos/crear-alumno" style="color:inherit; font-weight:600;">Crear el primero →</a>
    </div>
  </div>

</PlantillaAdmin>

<script>
const estadoCarga = document.getElementById('estado-carga')!;
const tabla       = document.getElementById('tabla-alumnos')!;
const tbody       = document.getElementById('tbody-alumnos')!;
const estadoVacio = document.getElementById('estado-vacio')!;

async function cargarAlumnos() {
  try {
    const res  = await fetch('/api/alumnos.php');
    const data = await res.json();
    estadoCarga.style.display = 'none';

    if (!data.ok || data.alumnos.length === 0) {
      estadoVacio.style.display = 'block';
      return;
    }

    tabla.style.display = 'table';
    const hoy = new Date(); hoy.setHours(0,0,0,0);
    tbody.innerHTML = data.alumnos.map((a: any) => {
      const fechaAlta = a.fecha_alta ? new Date(a.fecha_alta).toLocaleDateString('es-ES') : '—';

      let badgeBaja = '—';
      if (a.fecha_baja) {
        const fin  = new Date(a.fecha_baja + 'T00:00:00');
        const dias = Math.round((fin.getTime() - hoy.getTime()) / 86400000);
        const fechaStr = fin.toLocaleDateString('es-ES');
        if (dias < 0) {
          badgeBaja = `<span style="font-size:0.72rem;font-weight:700;padding:0.2rem 0.55rem;border-radius:12px;background:#fdf0f0;color:#c33;">Expirada</span>`;
        } else if (dias <= 30) {
          badgeBaja = `<span style="font-size:0.72rem;font-weight:700;padding:0.2rem 0.55rem;border-radius:12px;background:#fff8e6;color:#a06010;" title="${fechaStr}">${dias}d restantes</span>`;
        } else {
          badgeBaja = `<span style="font-size:0.72rem;color:#888;">${fechaStr}</span>`;
        }
      }

      const avatarStyle = 'width:36px;height:36px;border-radius:50%;object-fit:cover;border:2px solid #e4ede9;display:block;';
      const avatarHtml = a.foto_perfil
        ? `<img src="${a.foto_perfil}" alt="" style="${avatarStyle}" />`
        : `<div style="width:36px;height:36px;border-radius:50%;background:var(--color-light);display:flex;align-items:center;justify-content:center;font-size:0.78rem;font-weight:800;color:var(--color-text);border:2px solid #e4ede9;flex-shrink:0;">${(a.nombre?.[0] || '?').toUpperCase()}</div>`;

      return `
        <tr>
          <td style="padding:0.5rem 0.75rem;">${avatarHtml}</td>
          <td class="td-nombre">${a.nombre} ${a.apellidos}</td>
          <td class="td-email">${a.email}</td>
          <td>
            ${a.num_cursos > 0
              ? `<span class="badge-modulos">${a.num_cursos}</span>`
              : `<span class="badge-modulos vacio">—</span>`}
          </td>
          <td>${fechaAlta}</td>
          <td>${badgeBaja}</td>
          <td>
            <a href="/admin/alumnos/detalle?id=${a.id}" class="btn-admin">
              Ver detalle
              <svg viewBox="0 0 16 16" fill="none">
                <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </td>
        </tr>
      `;
    }).join('');
  } catch {
    estadoCarga.textContent = 'Error al cargar los alumnos.';
  }
}

cargarAlumnos();

function filtrarAlumnos() {
  const q = (document.getElementById('buscar-alumno') as HTMLInputElement).value.toLowerCase().trim();
  const filas = tbody.querySelectorAll('tr');
  let visibles = 0;
  filas.forEach(fila => {
    const nombre = fila.querySelector('.td-nombre')?.textContent?.toLowerCase() || '';
    const email  = fila.querySelector('.td-email')?.textContent?.toLowerCase()  || '';
    const coincide = !q || nombre.includes(q) || email.includes(q);
    (fila as HTMLElement).style.display = coincide ? '' : 'none';
    if (coincide) visibles++;
  });
  // Mostrar "sin resultados" si no hay coincidencias
  let sinRes = document.getElementById('sin-resultados');
  if (!sinRes) {
    sinRes = document.createElement('div');
    sinRes.id = 'sin-resultados';
    sinRes.style.cssText = 'padding:1.5rem; text-align:center; color:#aaa; font-size:0.85rem;';
    sinRes.textContent = 'No hay alumnos que coincidan con la búsqueda.';
    tabla.after(sinRes);
  }
  sinRes.style.display = (q && visibles === 0) ? 'block' : 'none';
}

(window as any).filtrarAlumnos = filtrarAlumnos;
</script>

<style>
  /* Skeletons de filas de alumno mientras carga la tabla */
  .alumnos-skel {
    padding: 0.5rem 0;
  }
  .alumno-skel-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1.5rem;
    border-bottom: 1px solid #eef3f0;
  }
  .alumno-skel-avatar {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
  }
  .alumno-skel-cols {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
</style>
