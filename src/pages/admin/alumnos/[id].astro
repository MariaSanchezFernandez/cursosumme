---
import PlantillaAdmin from '../../../layouts/PlantillaAdmin.astro';
import { getAlumnos, getUsuarioById } from '../../../data/usuarios';
import { cursos } from '../../../data/cursos';

export function getStaticPaths() {
  return getAlumnos().map(a => ({ params: { id: a.id } }));
}

const { id } = Astro.params;
const alumno = getUsuarioById(id!);
if (!alumno) return Astro.redirect('/admin/alumnos');

const acentoColors: Record<string, string> = {
  c1: '#b5d8cc',
  c2: '#b5c8e8',
  c3: '#d4c8e8',
  c4: '#e8d4b5',
};
---

<PlantillaAdmin titulo={`${alumno.nombre} ${alumno.apellidos}`} paginaActual="alumnos">

  <!-- Cabecera de perfil -->
  <div class="perfil-cabecera">
    <div class="perfil-avatar">
      {alumno.nombre.charAt(0)}
    </div>
    <div>
      <p class="perfil-nombre">{alumno.nombre} {alumno.apellidos}</p>
      <p class="perfil-email">{alumno.email}</p>
    </div>
  </div>

  <!-- Módulos asignados -->
  <p class="seccion-titulo">Módulos asignados</p>

  <div class="modulos-grid" id="modulos-grid" data-asignados={JSON.stringify(alumno.modulosAsignados)}>
    {cursos.map(curso => {
      const asignado = alumno.modulosAsignados.includes(curso.id);
      return (
        <div
          class={`modulo-item${asignado ? ' asignado' : ''}`}
          data-id={curso.id}
          role="button"
          tabindex="0"
        >
          <div class="modulo-checkbox">
            <svg viewBox="0 0 12 12" fill="none">
              <path d="M2 6l3 3 5-5" stroke="#fff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <div class="modulo-acento" style={`background:${acentoColors[curso.acento] ?? '#ddd'}`}></div>
          <div class="modulo-info">
            <p class="modulo-titulo">{curso.titulo}</p>
            <p class="modulo-meta">{curso.etiqueta} · {curso.duracion} · {curso.nivel}</p>
          </div>
        </div>
      );
    })}
  </div>

  <!-- Botón guardar -->
  <div style="margin-top:1.5rem; display:flex; gap:0.75rem; align-items:center;">
    <button id="btn-guardar" class="btn-admin primario">
      Guardar cambios
    </button>
    <a href="/admin/alumnos" class="btn-admin">Volver</a>
    <span id="msg-guardado" style="font-size:0.8rem; color:#2e7d55; display:none;">✓ Cambios guardados</span>
  </div>

</PlantillaAdmin>

<script>
  const grid = document.getElementById('modulos-grid') as HTMLDivElement;
  const btnGuardar = document.getElementById('btn-guardar') as HTMLButtonElement;
  const msgGuardado = document.getElementById('msg-guardado') as HTMLSpanElement;

  // Toggle on click or keyboard
  grid.addEventListener('click', (e) => {
    const item = (e.target as HTMLElement).closest('.modulo-item') as HTMLElement | null;
    if (!item) return;
    item.classList.toggle('asignado');
  });

  grid.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      const item = (e.target as HTMLElement).closest('.modulo-item') as HTMLElement | null;
      if (item) item.classList.toggle('asignado');
    }
  });

  btnGuardar.addEventListener('click', () => {
    msgGuardado.style.display = 'inline';
    setTimeout(() => { msgGuardado.style.display = 'none'; }, 2500);
  });
</script>
