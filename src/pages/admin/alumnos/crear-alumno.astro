---
import PlantillaAdmin from '../../../layouts/PlantillaAdmin.astro';
---

<PlantillaAdmin titulo="Crear alumno" paginaActual="alumnos">

  <div style="max-width: 620px;">

    <div class="form-admin" id="form-wrap">
      <form id="form-nuevo-alumno">

        <p class="seccion-titulo" style="margin-bottom:1.25rem;">Datos del alumno</p>

        <div class="grid-2col">
          <div class="form-grupo">
            <label class="form-label" for="nombre">Nombre</label>
            <input class="form-input" type="text" id="nombre" name="nombre" placeholder="Ej. Ana" required />
          </div>
          <div class="form-grupo">
            <label class="form-label" for="apellidos">Apellidos</label>
            <input class="form-input" type="text" id="apellidos" name="apellidos" placeholder="Ej. García López" required />
          </div>
        </div>

        <div class="form-grupo">
          <label class="form-label" for="email">Email</label>
          <input class="form-input" type="email" id="email" name="email" placeholder="alumna@ejemplo.com" required />
        </div>

        <div class="grid-2col">
          <div class="form-grupo" style="margin:0;">
            <label class="form-label" for="fechaAlta">Fecha de alta</label>
            <input class="form-input" type="date" id="fechaAlta" name="fechaAlta" required />
          </div>
          <div class="form-grupo" style="margin:0;">
            <label class="form-label" for="fechaBaja">
              Fecha de baja
              <span style="font-weight:400; color:#aaa; font-size:0.76rem;">(acceso hasta)</span>
            </label>
            <input class="form-input" type="date" id="fechaBaja" name="fechaBaja" required />
          </div>
        </div>

        <div class="form-grupo" style="margin-top:0.25rem;">
          <label class="form-label">
            Contraseña inicial
            <span style="font-weight:400; color:#aaa; font-size:0.78rem; margin-left:0.3rem;">(puede cambiarla después)</span>
          </label>
          <div style="padding:0.6rem 0.85rem; background:#f7faf9; border:1px solid #e8eeec;
            border-radius:7px; font-size:0.82rem; color:#666; font-family:monospace;">
            Umme@2024
          </div>
        </div>

        <!-- Cursos / packs -->
        <div class="form-grupo" style="margin-top:0.5rem;">
          <label class="form-label">Asignar cursos</label>
          <div id="cursos-carga" style="font-size:0.82rem; color:#aaa; padding:0.5rem 0;">Cargando cursos…</div>
          <div id="cursos-container" style="display:none;"></div>
          <div id="cursos-vacio" style="display:none; font-size:0.82rem; color:#aaa; padding:0.5rem 0;">
            No hay cursos activos. <a href="/admin/cursos/crear-curso" style="color:inherit; font-weight:600;">Crea uno primero →</a>
          </div>
        </div>

        <div id="msg-error" style="display:none; padding:0.75rem 1rem; background:#fdf0f0;
          border:1px solid #f5c6c6; border-radius:7px; font-size:0.82rem; color:#a33; margin-bottom:1rem;"></div>

        <div style="display:flex; gap:0.75rem; margin-top:0.5rem;">
          <button type="submit" id="btn-crear" class="btn-admin primario" style="flex:1; justify-content:center;">
            Crear alumno
          </button>
          <a href="/admin/alumnos" class="btn-admin" style="justify-content:center;">Cancelar</a>
        </div>
      </form>
    </div>

    <div id="aviso-creado" style="display:none; margin-top:1.25rem; padding:1rem 1.25rem;
      background:#f0faf5; border:1px solid #b6e0cc; border-radius:8px; font-size:0.85rem; color:#2e7d55;">
      ✓ Alumno creado correctamente.
      <br/><a href="/admin/alumnos" style="color:inherit; font-weight:600; margin-top:0.4rem; display:inline-block;">
        ← Volver a la lista
      </a>
    </div>

  </div>

</PlantillaAdmin>

<style is:global>
.pack-grupo { margin-bottom: 1.25rem; }
.pack-grupo-cabecera {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem 1rem;
  background: var(--color-light);
  border: 1.5px solid var(--color-primary);
  border-radius: 10px 10px 0 0;
  margin-bottom: -1px;
}
.pack-grupo-nombre {
  font-size: 0.85rem;
  font-weight: 800;
  flex: 1;
  color: var(--color-text);
}
.pack-grupo-count {
  font-size: 0.72rem;
  color: var(--color-text-muted);
}
.btn-sel-pack {
  font-size: 0.72rem;
  padding: 0.25rem 0.65rem;
  height: auto;
  border-radius: 6px;
  white-space: nowrap;
}
.pack-grupo .modulo-item { border-radius: 0; border-top: none; }
.pack-grupo .modulo-item:last-child { border-radius: 0 0 10px 10px; }
.pack-grupo-solo { margin-bottom: 0.5rem; }
.pack-grupo-solo-label {
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: #bbb;
  margin: 1rem 0 0.5rem;
}

.grid-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
@media (max-width: 640px) {
  .grid-2col { grid-template-columns: 1fr; }
}
</style>

<script>
const acentos = ['#b5d8cc','#b5c8e8','#d4c8e8','#e8d4b5','#e8c8b5','#c8e8b5'];
const cursosSeleccionados = new Set<number>();

async function cargarCursos() {
  try {
    const res  = await fetch('/api/cursos.php');
    const data = await res.json();

    document.getElementById('cursos-carga')!.style.display = 'none';

    const activos = (data.cursos || []).filter((c: any) => c.activo == 1);
    if (!data.ok || activos.length === 0) {
      document.getElementById('cursos-vacio')!.style.display = 'block';
      return;
    }

    const container = document.getElementById('cursos-container')!;
    container.style.display = 'block';
    renderCursosConPacks(activos, new Set(), container);

  } catch {
    document.getElementById('cursos-carga')!.textContent = 'Error al cargar los cursos.';
  }
}

function renderCursosConPacks(cursos: any[], idsAsignados: Set<number>, container: HTMLElement) {
  container.innerHTML = '';

  // Agrupar
  const grupos = new Map<string, any[]>();
  for (const c of cursos) {
    const key = c.pack || '';
    if (!grupos.has(key)) grupos.set(key, []);
    grupos.get(key)!.push(c);
  }

  let idxGlobal = 0;
  const hayPacks = [...grupos.keys()].some(k => k !== '');

  grupos.forEach((lista, pack) => {
    const esPack = pack !== '';

    if (esPack) {
      const grupo = document.createElement('div');
      grupo.className = 'pack-grupo modulos-grid';

      // Cabecera del pack con botón "Seleccionar pack"
      const cab = document.createElement('div');
      cab.className = 'pack-grupo-cabecera';
      cab.innerHTML = `
        <svg viewBox="0 0 18 18" fill="none" style="width:16px;height:16px;flex-shrink:0;">
          <rect x="1" y="5" width="16" height="11" rx="2" stroke="var(--color-primary)" stroke-width="1.6"/>
          <path d="M6 5V4a3 3 0 016 0v1" stroke="var(--color-primary)" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
        <span class="pack-grupo-nombre">${pack}</span>
        <span class="pack-grupo-count">${lista.length} curso${lista.length !== 1 ? 's' : ''}</span>
        <button type="button" class="btn-admin btn-sel-pack">Seleccionar pack</button>
      `;

      const btnSel = cab.querySelector('.btn-sel-pack') as HTMLButtonElement;
      btnSel.addEventListener('click', () => {
        const todosOn = lista.every(c => cursosSeleccionados.has(Number(c.id)));
        lista.forEach(c => {
          const id = Number(c.id);
          const item = grupo.querySelector<HTMLElement>(`[data-curso-id="${id}"]`);
          if (todosOn) {
            cursosSeleccionados.delete(id);
            item?.classList.remove('asignado');
          } else {
            cursosSeleccionados.add(id);
            item?.classList.add('asignado');
          }
        });
        actualizarBtnPack(btnSel, lista);
      });

      grupo.appendChild(cab);

      lista.forEach(curso => {
        const asignado = idsAsignados.has(Number(curso.id));
        if (asignado) cursosSeleccionados.add(Number(curso.id));
        grupo.appendChild(crearItemCurso(curso, asignado, idxGlobal++, btnSel, lista));
      });

      actualizarBtnPack(btnSel, lista);
      container.appendChild(grupo);

    } else {
      if (hayPacks && lista.length > 0) {
        const lbl = document.createElement('p');
        lbl.className = 'pack-grupo-solo-label';
        lbl.textContent = 'Cursos individuales';
        container.appendChild(lbl);
      }
      const grid = document.createElement('div');
      grid.className = 'modulos-grid pack-grupo-solo';
      lista.forEach(curso => {
        const asignado = idsAsignados.has(Number(curso.id));
        if (asignado) cursosSeleccionados.add(Number(curso.id));
        grid.appendChild(crearItemCurso(curso, asignado, idxGlobal++, null, []));
      });
      container.appendChild(grid);
    }
  });
}

function actualizarBtnPack(btn: HTMLButtonElement, lista: any[]) {
  const todosOn = lista.every(c => cursosSeleccionados.has(Number(c.id)));
  btn.textContent = todosOn ? 'Quitar pack' : 'Seleccionar pack';
  btn.style.background = todosOn ? 'var(--color-primary)' : '';
  btn.style.borderColor = todosOn ? 'var(--color-primary)' : '';
  btn.style.color = todosOn ? '#1a2e28' : '';
}

function crearItemCurso(curso: any, asignado: boolean, idx: number, btnPack: HTMLButtonElement | null, packLista: any[]): HTMLElement {
  const item = document.createElement('div');
  item.className       = `modulo-item${asignado ? ' asignado' : ''}`;
  item.dataset.cursoId = String(curso.id);
  item.innerHTML = `
    <div class="modulo-checkbox">
      <svg viewBox="0 0 11 9" fill="none">
        <path d="M1 4l3 3 6-6" stroke="#fff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <div class="modulo-acento" style="background:${curso.color || curso.pack_color || acentos[idx % acentos.length]}"></div>
    <div class="modulo-info">
      <p class="modulo-titulo">${curso.titulo}</p>
      <p class="modulo-meta">${curso.etiqueta} · ${curso.nivel}${curso.duracion ? ' · ' + curso.duracion : ''}</p>
    </div>
  `;

  item.addEventListener('click', () => {
    const id = Number(item.dataset.cursoId);
    if (cursosSeleccionados.has(id)) {
      cursosSeleccionados.delete(id);
      item.classList.remove('asignado');
    } else {
      cursosSeleccionados.add(id);
      item.classList.add('asignado');
    }
    if (btnPack) actualizarBtnPack(btnPack, packLista);
  });

  return item;
}

cargarCursos();

// Fechas por defecto: alta = hoy, baja = hoy + 1 año
const hoy = new Date();
const bajaPorDefecto = new Date(hoy);
bajaPorDefecto.setFullYear(bajaPorDefecto.getFullYear() + 1);
(document.getElementById('fechaAlta') as HTMLInputElement).value = hoy.toISOString().split('T')[0];
(document.getElementById('fechaBaja') as HTMLInputElement).value = bajaPorDefecto.toISOString().split('T')[0];

// Al cambiar fecha de alta, recalcular baja automáticamente si no se ha tocado
const inpAlta = document.getElementById('fechaAlta') as HTMLInputElement;
const inpBaja = document.getElementById('fechaBaja') as HTMLInputElement;
let bajaEditadaManualmente = false;
inpBaja.addEventListener('change', () => { bajaEditadaManualmente = true; });
inpAlta.addEventListener('change', () => {
  if (!bajaEditadaManualmente && inpAlta.value) {
    const nueva = new Date(inpAlta.value);
    nueva.setFullYear(nueva.getFullYear() + 1);
    inpBaja.value = nueva.toISOString().split('T')[0];
  }
});

// ── Enviar formulario ─────────────────────────────────────────
const form     = document.getElementById('form-nuevo-alumno') as HTMLFormElement;
const formWrap = document.getElementById('form-wrap') as HTMLDivElement;
const aviso    = document.getElementById('aviso-creado') as HTMLDivElement;
const btnCrear = document.getElementById('btn-crear') as HTMLButtonElement;
const msgError = document.getElementById('msg-error') as HTMLDivElement;

form.addEventListener('submit', async (e) => {
  e.preventDefault();
  btnCrear.disabled    = true;
  btnCrear.textContent = 'Creando…';
  msgError.style.display = 'none';

  const datos = {
    nombre:     (document.getElementById('nombre')    as HTMLInputElement).value.trim(),
    apellidos:  (document.getElementById('apellidos') as HTMLInputElement).value.trim(),
    email:      (document.getElementById('email')     as HTMLInputElement).value.trim().toLowerCase(),
    fecha_alta: (document.getElementById('fechaAlta') as HTMLInputElement).value,
    fecha_baja: (document.getElementById('fechaBaja') as HTMLInputElement).value,
    cursos:     Array.from(cursosSeleccionados),
  };

  try {
    const res  = await fetch('/api/alumnos.php', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify(datos),
    });
    const data = await res.json();

    if (!data.ok) {
      msgError.textContent   = data.mensaje || 'Error al crear el alumno';
      msgError.style.display = 'block';
      btnCrear.disabled      = false;
      btnCrear.textContent   = 'Crear alumno';
      (window as any).logAppError?.('crear_alumno', 'Servidor rechazó creación de alumno', { detalle: data.mensaje || ('HTTP ' + res.status) });
      return;
    }

    formWrap.style.display = 'none';
    aviso.style.display    = 'block';
  } catch (err: any) {
    msgError.textContent   = 'Error de conexión. Inténtalo de nuevo.';
    msgError.style.display = 'block';
    btnCrear.disabled      = false;
    btnCrear.textContent   = 'Crear alumno';
    (window as any).logAppError?.('crear_alumno', 'Error de red al crear alumno', { detalle: err?.message, stack: err?.stack });
  }
});
</script>
