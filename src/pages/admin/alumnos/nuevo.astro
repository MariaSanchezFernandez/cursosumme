---
import PlantillaAdmin from '../../../layouts/PlantillaAdmin.astro';
---

<PlantillaAdmin titulo="Nuevo alumno" paginaActual="alumnos">

  <div style="max-width: 560px;">
    <div class="form-admin">
      <form id="form-nuevo-alumno">
        <div class="form-grupo">
          <label class="form-label" for="nombre">Nombre</label>
          <input class="form-input" type="text" id="nombre" name="nombre" placeholder="Ej. Ana" required />
        </div>

        <div class="form-grupo">
          <label class="form-label" for="apellidos">Apellidos</label>
          <input class="form-input" type="text" id="apellidos" name="apellidos" placeholder="Ej. García López" required />
        </div>

        <div class="form-grupo">
          <label class="form-label" for="email">Email</label>
          <input class="form-input" type="email" id="email" name="email" placeholder="alumno@ejemplo.com" required />
        </div>

        <div class="form-grupo">
          <label class="form-label" for="fechaAlta">Fecha de alta</label>
          <input class="form-input" type="date" id="fechaAlta" name="fechaAlta" required />
        </div>

        <div style="display:flex; gap:0.75rem; margin-top:0.5rem;">
          <button type="submit" class="btn-admin primario" style="flex:1; justify-content:center;">
            Crear alumno
          </button>
          <a href="/admin/alumnos" class="btn-admin" style="justify-content:center;">
            Cancelar
          </a>
        </div>
      </form>
    </div>

    <div id="aviso-creado" style="display:none; margin-top:1.25rem; padding:1rem 1.25rem; background:#f0faf5; border:1px solid #b6e0cc; border-radius:8px; font-size:0.85rem; color:#2e7d55;">
      ✓ Alumno creado correctamente. En una versión con base de datos este alumno quedaría guardado.
      <br/><a href="/admin/alumnos" style="color:inherit; font-weight:600; margin-top:0.4rem; display:inline-block;">← Volver a la lista</a>
    </div>
  </div>

</PlantillaAdmin>

<script>
  const form = document.getElementById('form-nuevo-alumno') as HTMLFormElement;
  const aviso = document.getElementById('aviso-creado') as HTMLDivElement;

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    form.style.display = 'none';
    aviso.style.display = 'block';
  });
</script>
