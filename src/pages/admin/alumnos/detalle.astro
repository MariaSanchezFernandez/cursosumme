---
import PlantillaAdmin from '../../../layouts/PlantillaAdmin.astro';
---

<PlantillaAdmin titulo="Detalle alumno" paginaActual="alumnos">

  <div id="msg-global" style="display:none; padding:0.75rem 1rem; border-radius:7px;
    font-size:0.82rem; margin-bottom:1.25rem;"></div>

  <!-- Cabecera perfil -->
  <div class="perfil-cabecera" id="perfil-cabecera" style="display:none;">
    <div class="perfil-avatar" id="perfil-inicial" style="position:relative; overflow:hidden;">?</div>
    <div style="flex:1;">
      <p class="perfil-nombre" id="perfil-nombre">—</p>
      <p class="perfil-email"  id="perfil-email">—</p>
    </div>
  </div>

  <!-- Fechas de acceso -->
  <div id="acceso-wrap" style="display:none; margin-bottom:1.75rem;">
    <p class="seccion-titulo" style="margin-bottom:0.75rem;">Acceso a la plataforma</p>
    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(220px, 1fr)); gap:1rem;">
      <div class="form-grupo" style="margin:0;">
        <label class="form-label">Fecha de alta</label>
        <input class="form-input" type="date" id="inp-fecha-alta" />
      </div>
      <div class="form-grupo" style="margin:0;">
        <label class="form-label">
          Fecha de baja
          <span style="font-weight:400; color:#aaa; font-size:0.76rem;">(acceso hasta)</span>
        </label>
        <input class="form-input" type="date" id="inp-fecha-baja" />
      </div>
    </div>
    <div style="display:flex; align-items:center; gap:0.75rem; margin-top:0.75rem;">
      <button id="btn-guardar-fechas" class="btn-admin primario" style="height:38px; font-size:0.8rem;">
        Guardar fechas
      </button>
      <div id="badge-acceso" style="font-size:0.76rem; font-weight:700; padding:0.3rem 0.75rem;
        border-radius:20px; width:fit-content; white-space:nowrap;"></div>
    </div>
  </div>

  <!-- Cambiar contraseña del alumno -->
  <div id="pwd-wrap" style="display:none; margin-bottom:1.75rem;">
    <p class="seccion-titulo" style="margin-bottom:0.75rem;">Contraseña del alumno</p>
    <p style="font-size:0.78rem; color:#888; margin:0 0 0.6rem;">
      No es posible ver la contraseña actual (está cifrada). Aquí puedes asignar una nueva.
    </p>
    <div style="display:flex; gap:0.6rem; align-items:center; flex-wrap:wrap;">
      <input id="inp-nueva-pwd" type="text" autocomplete="new-password" placeholder="Mínimo 6 caracteres"
        class="form-input" style="max-width:280px; height:38px; font-family:ui-monospace, monospace;" />
      <button id="btn-generar-pwd" class="btn-admin" style="height:38px; font-size:0.78rem;">Generar</button>
      <button id="btn-cambiar-pwd" class="btn-admin primario" style="height:38px; font-size:0.8rem;">Guardar contraseña</button>
    </div>
    <p id="pwd-aviso" style="display:none; font-size:0.78rem; margin-top:0.6rem;
      padding:0.5rem 0.75rem; border-radius:7px; background:#fff8e6; color:#a06010;
      border:1px solid #f3dfb6;"></p>
  </div>

  <!-- Progreso del alumno -->
  <div id="progreso-wrap" style="display:none; margin-bottom:2rem;">
    <p class="seccion-titulo" style="margin-bottom:0.75rem;">Progreso del alumno</p>
    <div id="progreso-lista"></div>
  </div>

  <p class="seccion-titulo">Cursos asignados</p>

  <div id="cursos-carga" style="color:#aaa; font-size:0.85rem; margin-bottom:1rem;">Cargando…</div>

  <div id="cursos-container" style="display:none;"></div>

  <div id="cursos-vacio" style="display:none; font-size:0.85rem; color:#aaa; margin-bottom:1rem;">
    No hay cursos disponibles todavía.
  </div>

  <div style="margin-top:1.5rem; display:flex; gap:0.75rem; align-items:center; flex-wrap:wrap;">
    <button id="btn-guardar" class="btn-admin primario" style="display:none;">Guardar cambios</button>
    <button id="btn-entrar-como" class="btn-admin" style="display:none; gap:0.45rem; color:#5a7dbf; border-color:#c0cfe8;">
      <svg viewBox="0 0 16 16" fill="none" width="14" height="14">
        <path d="M10 8H3M3 8l2.5-2.5M3 8l2.5 2.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M8 4V3a1 1 0 011-1h3a1 1 0 011 1v10a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
      </svg>
      Entrar como alumno
    </button>
    <a href="/admin/alumnos" class="btn-admin">← Volver</a>
    <button id="btn-eliminar-alumno" class="btn-admin" style="display:none; color:#c33; border-color:#f5c6c6; margin-left:auto;">
      <svg viewBox="0 0 14 14" fill="none" width="13" height="13">
        <path d="M2 4h10M5 4V2.5h4V4M5.5 6.5v4M8.5 6.5v4M3 4l.75 7.5h6.5L11 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Eliminar alumno
    </button>
  </div>

</PlantillaAdmin>

<style is:global>
.pack-grupo { margin-bottom: 1.25rem; }
.pack-grupo-cabecera {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem 1rem;
  background: var(--color-light);
  border: 1.5px solid var(--color-primary);
  border-radius: 10px 10px 0 0;
  margin-bottom: -1px;
}
.pack-grupo-nombre { font-size: 0.85rem; font-weight: 800; flex: 1; color: var(--color-text); }
.pack-grupo-count  { font-size: 0.72rem; color: var(--color-text-muted); }
.btn-sel-pack      { font-size: 0.72rem; padding: 0.25rem 0.65rem; height: auto; border-radius: 6px; white-space: nowrap; }
.pack-grupo .modulo-item { border-radius: 0; border-top: none; }
.pack-grupo .modulo-item:last-child { border-radius: 0 0 10px 10px; }
.pack-grupo-solo-label {
  font-size: 0.65rem; font-weight: 700; text-transform: uppercase;
  letter-spacing: 0.1em; color: #bbb; margin: 1rem 0 0.5rem;
}
</style>

<script>
const params   = new URLSearchParams(window.location.search);
const alumnoId = parseInt(params.get('id') || '0', 10);
if (!alumnoId) window.location.href = '/admin/alumnos';

const msgGlobal = document.getElementById('msg-global') as HTMLDivElement;
function mostrarMsg(texto: string, tipo: 'ok' | 'error') {
  msgGlobal.textContent      = texto;
  msgGlobal.style.display    = 'block';
  msgGlobal.style.background = tipo === 'ok' ? '#f0faf5' : '#fdf0f0';
  msgGlobal.style.border     = `1px solid ${tipo === 'ok' ? '#b6e0cc' : '#f5c6c6'}`;
  msgGlobal.style.color      = tipo === 'ok' ? '#2e7d55' : '#a33';
  setTimeout(() => { msgGlobal.style.display = 'none'; }, 4000);
}

const PALETA = ['#b5d8cc','#b5c8e8','#d4c8e8','#e8d4b5','#e8c8b5','#c8e8b5'];
const cursosSeleccionados = new Set<number>();

async function cargar() {
  const [resAlumnos, resCursos] = await Promise.all([
    fetch('/api/alumnos.php'),
    fetch('/api/cursos.php'),
  ]);
  const [dataAlumnos, dataCursos] = await Promise.all([
    resAlumnos.json(),
    resCursos.json(),
  ]);

  const alumno = (dataAlumnos.alumnos ?? []).find((a: any) => a.id == alumnoId);
  if (!alumno) { window.location.href = '/admin/alumnos'; return; }

  const avatarEl = document.getElementById('perfil-inicial') as HTMLElement;
  avatarEl.textContent = alumno.nombre.charAt(0).toUpperCase();
  // Mostrar foto si existe
  fetch(`/api/foto-perfil.php?usuario_id=${alumnoId}`)
    .then(r => r.json())
    .then(d => {
      if (d.ok && d.url) {
        avatarEl.textContent = '';
        const img = document.createElement('img');
        img.src = d.url;
        img.style.cssText = 'width:100%;height:100%;object-fit:cover;border-radius:50%;';
        avatarEl.appendChild(img);
      }
    }).catch(() => {});

  (document.getElementById('perfil-nombre')  as HTMLElement).textContent = `${alumno.nombre} ${alumno.apellidos}`;
  (document.getElementById('perfil-email')   as HTMLElement).textContent = alumno.email;
  (document.getElementById('perfil-cabecera') as HTMLElement).style.display = 'flex';
  document.querySelector('.admin-header-titulo')!.textContent = `${alumno.nombre} ${alumno.apellidos}`;

  // ── Fechas de acceso ─────────────────────────────────────
  const inpAlta  = document.getElementById('inp-fecha-alta') as HTMLInputElement;
  const inpBaja  = document.getElementById('inp-fecha-baja') as HTMLInputElement;
  const badge    = document.getElementById('badge-acceso') as HTMLElement;
  const accesoWrap = document.getElementById('acceso-wrap') as HTMLElement;

  inpAlta.value = alumno.fecha_alta ?? '';
  inpBaja.value = alumno.fecha_baja ?? '';

  function actualizarBadge() {
    const baja = inpBaja.value;
    if (!baja) { badge.textContent = ''; return; }
    const hoy  = new Date(); hoy.setHours(0,0,0,0);
    const fin  = new Date(baja + 'T00:00:00');
    const dias = Math.round((fin.getTime() - hoy.getTime()) / 86400000);
    if (dias < 0) {
      badge.textContent = 'Expirada';
      badge.style.cssText = 'font-size:0.76rem;font-weight:700;padding:0.3rem 0.75rem;border-radius:20px;width:fit-content;white-space:nowrap;background:#fdf0f0;color:#c33;';
    } else if (dias <= 30) {
      badge.textContent = `Expira en ${dias} día${dias !== 1 ? 's' : ''}`;
      badge.style.cssText = 'font-size:0.76rem;font-weight:700;padding:0.3rem 0.75rem;border-radius:20px;width:fit-content;white-space:nowrap;background:#fff8e6;color:#a06010;';
    } else {
      badge.textContent = `Activa · ${dias} días`;
      badge.style.cssText = 'font-size:0.76rem;font-weight:700;padding:0.3rem 0.75rem;border-radius:20px;width:fit-content;white-space:nowrap;background:#e8f5ee;color:#2e7d55;';
    }
  }
  actualizarBadge();
  inpBaja.addEventListener('change', actualizarBadge);

  accesoWrap.style.display = 'block';

  // ── Cambiar contraseña del alumno ─────────────────────────
  const pwdWrap     = document.getElementById('pwd-wrap') as HTMLElement;
  const inpNueva    = document.getElementById('inp-nueva-pwd') as HTMLInputElement;
  const btnGenerar  = document.getElementById('btn-generar-pwd') as HTMLButtonElement;
  const btnCambiar  = document.getElementById('btn-cambiar-pwd') as HTMLButtonElement;
  const pwdAviso    = document.getElementById('pwd-aviso') as HTMLElement;
  pwdWrap.style.display = 'block';

  btnGenerar.addEventListener('click', () => {
    // 12 caracteres alfanuméricos legibles (sin 0/O, 1/I/l)
    const abc = 'ABCDEFGHJKMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789';
    let pwd = '';
    for (let i = 0; i < 12; i++) pwd += abc[Math.floor(Math.random() * abc.length)];
    inpNueva.value = pwd;
    inpNueva.focus();
  });

  btnCambiar.addEventListener('click', async () => {
    const nueva = inpNueva.value.trim();
    if (nueva.length < 6) { mostrarMsg('La contraseña debe tener al menos 6 caracteres.', 'error'); return; }
    const sesion = JSON.parse(localStorage.getItem('umme_sesion') || '{}');
    btnCambiar.disabled = true; btnCambiar.textContent = 'Guardando…';
    const res  = await fetch('/api/cambiar-password.php', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ usuario_id: alumnoId, password_nueva: nueva, actor_id: Number(sesion.userId || 0) }),
    });
    const data = await res.json();
    btnCambiar.disabled = false; btnCambiar.textContent = 'Guardar contraseña';
    if (data.ok) {
      mostrarMsg('✓ Contraseña actualizada.', 'ok');
      pwdAviso.textContent = `Nueva contraseña: ${nueva} — cópiala ahora, no se podrá ver de nuevo.`;
      pwdAviso.style.display = 'block';
    } else {
      mostrarMsg(data.mensaje || 'Error al cambiar la contraseña.', 'error');
    }
  });

  document.getElementById('btn-guardar-fechas')!.addEventListener('click', async () => {
    const btn = document.getElementById('btn-guardar-fechas') as HTMLButtonElement;
    // Validar que fecha_baja no sea anterior a fecha_alta
    if (inpAlta.value && inpBaja.value && inpBaja.value < inpAlta.value) {
      mostrarMsg('La fecha de baja no puede ser anterior a la fecha de alta.', 'error');
      return;
    }
    btn.disabled = true; btn.textContent = 'Guardando…';
    const res  = await fetch('/api/alumnos.php', {
      method: 'PUT', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ id: alumnoId, fecha_alta: inpAlta.value, fecha_baja: inpBaja.value }),
    });
    const data = await res.json();
    btn.disabled = false; btn.textContent = 'Guardar fechas';
    mostrarMsg(data.ok ? '✓ Fechas actualizadas.' : (data.mensaje || 'Error'), data.ok ? 'ok' : 'error');
    if (data.ok) actualizarBadge();
  });

  const [resMis, resProgreso] = await Promise.all([
    fetch(`/api/mis-cursos.php?usuario_id=${alumnoId}`),
    fetch(`/api/progreso.php?usuario_id=${alumnoId}`),
  ]);
  const [dataMis, dataProgreso] = await Promise.all([resMis.json(), resProgreso.json()]);
  const idsAsignados = new Set<number>((dataMis.cursos ?? []).map((c: any) => Number(c.id)));
  const temaVistos   = new Set<number>((dataProgreso.vistos ?? []).map(Number));

  // ── Mostrar progreso por curso ────────────────────────────
  const cursosConProgreso = dataMis.cursos ?? [];
  if (cursosConProgreso.length > 0) {
    const progresoWrap  = document.getElementById('progreso-wrap')!;
    const progresoLista = document.getElementById('progreso-lista')!;
    progresoWrap.style.display = 'block';
    progresoLista.innerHTML = '';

    cursosConProgreso.forEach((curso: any) => {
      const temas    = curso.temas ?? [];
      const total    = temas.length;
      const vistos   = temas.filter((t: any) => temaVistos.has(Number(t.id))).length;
      const pct      = total > 0 ? Math.round((vistos / total) * 100) : 0;
      const color    = curso.color || curso.pack_color || PALETA[Number(curso.id) % PALETA.length];

      const card = document.createElement('div');
      card.style.cssText = 'background:#fff; border:1px solid #e8eeec; border-radius:12px; padding:1rem 1.25rem; margin-bottom:0.75rem;';

      const temasList = temas.map((t: any) => {
        const visto = temaVistos.has(Number(t.id));
        return `<span style="display:inline-flex; align-items:center; gap:0.35rem; font-size:0.75rem;
          color:${visto ? '#2e7d55' : '#aaa'}; margin:0.15rem 0.25rem 0.15rem 0;">
          <svg viewBox="0 0 12 12" fill="none" width="11" height="11">
            ${visto
              ? '<circle cx="6" cy="6" r="5" fill="#42b286"/><path d="M3.5 6l1.5 1.5 3-3" stroke="white" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>'
              : '<circle cx="6" cy="6" r="5" stroke="#ddd" stroke-width="1.2"/>'}
          </svg>
          ${t.titulo}
        </span>`;
      }).join('');

      card.innerHTML = `
        <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:0.65rem;">
          <span style="width:10px; height:10px; border-radius:50%; background:${color}; flex-shrink:0;"></span>
          <span style="font-size:0.85rem; font-weight:700; flex:1; color:var(--color-text);">${curso.titulo}</span>
          <span style="font-size:0.78rem; font-weight:700; color:${pct === 100 ? '#2e7d55' : 'var(--color-text-muted)'};">${vistos}/${total} temas · ${pct}%</span>
        </div>
        <div style="height:6px; background:#e8eeed; border-radius:10px; overflow:hidden; margin-bottom:0.65rem;">
          <div style="height:100%; width:${pct}%; background:${color}; border-radius:10px; transition:width 0.4s;"></div>
        </div>
        <div style="display:flex; flex-wrap:wrap; gap:0;">${temasList}</div>
      `;
      progresoLista.appendChild(card);
    });
  }

  const cursosActivos = (dataCursos.cursos ?? []).filter((c: any) => c.activo == 1);
  const cargaEl    = document.getElementById('cursos-carga')!;
  const container  = document.getElementById('cursos-container')!;
  const vacioEl    = document.getElementById('cursos-vacio')!;
  const btnGuardar = document.getElementById('btn-guardar') as HTMLButtonElement;

  cargaEl.style.display = 'none';

  if (cursosActivos.length === 0) { vacioEl.style.display = 'block'; return; }

  container.style.display = 'block';
  btnGuardar.style.display = 'inline-flex';

  // Botón "Entrar como alumno"
  // ── Botón eliminar alumno ─────────────────────────────────
  const btnEliminar = document.getElementById('btn-eliminar-alumno') as HTMLButtonElement;
  btnEliminar.style.display = 'inline-flex';
  btnEliminar.addEventListener('click', async () => {
    if (!confirm(`¿Eliminar permanentemente a "${alumno.nombre}" (${alumno.email})?\n\nSe borrarán su cuenta, progreso y acceso a todos los cursos. Esta acción no se puede deshacer.`)) return;
    await window.botonCargando(btnEliminar, 'Eliminando…', async () => {
      const res  = await fetch(`/api/alumnos.php?id=${alumnoId}`, { method: 'DELETE' });
      const data = await res.json();
      if (data.ok) {
        window.location.href = '/admin/alumnos';
      } else {
        window.mostrarToast(data.mensaje || 'Error al eliminar', 'error');
      }
    });
  });

  const btnEntrar = document.getElementById('btn-entrar-como') as HTMLButtonElement;
  btnEntrar.style.display = 'inline-flex';
  btnEntrar.addEventListener('click', () => {
    const sesionAlumno = {
      userId: String(alumno.id),
      email:  alumno.email,
      nombre: alumno.nombre,
      rol:    'alumno',
      exp:    Date.now() + 4 * 60 * 60 * 1000, // 4 h
      esVistaAdmin: true,
    };
    // Guardar sesión temporal en localStorage para la nueva pestaña
    localStorage.setItem('umme_vista_admin', JSON.stringify(sesionAlumno));
    window.open('/inicio?vista-admin=1', '_blank');
  });

  renderCursosConPacks(cursosActivos, idsAsignados, container);

  btnGuardar.addEventListener('click', async () => {
    btnGuardar.disabled    = true;
    btnGuardar.textContent = 'Guardando…';
    const res  = await fetch('/api/alumnos.php', {
      method:  'PUT',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ id: alumnoId, cursos: Array.from(cursosSeleccionados) }),
    });
    const data = await res.json();
    btnGuardar.disabled    = false;
    btnGuardar.textContent = 'Guardar cambios';
    mostrarMsg(data.ok ? '✓ Cursos actualizados correctamente.' : (data.mensaje || 'Error al guardar'), data.ok ? 'ok' : 'error');
  });
}

function renderCursosConPacks(cursos: any[], idsAsignados: Set<number>, container: HTMLElement) {
  container.innerHTML = '';
  cursosSeleccionados.clear();

  const grupos = new Map<string, any[]>();
  for (const c of cursos) {
    const key = c.pack || '';
    if (!grupos.has(key)) grupos.set(key, []);
    grupos.get(key)!.push(c);
  }

  const hayPacks = [...grupos.keys()].some(k => k !== '');

  grupos.forEach((lista, pack) => {
    const esPack = pack !== '';

    if (esPack) {
      const grupo = document.createElement('div');
      grupo.className = 'pack-grupo modulos-grid';

      const cab = document.createElement('div');
      cab.className = 'pack-grupo-cabecera';
      cab.innerHTML = `
        <svg viewBox="0 0 18 18" fill="none" style="width:16px;height:16px;flex-shrink:0;">
          <rect x="1" y="5" width="16" height="11" rx="2" stroke="var(--color-primary)" stroke-width="1.6"/>
          <path d="M6 5V4a3 3 0 016 0v1" stroke="var(--color-primary)" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
        <span class="pack-grupo-nombre">${pack}</span>
        <span class="pack-grupo-count">${lista.length} curso${lista.length !== 1 ? 's' : ''}</span>
        <button type="button" class="btn-admin btn-sel-pack">Seleccionar pack</button>
      `;

      const btnSel = cab.querySelector('.btn-sel-pack') as HTMLButtonElement;
      btnSel.addEventListener('click', () => {
        const todosOn = lista.every(c => cursosSeleccionados.has(Number(c.id)));
        lista.forEach(c => {
          const id = Number(c.id);
          const item = grupo.querySelector<HTMLElement>(`[data-curso-id="${id}"]`);
          if (todosOn) { cursosSeleccionados.delete(id); item?.classList.remove('asignado'); }
          else          { cursosSeleccionados.add(id);    item?.classList.add('asignado'); }
        });
        actualizarBtnPack(btnSel, lista);
      });

      grupo.appendChild(cab);
      lista.forEach(curso => {
        const asignado = idsAsignados.has(Number(curso.id));
        if (asignado) cursosSeleccionados.add(Number(curso.id));
        grupo.appendChild(crearItemCurso(curso, asignado, btnSel, lista));
      });
      actualizarBtnPack(btnSel, lista);
      container.appendChild(grupo);

    } else {
      if (hayPacks && lista.length > 0) {
        const lbl = document.createElement('p');
        lbl.className = 'pack-grupo-solo-label';
        lbl.textContent = 'Cursos individuales';
        container.appendChild(lbl);
      }
      const grid = document.createElement('div');
      grid.className = 'modulos-grid';
      grid.style.marginBottom = '0.5rem';
      lista.forEach(curso => {
        const asignado = idsAsignados.has(Number(curso.id));
        if (asignado) cursosSeleccionados.add(Number(curso.id));
        grid.appendChild(crearItemCurso(curso, asignado, null, []));
      });
      container.appendChild(grid);
    }
  });
}

function actualizarBtnPack(btn: HTMLButtonElement, lista: any[]) {
  const todosOn = lista.every(c => cursosSeleccionados.has(Number(c.id)));
  btn.textContent   = todosOn ? 'Quitar pack' : 'Seleccionar pack';
  btn.style.background  = todosOn ? 'var(--color-primary)' : '';
  btn.style.borderColor = todosOn ? 'var(--color-primary)' : '';
  btn.style.color       = todosOn ? '#1a2e28' : '';
}

function crearItemCurso(curso: any, asignado: boolean, btnPack: HTMLButtonElement | null, packLista: any[]): HTMLElement {
  const item = document.createElement('div');
  item.className       = `modulo-item${asignado ? ' asignado' : ''}`;
  item.dataset.cursoId = String(curso.id);
  item.innerHTML = `
    <div class="modulo-checkbox">
      <svg viewBox="0 0 11 9" fill="none">
        <path d="M1 4l3 3 6-6" stroke="#fff" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <div class="modulo-acento" style="background:${curso.color || curso.pack_color || PALETA[Number(curso.id) % PALETA.length]}"></div>
    <div class="modulo-info">
      <p class="modulo-titulo">${curso.titulo}</p>
      <p class="modulo-meta">${curso.etiqueta} · ${curso.nivel}${curso.duracion ? ' · ' + curso.duracion : ''}</p>
    </div>
  `;
  item.addEventListener('click', () => {
    const id = Number(item.dataset.cursoId);
    if (cursosSeleccionados.has(id)) { cursosSeleccionados.delete(id); item.classList.remove('asignado'); }
    else                              { cursosSeleccionados.add(id);    item.classList.add('asignado'); }
    if (btnPack) actualizarBtnPack(btnPack, packLista);
  });
  return item;
}

cargar();
</script>
