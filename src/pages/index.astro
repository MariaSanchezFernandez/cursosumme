---
/**
 * PÁGINA: Home (Login)
 * --------------------
 * Primera página que ve el usuario. Muestra la pantalla de acceso.
 * Delega la estructura visual a LoginCard y el fondo a LoginBackground.
 */
import Layout from '../layouts/Layout.astro';
import LoginCard from '../components/LoginCard.astro';
import LoginBackground from '../components/LoginBackground.astro';
---

<Layout>
  <!-- Fondo animado (nubes + globo). Queda por debajo de la tarjeta -->
  <LoginBackground />

  <!-- Tarjeta de login centrada. z-index 1 para quedar sobre el fondo -->
  <main class="login-page">
    <LoginCard />
  </main>
</Layout>

<style>
  /* Centra la tarjeta. Sin background: lo pone el body en global.css */
  .login-page {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>
