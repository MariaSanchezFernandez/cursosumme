}

/* ───────────────────────────────────────────────────────────────
   CTA final
   ─────────────────────────────────────────────────────────────── */
.cta-final {
  padding: 4.5rem 1.5rem;
  /* Coral diluido (~18%) plano: cálido pero discreto, marca claramente
     que la sección es un cierre sin gritar como hacía el turquesa pleno. */
  background: color-mix(in srgb, var(--color-coral) 18%, #ffffff);
}
.cta-final-inner {
  max-width: 720px;
  margin: 0 auto;
  text-align: center;
}
.cta-final h2 {
