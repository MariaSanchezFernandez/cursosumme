  margin-bottom: 0.75rem;
}
.cta-final p {
  color: var(--color-text);
  margin-bottom: 1.75rem;
  font-size: 1rem;
}

/* ───────────────────────────────────────────────────────────────
   Animaciones globales
   - .animar-entrada: estado inicial (oculto + desplazado).
   - .animar-entrada.visible: estado final (visible + en su sitio).
   - El IntersectionObserver del script añade .visible al entrar.
   - prefers-reduced-motion: si el sistema lo pide, anulamos TODO
     el movimiento (blobs, fade-in, bounce, transforms).
   ─────────────────────────────────────────────────────────────── */
.animar-entrada {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.7s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  will-change: opacity, transform;
}
.animar-entrada.visible {
  opacity: 1;
  transform: translateY(0);
}
/* Escalonado: cada hijo entra 80 ms después del anterior */
.animar-entrada-cascada > * {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.6s ease, transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
}
.animar-entrada-cascada.visible > *           { opacity: 1; transform: none; }
.animar-entrada-cascada.visible > *:nth-child(1) { transition-delay: 0.00s; }
.animar-entrada-cascada.visible > *:nth-child(2) { transition-delay: 0.08s; }
.animar-entrada-cascada.visible > *:nth-child(3) { transition-delay: 0.16s; }
.animar-entrada-cascada.visible > *:nth-child(4) { transition-delay: 0.24s; }
.animar-entrada-cascada.visible > *:nth-child(5) { transition-delay: 0.32s; }
.animar-entrada-cascada.visible > *:nth-child(6) { transition-delay: 0.40s; }

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation: none !important;
    transition: none !important;
  }
  .animar-entrada,
  .animar-entrada-cascada > * { opacity: 1 !important; transform: none !important; }
  .hero-deco { display: none !important; }
}

/* ───────────────────────────────────────────────────────────────
   Responsive
   ─────────────────────────────────────────────────────────────── */
@media (max-width: 720px) {
  .hero { padding: 3.5rem 1.25rem 4rem; }
  .seccion { padding: 3.5rem 1.25rem; }
  .cta-final { padding: 3.5rem 1.25rem; }
  .hero-ctas .cta { flex: 1 1 auto; min-width: 0; }
}
