}
.lema-eyebrow {
  font-size: 0.74rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  color: var(--color-text);
  opacity: 0.65;
  margin-bottom: 1.5rem;
}
.lema-frase {
  font-size: clamp(1.6rem, 4vw, 2.6rem);
  font-weight: 800;
  line-height: 1.25;
  letter-spacing: -0.015em;
  margin: 0 0 1.5rem;
  color: var(--color-text);
  quotes: none;
}
.lema-acento {
  display: inline;
  background: linear-gradient(180deg, transparent 65%, rgba(255,255,255,0.85) 65%);
