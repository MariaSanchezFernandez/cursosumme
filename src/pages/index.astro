<script>
// ───────────────────────────────────────────────────────────────
// Sección destacados: dos carruseles (packs y cursos individuales).
// Datos reales desde /api/packs.php y /api/cursos.php?publicos=1.
// Si falla la API, mostramos un fallback con link a /precios.
//
// Carrusel:
//   - Pista con overflow-x:auto + scroll-snap-type:x mandatory.
//   - Flechas: scroll por ancho de una tarjeta (con gap).
//   - Dots dinámicos: una por cada "página" de tarjetas visible.
//   - Las flechas se deshabilitan en los extremos.
// ───────────────────────────────────────────────────────────────
const PALETA = ['#b3e8da','#b5c8e8','#d4c8e8','#fff8b7','#ffb5a7','#c8e8b5'];

interface PackApi  { id: number; nombre: string; descripcion?: string; precio?: string | number; }
interface CursoApi { id: number; titulo: string; etiqueta?: string; color?: string; precio?: string | number; num_temas?: number | string; puntos?: string[]; duracion_seg?: number | string; }

function formateaPrecio(valor: string | number): string {
  return parseFloat(String(valor)).toFixed(2).replace('.', ',');
}

function escapar(texto: string): string {
  return texto
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

function pintarPacks(packs: PackApi[]) {
  const wrap = document.getElementById('carrusel-packs-wrap')!;
  const pista = document.getElementById('carrusel-packs')!;
  const controles = document.getElementById('carrusel-packs-controles')!;
  const dotsCont = document.getElementById('carrusel-packs-dots')!;
  if (packs.length === 0) return;
  wrap.style.display = 'block';
  pista.innerHTML = '';
  // ≤2 packs: render como grid wrap, sin flechas ni dots.
  const modoGrid = packs.length <= 2;
  if (modoGrid) {
    wrap.classList.add('carrusel--grid');
    controles.style.display = 'none';
    dotsCont.style.display = 'none';
  } else {
    wrap.classList.remove('carrusel--grid');
    controles.style.display = '';
    dotsCont.style.display = '';
  }
  packs.forEach((pack, idx) => {
    const color = PALETA[idx % PALETA.length];
    const card  = document.createElement('article');
    card.className = 'tarjeta-curso tarjeta-curso--pack';
    card.style.setProperty('--curso-color', color);
    // Misma estructura que los cursos individuales: chip + título +
    // checklist de 4 items + pie con precio. Así packs y cursos son
    // visualmente idénticos dentro del carrusel.
    const items = [
      'Todos los cursos del pack',
      'Apuntes y materiales descargables',
      'Ahorra frente a comprarlos sueltos',
    ];
    card.innerHTML = `
      <div class="tarjeta-curso-acento"></div>
      <div class="tarjeta-curso-body">
        <span class="tarjeta-curso-chip tarjeta-curso-chip--pack">Pack completo</span>
        <h3 class="tarjeta-curso-titulo">${escapar(pack.nombre)}</h3>
        <ul class="tarjeta-curso-checklist">${items.map((p) => `<li>${p}</li>`).join('')}</ul>
        <div class="tarjeta-curso-pie">
          <span class="tarjeta-curso-precio">${formateaPrecio(pack.precio ?? 0)} €</span>
          <a href="/precios#packs" class="tarjeta-curso-link">Ver detalles →</a>
        </div>
      </div>
    `;
    pista.appendChild(card);
  });
  if (!modoGrid) configurarCarrusel('carrusel-packs');
}

function pintarCursos(cursos: (CursoApi & { imagen?: string })[]) {
  const wrap = document.getElementById('carrusel-cursos-wrap')!;
  const pista = document.getElementById('carrusel-cursos')!;
  if (cursos.length === 0) return;
  wrap.style.display = 'block';
  pista.innerHTML = '';
  cursos.forEach((curso, idx) => {
    const color    = curso.color || PALETA[idx % PALETA.length];
    const numTemas = Number(curso.num_temas ?? 0);
    const puntosRaw: string[] = Array.isArray(curso.puntos) ? curso.puntos : [];
    const card     = document.createElement('a');
    card.className = 'tarjeta-curso';
    card.style.setProperty('--curso-color', color);
    card.setAttribute('href', `/cursos/${curso.id}`);
    // Lista compacta — máx 4 ideas. El nº de temas va como primer punto
    // (no pill aparte) y luego los puntos personalizados del curso.
    const items: string[] = [];
    if (numTemas > 0) items.push(`${numTemas} ${numTemas === 1 ? 'tema' : 'temas'} en vídeo`);
    for (const p of puntosRaw) {
      if (items.length >= 4) break;
      items.push(p);
    }
    const checklistHtml = items.length > 0
      ? `<ul class="tarjeta-curso-checklist">${items.map((p) => `<li>${escapar(p)}</li>`).join('')}</ul>`
      : '';
    card.innerHTML = `
      <div class="tarjeta-curso-acento"></div>
      <div class="tarjeta-curso-body">
        ${curso.etiqueta ? `<span class="tarjeta-curso-chip">${escapar(curso.etiqueta)}</span>` : ''}
        <h3 class="tarjeta-curso-titulo">${escapar(curso.titulo)}</h3>
        ${checklistHtml}
        <div class="tarjeta-curso-pie">
          <span class="tarjeta-curso-precio">${formateaPrecio(curso.precio ?? 0)} €</span>
          <span class="tarjeta-curso-link">Ver detalle →</span>
        </div>
      </div>
    `;
    pista.appendChild(card);
  });
  configurarCarrusel('carrusel-cursos');
}

// ── Carrusel: flechas, dots, observers ───────────────────────
function configurarCarrusel(id: string) {
  // El guard `if (!_p) return` no se preserva en funciones anidadas: TS asume
  // que la variable puede haber cambiado. Reasignamos a `const pista: HTMLElement`
  // (no-null) para que el narrowing sobreviva dentro de las callbacks.
  const _p = document.getElementById(id);
  if (!_p) return;
  const pista: HTMLElement = _p;
  if (!pista.querySelector(':scope > *')) return;

  const dotsCont = document.getElementById(id + '-dots');
  const flechas = document.querySelectorAll<HTMLButtonElement>(
    `.carrusel-flecha[data-target="${id}"]`,
  );

  // Avance de cada flecha = "página" completa (N tarjetas visibles)
  // para que el snap caiga limpio en el siguiente grupo.
  function pasoPagina(): number {
    const t = pista.querySelector(':scope > *') as HTMLElement | null;
    if (!t) return pista.clientWidth;
    const cs = window.getComputedStyle(pista);
    const gap = parseFloat(cs.columnGap || cs.gap || '16') || 16;
    const tarjeta = t.getBoundingClientRect().width;
    const visibles = Math.max(1, Math.floor((pista.clientWidth + gap) / (tarjeta + gap)));
    return visibles * (tarjeta + gap);
  }

  flechas.forEach((btn) => {
    btn.addEventListener('click', () => {
      const dir = Number(btn.dataset.dir || '1');
      pista.scrollBy({ left: pasoPagina() * dir, behavior: 'smooth' });
    });
  });

  // Dots: una por cada "página" (cuántas tarjetas caben de una vez).
  function pintarDots() {
    if (!dotsCont) return;
    const cont: HTMLElement = dotsCont;
    const ancho = pista.clientWidth;
    const total = pista.scrollWidth;
    const paginas = Math.max(1, Math.ceil(total / ancho));
    cont.innerHTML = '';
    if (paginas <= 1) { cont.style.display = 'none'; return; }
    cont.style.display = '';
    for (let i = 0; i < paginas; i++) {
      const dot = document.createElement('button');
      dot.className = 'carrusel-dot';
      dot.type = 'button';
      dot.setAttribute('aria-label', `Ir a página ${i + 1}`);
      dot.addEventListener('click', () => {
        pista.scrollTo({ left: ancho * i, behavior: 'smooth' });
      });
      cont.appendChild(dot);
    }
    actualizarEstado();
  }

  function actualizarEstado() {
    const maxScroll = pista.scrollWidth - pista.clientWidth;
    const x = pista.scrollLeft;
    flechas.forEach((b) => {
      const dir = Number(b.dataset.dir || '1');
      if (dir < 0) b.disabled = x <= 2;
      else         b.disabled = x >= maxScroll - 2;
    });
    if (dotsCont) {
      const ancho = pista.clientWidth || 1;
      const activa = Math.round(x / ancho);
      dotsCont.querySelectorAll('.carrusel-dot').forEach((d, i) => {
        d.classList.toggle('activo', i === activa);
      });
    }
  }

  pista.addEventListener('scroll', actualizarEstado, { passive: true });
  window.addEventListener('resize', pintarDots);
  pintarDots();
}

async function cargarDestacados() {
  const loading = document.getElementById('destacados-loading')!;
  const errorEl = document.getElementById('destacados-error')!;
  try {
    const [resPacks, resCursos] = await Promise.all([
      fetch('/api/packs.php'),
      fetch('/api/cursos.php?publicos=1'),
    ]);
    const dataPacks  = await resPacks.json();
    const dataCursos = await resCursos.json();

    // Orden ascendente por precio: más barato primero. parseFloat
    // tolera tanto strings ("12.50") como números (12.5) — la API
    // devuelve DECIMAL como string en la mayoría de drivers MySQL.
    const porPrecio = (a: { precio?: string | number }, b: { precio?: string | number }) =>
      parseFloat(String(a.precio ?? 0)) - parseFloat(String(b.precio ?? 0));

    const packs  = (dataPacks.packs   ?? []).filter((p: PackApi)  => p.precio).sort(porPrecio);
    const cursos = (dataCursos.cursos ?? []).filter((c: CursoApi) => c.precio).sort(porPrecio);

    loading.remove();

    if (packs.length === 0 && cursos.length === 0) {
      errorEl.textContent = 'Pronto añadiremos nuevos cursos. Mientras tanto, ';
      const a = document.createElement('a');
      a.href = '/precios';
      a.textContent = 'visita el catálogo completo →';
      errorEl.appendChild(a);
      errorEl.style.display = 'block';
      return;
    }

    // Cursos antes que packs (orden de las llamadas no afecta al
    // orden visual — eso lo decide el HTML — pero por coherencia).
    pintarCursos(cursos);
    pintarPacks(packs);
    activarObserverEnNuevos();
  } catch {
    loading.remove();
    errorEl.style.display = 'block';
  }
}

// ───────────────────────────────────────────────────────────────
// IntersectionObserver: marca .animar-entrada como .visible al entrar
// en viewport. Una sola vez por elemento (disconnect tras visible).
// ───────────────────────────────────────────────────────────────
const observer = new IntersectionObserver(
  (entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  },
  { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
);

function activarObserverEnNuevos() {
  document.querySelectorAll('.animar-entrada, .animar-entrada-cascada').forEach((el) => {
    if (!el.classList.contains('visible')) observer.observe(el);
  });
}
activarObserverEnNuevos();

cargarDestacados();
</script>
