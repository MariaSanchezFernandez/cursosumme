# ════════════════════════════════════════════════════════════════════
# .htaccess de cursosumme.es (servido por Apache de IONOS)
# ════════════════════════════════════════════════════════════════════

# ── Reescritura ──────────────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1) Mantener el header Authorization, que IONOS Apache descarta
    #    en algunos verbos/rutas. Lo movemos a una variable de entorno
    #    que PHP sí puede leer (HTTP_AUTHORIZATION). Necesario para
    #    Stripe webhooks, logout y otros endpoints.
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # 2) Canonicalizar el dominio en UNA sola redirección 301:
    #    - http://*           → https://cursosumme.es/...
    #    - https://www....    → https://cursosumme.es/...
    #    Así Google no ve 4 versiones de cada página (http/https y
    #    www/no-www) compitiendo entre sí como contenido duplicado.
    RewriteCond %{HTTPS} !=on [OR]
    RewriteCond %{HTTP_HOST} ^www\.cursosumme\.es$ [NC]
    RewriteRule ^(.*)$ https://cursosumme.es/$1 [R=301,L]
</IfModule>

# ── Cabeceras de respuesta ───────────────────────────────────────────
<IfModule mod_headers.c>
    # Permite reproducción de vídeo VdoCipher (DRM).
    Header always set Permissions-Policy "autoplay=*, encrypted-media=*"

    # HSTS — fuerza HTTPS en los próximos accesos del navegador.
    # 1 año (31.536.000 s) es el estándar; subsiguiente al SSL ya activo.
    # No usamos `preload` porque eso requiere registro en la lista de
    # Chrome y es un compromiso difícil de revertir.
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # Defensa básica frente a clickjacking. SAMEORIGIN permite incrustar
    # tu propio sitio en un iframe propio (lo necesita VdoCipher: el
    # reproductor de vídeo va en iframe interno).
    Header always set X-Frame-Options "SAMEORIGIN"

    # Evita que el navegador adivine el Content-Type a partir del contenido.
    Header always set X-Content-Type-Options "nosniff"

    # Solo envía el referrer a la misma jurisdicción de origen.
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # ── Cache larga para assets versionados de Astro ─────────────────
    # Los archivos de /_astro/ ya llevan hash en el nombre (p.ej.
    # `aviso-legal.BYll8-m1.css`); cambian de URL al cambiar de contenido,
    # así que se pueden cachear de forma agresiva.
    <FilesMatch "\.(css|js|woff2?|svg|png|jpg|jpeg|gif|webp|avif|ico)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # HTML siempre fresco (las URLs no llevan hash y queremos que los
    # cambios se vean en cuanto se despliegan).
    <FilesMatch "\.html$">
        Header set Cache-Control "no-cache"
    </FilesMatch>
</IfModule>

# ── Compresión ───────────────────────────────────────────────────────
# Ya está activa en IONOS por defecto, pero la dejamos explícita por si
# alguna vez cambian la config del servidor.
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/json application/xml
    AddOutputFilterByType DEFLATE image/svg+xml font/woff font/woff2
</IfModule>
